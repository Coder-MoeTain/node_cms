{
  "name": "Classic Blog",
  "slug": "classic-blog",
  "version": "1.0.0",
  "author": "NodePress",
  "description": "A balanced classic blog layout — the default NodePress starter theme.",
  "parent": null,
  "layouts": ["default", "sidebar-left", "sidebar-right"],
  "templates": ["home", "blog", "post", "page", "archive", "search", "contact", "error"],
  "supports": ["logo", "favicon", "menus", "widgets", "customColors", "darkMode", "customCss"],
  "screenshot": "/themes/classic-blog/screenshot.svg",
  "defaults": {
    "preset": "classic-blue",
    "primary_color": "#2271b1",
    "secondary_color": "#50575e",
    "background_color": "#ffffff",
    "text_color": "#1d2327",
    "header_layout": "standard",
    "footer_layout": "four-columns",
    "sidebar_position": "right",
    "blog_layout": "grid",
    "site_layout": "full-width"
  }
}
