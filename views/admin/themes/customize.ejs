<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main np-customizer-page">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header">
      <h1>Customize</h1>
      <a class="np-btn np-btn-secondary" href="/admin/themes">Installed Themes</a>
    </div>
    <%- include('../partials/settings-nav') %>

    <% const customCss = themeSetting.custom_css || '';
       const linkMatch = customCss.match(/--site-link:\s*([^;\s]+)/i);
       const buttonMatch = customCss.match(/--site-button:\s*([^;\s]+)/i);
       const linkColor = linkMatch ? linkMatch[1].trim() : (themeSetting.primary_color || '#2271b1');
       const buttonColor = buttonMatch ? buttonMatch[1].trim() : (themeSetting.primary_color || '#2271b1');
       const accentColor = (themeVars && themeVars.accent) || '#d71920';
       const cardColor = (themeVars && themeVars.card) || '#ffffff';
       const footerColor = (themeVars && themeVars.footer) || '#0b2f47';
       const mutedColor = (themeVars && themeVars.muted) || '#6b7280';
       const cssWithoutVars = typeof cssWithoutManaged !== 'undefined' ? cssWithoutManaged : customCss.replace(/\/\* np-theme-vars \*\/[\s\S]*?\}\s*/g, '').replace(/\/\* np-portal-config \*\/[\s\S]*?(?=\n\n|$)/g, '').trim();
       const pc = portalConfig || {};
       const ph = pc.homepage || {};
       const phdr = pc.header || {};
       const pnav = pc.nav || {};
       const pw = pc.widgets || {};
    %>

    <form method="post" action="/admin/theme-settings?_method=PUT&_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data" data-theme-customizer>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="np-customizer-shell">
        <div class="np-customizer-panel">
          <p class="np-customizer-section-title">Color presets</p>
          <div class="theme-preset-grid" role="group" aria-label="Color presets">
            <% const presets = [
              { id: 'wordpress-blue', label: 'WordPress Blue', primary: '#2271b1', secondary: '#50575e', bg: '#ffffff', text: '#1d2327' },
              { id: 'modern-indigo', label: 'Modern Indigo', primary: '#4f46e5', secondary: '#6366f1', bg: '#ffffff', text: '#1e1b4b' },
              { id: 'clean-green', label: 'Clean Green', primary: '#008a20', secondary: '#50575e', bg: '#ffffff', text: '#1d2327' },
              { id: 'dark-slate', label: 'Dark Slate', primary: '#38bdf8', secondary: '#64748b', bg: '#0f172a', text: '#f8fafc' },
              { id: 'warm-orange', label: 'Warm Orange', primary: '#d97706', secondary: '#78716c', bg: '#fffbeb', text: '#292524' },
              { id: 'minimal-gray', label: 'Minimal Gray', primary: '#50575e', secondary: '#646970', bg: '#f6f7f7', text: '#1d2327' },
              { id: 'myanmar-portal', label: 'Myanmar Portal', primary: '#006ba6', secondary: '#ffcc00', bg: '#e8edf2', text: '#2b2b2b', accent: '#e4282c', card: '#ffffff', footer: '#0c3d5c', muted: '#5a6570', border: '#c5d3de', headerLayout: 'portal' }
            ]; %>
            <% presets.forEach(function(preset) { %>
              <button class="theme-preset-btn <%= (pc.preset || themePreset) === preset.id ? 'active' : '' %>" type="button" data-theme-preset="<%= preset.id %>" data-primary="<%= preset.primary %>" data-secondary="<%= preset.secondary %>" data-bg="<%= preset.bg %>" data-text="<%= preset.text %>" data-accent="<%= preset.accent || '' %>" data-card="<%= preset.card || '' %>" data-footer="<%= preset.footer || '' %>" data-muted="<%= preset.muted || '' %>" data-border="<%= preset.border || '' %>" data-header-layout="<%= preset.headerLayout || '' %>"><%= preset.label %></button>
            <% }) %>
          </div>

          <div class="np-customizer-section">
            <p class="np-customizer-section-title">Colors</p>
            <div class="np-color-grid">
              <div class="np-color-field"><label for="primary_color">Primary</label><input class="form-control" id="primary_color" name="primary_color" type="color" value="<%= themeSetting.primary_color || '#2271b1' %>" data-preview-primary></div>
              <div class="np-color-field"><label for="secondary_color">Secondary</label><input class="form-control" id="secondary_color" name="secondary_color" type="color" value="<%= themeSetting.secondary_color || '#50575e' %>" data-preview-secondary></div>
              <div class="np-color-field"><label for="background_color">Background</label><input class="form-control" id="background_color" name="background_color" type="color" value="<%= themeSetting.background_color || '#ffffff' %>" data-preview-bg></div>
              <div class="np-color-field"><label for="text_color">Text</label><input class="form-control" id="text_color" name="text_color" type="color" value="<%= themeSetting.text_color || '#1d2327' %>" data-preview-text></div>
              <div class="np-color-field"><label for="link_color">Links</label><input class="form-control" id="link_color" type="color" value="<%= linkColor %>" data-preview-link></div>
              <div class="np-color-field"><label for="button_color">Buttons</label><input class="form-control" id="button_color" type="color" value="<%= buttonColor %>" data-preview-button-color></div>
              <div class="np-color-field"><label for="accent_color">Accent</label><input class="form-control" id="accent_color" type="color" value="<%= accentColor %>" data-preview-accent></div>
              <div class="np-color-field"><label for="card_color">Card</label><input class="form-control" id="card_color" type="color" value="<%= cardColor %>" data-preview-card></div>
              <div class="np-color-field"><label for="footer_color">Footer</label><input class="form-control" id="footer_color" type="color" value="<%= footerColor %>" data-preview-footer></div>
              <div class="np-color-field"><label for="muted_color">Muted text</label><input class="form-control" id="muted_color" type="color" value="<%= mutedColor %>" data-preview-muted></div>
            </div>
            <p class="np-help-text mt-2">Link and button colors are stored in Additional CSS as <code>--site-link</code> and <code>--site-button</code>.</p>
          </div>

          <div class="np-customizer-section">
            <p class="np-customizer-section-title">Site identity</p>
            <div class="np-identity-preview">
              <img data-logo-preview src="<%= themeSetting.logo || '' %>" alt="Logo preview" <%= themeSetting.logo ? '' : 'hidden' %>>
              <img data-favicon-preview src="<%= themeSetting.favicon || '' %>" alt="Favicon preview" <%= themeSetting.favicon ? '' : 'hidden' %>>
              <span class="text-muted small">Logo and favicon previews update when you pick media.</span>
            </div>
            <div class="row g-3">
              <div class="col-md-6"><%- include('../partials/image-upload-field', { label: 'Logo', name: 'logo', fileName: 'logo_file', value: themeSetting.logo || '' }) %></div>
              <div class="col-md-6"><%- include('../partials/image-upload-field', { label: 'Favicon', name: 'favicon', fileName: 'favicon_file', value: themeSetting.favicon || '' }) %></div>
            </div>
          </div>

          <div class="np-customizer-section">
            <p class="np-customizer-section-title">Layout &amp; typography</p>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label" for="font_family">Font family</label>
                <select class="form-select" id="font_family" name="font_family" data-font-select>
                  <% const fonts = [
                    { value: 'Georgia, "Times New Roman", serif', label: 'Georgia (Classic)' },
                    { value: '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif', label: 'System Sans' },
                    { value: 'Inter, Arial, sans-serif', label: 'Inter' },
                    { value: '"Source Sans 3", Arial, sans-serif', label: 'Source Sans' },
                    { value: 'Merriweather, Georgia, serif', label: 'Merriweather' },
                    { value: 'Lora, Georgia, serif', label: 'Lora' }
                  ];
                  const currentFont = themeSetting.font_family || 'Georgia, serif';
                  fonts.forEach(function(font) { %>
                    <option value="<%= font.value %>" <%= currentFont === font.value ? 'selected' : '' %>><%= font.label %></option>
                  <% }); %>
                  <option value="__custom__" <%= fonts.every(function(f){ return f.value !== currentFont; }) ? 'selected' : '' %>>Custom…</option>
                </select>
                <input class="form-control mt-2 <%= fonts.some(function(f){ return f.value === currentFont; }) ? 'd-none' : '' %>" id="font_family_custom" data-font-custom value="<%= currentFont %>" placeholder="Custom font stack">
              </div>
              <div class="col-md-6"><label class="form-label" for="sidebar_position">Sidebar position</label><select class="form-select" id="sidebar_position" name="sidebar_position"><% ['right','left','none'].forEach(function(value) { %><option value="<%= value %>" <%= themeSetting.sidebar_position === value ? 'selected' : '' %>><%= value %></option><% }) %></select></div>
              <div class="col-md-6"><label class="form-label" for="header_layout">Header layout</label><select class="form-select" id="header_layout" name="header_layout" data-portal-header-layout><% ['standard','centered','minimal','portal'].forEach(function(value) { %><option value="<%= value %>" <%= (themeSetting.header_layout || 'standard') === value ? 'selected' : '' %>><%= value %></option><% }) %></select></div>
              <div class="col-md-6"><label class="form-label" for="footer_layout">Footer layout</label><select class="form-select" id="footer_layout" name="footer_layout"><% ['four-columns','simple','minimal'].forEach(function(value) { %><option value="<%= value %>" <%= (themeSetting.footer_layout || 'four-columns') === value ? 'selected' : '' %>><%= value %></option><% }) %></select></div>
              <div class="col-md-6"><label class="form-label" for="blog_layout">Blog layout</label><select class="form-select" id="blog_layout" name="blog_layout"><% ['grid','list','masonry'].forEach(function(value) { %><option value="<%= value %>" <%= themeSetting.blog_layout === value ? 'selected' : '' %>><%= value %></option><% }) %></select></div>
              <div class="col-md-6"><label class="form-label" for="site_layout">Site layout</label><select class="form-select" id="site_layout" name="site_layout"><option value="full-width" <%= ['full-width','wide'].includes(themeSetting.site_layout) ? 'selected' : '' %>>Full width</option><option value="boxed" <%= themeSetting.site_layout === 'boxed' ? 'selected' : '' %>>Boxed</option></select></div>
              <div class="col-md-6 d-flex align-items-end"><label class="form-check"><input class="form-check-input" name="dark_mode" type="checkbox" <%= themeSetting.dark_mode ? 'checked' : '' %>> Enable dark mode</label></div>
            </div>
          </div>

          <div class="np-customizer-section" data-portal-options>
            <p class="np-customizer-section-title">Portal header &amp; navigation</p>
            <div class="row g-2">
              <div class="col-md-6"><label class="form-check"><input class="form-check-input" type="checkbox" data-portal-opt="header.showUtilityBar" <%= phdr.showUtilityBar ? 'checked' : '' %>> Show utility bar</label></div>
              <div class="col-md-6"><label class="form-check"><input class="form-check-input" type="checkbox" data-portal-opt="header.showFontControls" <%= phdr.showFontControls ? 'checked' : '' %>> Font size controls</label></div>
              <div class="col-md-6"><label class="form-check"><input class="form-check-input" type="checkbox" data-portal-opt="header.showLanguageSwitcher" <%= phdr.showLanguageSwitcher ? 'checked' : '' %>> Language switcher</label></div>
              <div class="col-md-6"><label class="form-check"><input class="form-check-input" type="checkbox" data-portal-opt="header.showLoginLinks" <%= phdr.showLoginLinks ? 'checked' : '' %>> Login / register links</label></div>
              <div class="col-md-6"><label class="form-check"><input class="form-check-input" type="checkbox" data-portal-opt="header.showSearch" <%= phdr.showSearch ? 'checked' : '' %>> Search box</label></div>
              <div class="col-md-6"><label class="form-check"><input class="form-check-input" type="checkbox" data-portal-opt="nav.megaMenu" <%= pnav.megaMenu ? 'checked' : '' %>> Mega menu</label></div>
              <div class="col-md-6"><label class="form-check"><input class="form-check-input" type="checkbox" data-portal-opt="nav.sticky" <%= pnav.sticky ? 'checked' : '' %>> Sticky navigation</label></div>
              <div class="col-md-6">
                <label class="form-label" for="portal_nav_style">Menu style</label>
                <select class="form-select" id="portal_nav_style" data-portal-opt-select="nav.style">
                  <option value="simple" <%= pnav.style === 'simple' ? 'selected' : '' %>>Simple</option>
                  <option value="portal" <%= pnav.style === 'portal' ? 'selected' : '' %>>Portal</option>
                  <option value="card" <%= pnav.style === 'card' ? 'selected' : '' %>>Card dropdown</option>
                </select>
              </div>
            </div>
          </div>

          <div class="np-customizer-section" data-portal-options>
            <p class="np-customizer-section-title">Homepage sections</p>
            <div class="row g-2">
              <% const homeOpts = [
                { key: 'homepage.hero', label: 'Hero slider', checked: ph.hero },
                { key: 'homepage.quickLinks', label: 'Quick service cards', checked: ph.quickLinks },
                { key: 'homepage.emergency', label: 'Emergency contacts', checked: ph.emergency },
                { key: 'homepage.latestNews', label: 'Latest news', checked: ph.latestNews },
                { key: 'homepage.announcements', label: 'Announcements', checked: ph.announcements },
                { key: 'homepage.tendersJobs', label: 'Tenders / jobs', checked: ph.tendersJobs },
                { key: 'homepage.mobileApp', label: 'Mobile app promotion', checked: ph.mobileApp },
                { key: 'homepage.mediaGallery', label: 'Media gallery', checked: ph.mediaGallery },
                { key: 'homepage.hotNews', label: 'Hot news', checked: ph.hotNews },
                { key: 'homepage.subscribe', label: 'Subscribe', checked: ph.subscribe },
                { key: 'homepage.statistics', label: 'Statistics', checked: ph.statistics },
                { key: 'homepage.sectionNav', label: 'Homepage section navigation', checked: ph.sectionNav },
                { key: 'homepage.announcementTicker', label: 'Announcement ticker bar', checked: ph.announcementTicker }
              ]; %>
              <% homeOpts.forEach(function(opt) { %>
                <div class="col-md-6"><label class="form-check"><input class="form-check-input" type="checkbox" data-portal-opt="<%= opt.key %>" <%= opt.checked ? 'checked' : '' %>> <%= opt.label %></label></div>
              <% }) %>
            </div>
            <div class="mt-3">
              <label class="form-label" for="portal_card_style">Card style</label>
              <select class="form-select" id="portal_card_style" data-portal-opt-select="widgets.cardStyle">
                <option value="flat" <%= pw.cardStyle === 'flat' ? 'selected' : '' %>>Flat</option>
                <option value="bordered" <%= pw.cardStyle === 'bordered' ? 'selected' : '' %>>Bordered</option>
                <option value="shadow" <%= pw.cardStyle === 'shadow' ? 'selected' : '' %>>Shadow</option>
              </select>
            </div>
          </div>

          <div class="np-customizer-section">
            <p class="np-customizer-section-title">Additional CSS &amp; JavaScript</p>
            <div class="mb-3"><label class="form-label" for="custom_css">Custom CSS</label><textarea class="form-control font-monospace" id="custom_css" name="custom_css" rows="5" placeholder="/* Custom site styles */"><%= cssWithoutVars %></textarea></div>
            <div><label class="form-label" for="custom_js">Custom JavaScript</label><textarea class="form-control font-monospace" id="custom_js" name="custom_js" rows="4" placeholder="// No &lt;script&gt; tags"><%= themeSetting.custom_js || '' %></textarea></div>
          </div>

          <div class="np-customizer-save-bar">
            <button class="np-btn np-btn-primary" type="submit"><i class="bi bi-check-lg"></i> Save Changes</button>
          </div>
        </div>

        <div class="np-customizer-preview-wrap" aria-label="Live preview">
          <div class="theme-preview-panel">
            <div class="theme-preview-toggle" role="tablist">
              <button type="button" class="active" data-preview-mode="mock" aria-selected="true">Mock preview</button>
              <button type="button" data-preview-mode="iframe" aria-selected="false">Live site</button>
            </div>
            <div class="theme-preview-site" data-theme-preview>
              <div class="theme-preview-header" data-preview-header>
                <img data-preview-logo src="<%= themeSetting.logo || '' %>" alt="" <%= themeSetting.logo ? '' : 'hidden' %>>
                <img data-preview-favicon src="<%= themeSetting.favicon || '' %>" alt="" width="20" height="20" <%= themeSetting.favicon ? '' : 'hidden' %>>
                <span>NodePress Site</span>
              </div>
              <div class="theme-preview-body">
                <div class="portal-preview-mini-card" data-preview-accent-sample style="color:#d71920;font-size:11px;margin-bottom:8px;">Hot news label</div>
                <h2 data-preview-heading>Sample Blog Post</h2>
                <p data-preview-copy>This preview updates as you change colors and fonts. <a href="#" data-preview-link-sample onclick="return false;">Sample link</a></p>
                <button class="theme-preview-btn" type="button" data-preview-button>Read more</button>
              </div>
              <div class="theme-preview-footer-bar" data-preview-footer-bar style="background:#0b2f47;color:#fff;padding:8px 12px;font-size:11px;margin-top:12px;">Footer preview strip</div>
            </div>
            <iframe class="theme-preview-iframe" data-theme-preview-iframe src="/" title="Live site preview"></iframe>
          </div>
        </div>
      </div>
    </form>
  </main>
</div>
<%- include('../partials/media-modal') %>
<%- include('../partials/footer') %>
