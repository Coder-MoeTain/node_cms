<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content">
    <%- include('../partials/flash') %>
    <form class="card" method="post" action="/admin/theme-settings?_method=PUT&_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="card-header professional-card-header">
        <span>Theme Editor</span>
        <a href="/admin/themes">Installed Themes</a>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-3"><label class="form-label">Primary Color</label><input class="form-control" name="primary_color" value="<%= themeSetting.primary_color || '#0d6efd' %>"></div>
          <div class="col-md-3"><label class="form-label">Secondary Color</label><input class="form-control" name="secondary_color" value="<%= themeSetting.secondary_color || '#6c757d' %>"></div>
          <div class="col-md-3"><label class="form-label">Background</label><input class="form-control" name="background_color" value="<%= themeSetting.background_color || '#ffffff' %>"></div>
          <div class="col-md-3"><label class="form-label">Text Color</label><input class="form-control" name="text_color" value="<%= themeSetting.text_color || '#212529' %>"></div>
          <div class="col-md-4"><label class="form-label">Font Family</label><input class="form-control" name="font_family" value="<%= themeSetting.font_family || 'Inter, Arial, sans-serif' %>"></div>
          <div class="col-md-4"><label class="form-label">Sidebar Position</label><select class="form-select" name="sidebar_position"><% ['right','left','none'].forEach(function(value) { %><option value="<%= value %>" <%= themeSetting.sidebar_position === value ? 'selected' : '' %>><%= value %></option><% }) %></select></div>
          <div class="col-md-4"><label class="form-label">Blog Layout</label><select class="form-select" name="blog_layout"><% ['grid','list','masonry'].forEach(function(value) { %><option value="<%= value %>" <%= themeSetting.blog_layout === value ? 'selected' : '' %>><%= value %></option><% }) %></select></div>
          <div class="col-md-6"><%- include('../partials/image-upload-field', { label: 'Logo', name: 'logo', fileName: 'logo_file', value: themeSetting.logo || '' }) %></div>
          <div class="col-md-6"><%- include('../partials/image-upload-field', { label: 'Favicon', name: 'favicon', fileName: 'favicon_file', value: themeSetting.favicon || '' }) %></div>
          <div class="col-md-6"><label class="form-label">Header Layout</label><input class="form-control" name="header_layout" value="<%= themeSetting.header_layout || 'default' %>"></div>
          <div class="col-md-6"><label class="form-label">Footer Layout</label><input class="form-control" name="footer_layout" value="<%= themeSetting.footer_layout || 'default' %>"></div>
          <div class="col-md-6"><label class="form-label">Site Layout</label><select class="form-select" name="site_layout"><% ['wide','boxed'].forEach(function(value) { %><option value="<%= value %>" <%= themeSetting.site_layout === value ? 'selected' : '' %>><%= value %></option><% }) %></select></div>
          <div class="col-md-6 d-flex align-items-end"><label class="form-check"><input class="form-check-input" name="dark_mode" type="checkbox" <%= themeSetting.dark_mode ? 'checked' : '' %>> Enable dark mode</label></div>
        </div>
      </div>
      <div class="card-footer"><button class="btn btn-primary">Save Theme Settings</button></div>
    </form>
  </main>
</div>
<%- include('../partials/media-modal') %>
<%- include('../partials/footer') %>
