<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header np-page-header-split mb-4">
      <div>
        <h1><%= theme.name %></h1>
        <p class="np-help-text mb-0"><code><%= theme.slug %></code> · v<%= theme.version || '1.0.0' %> · <%= theme.author || 'Unknown' %></p>
      </div>
      <div class="d-flex flex-wrap gap-2">
        <a class="np-btn np-btn-secondary" href="/admin/themes"><i class="bi bi-arrow-left"></i> All themes</a>
        <% if (theme.active) { %>
          <a class="np-btn np-btn-primary" href="/admin/themes/customize"><i class="bi bi-brush"></i> Customize</a>
        <% } else { %>
          <form method="post" action="/admin/themes/activate" class="d-inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="theme_id" value="<%= theme.id %>">
            <input type="hidden" name="redirect" value="/admin/themes/<%= theme.slug %>">
            <button class="np-btn np-btn-primary" type="submit">Activate</button>
          </form>
          <a class="np-btn np-btn-secondary" href="/admin/themes/<%= theme.slug %>/preview" target="_blank" rel="noopener">Live Preview</a>
        <% } %>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-lg-4">
        <div class="np-widget mb-3">
          <div class="theme-preview-card">
            <a href="<%= theme.preview_thumb %>" data-theme-preview-open data-thumb="<%= theme.preview_thumb %>" data-full="<%= theme.preview_image || theme.preview_thumb %>" data-name="<%= theme.name %>">
              <img src="<%= theme.preview_thumb %>" alt="<%= theme.name %> preview" class="theme-preview-img">
            </a>
          </div>
          <div class="np-widget-body">
            <div class="theme-color-swatches theme-color-swatches-lg mb-3" aria-label="Theme colors">
              <span style="background:<%= theme.colors.primary %>" title="Primary"></span>
              <span style="background:<%= theme.colors.secondary %>" title="Secondary"></span>
              <span style="background:<%= theme.colors.background %>" title="Background"></span>
              <span style="background:<%= theme.colors.text %>" title="Text"></span>
            </div>
            <p class="mb-3"><%= theme.description || 'No description.' %></p>
            <dl class="row np-theme-details-dl mb-0">
              <dt class="col-5">Status</dt>
              <dd class="col-7"><span class="np-badge np-badge-<%= theme.active ? 'success' : 'secondary' %>"><%= theme.active ? 'Active' : 'Inactive' %></span></dd>
              <% if (theme.parent_slug) { %>
                <dt class="col-5">Parent</dt>
                <dd class="col-7"><code><%= theme.parent_slug %></code></dd>
              <% } %>
              <% if (assets.chain && assets.chain.length > 1) { %>
                <dt class="col-5">Inheritance</dt>
                <dd class="col-7"><%= assets.chain.join(' → ') %></dd>
              <% } %>
              <% if (theme.preset) { %>
                <dt class="col-5">Preset</dt>
                <dd class="col-7"><%= theme.preset %></dd>
              <% } %>
            </dl>
          </div>
        </div>

        <div class="np-widget">
          <div class="np-widget-header"><span>At a glance</span></div>
          <div class="np-widget-body">
            <ul class="list-unstyled mb-0 small">
              <li class="mb-2"><i class="bi bi-file-earmark-code me-1"></i> <%= theme.templateCount %> templates</li>
              <li class="mb-2"><i class="bi bi-puzzle me-1"></i> <%= theme.partialCount %> partials</li>
              <li class="mb-2"><i class="bi bi-folder2-open me-1"></i> <%= theme.assetCount %> assets</li>
              <% if (theme.supports.length) { %>
                <li><i class="bi bi-check2-square me-1"></i> <%= theme.supports.join(', ') %></li>
              <% } %>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-lg-8">
        <% if (readme) { %>
          <div class="np-widget mb-3">
            <div class="np-widget-header"><span><i class="bi bi-book me-1"></i> <%= readme.filename %></span></div>
            <div class="np-widget-body np-theme-readme"><%- readme.html %></div>
          </div>
        <% } %>

        <div class="np-widget mb-3">
          <div class="np-widget-header"><span>Templates</span></div>
          <div class="np-widget-body">
            <% if (assets.templates.length) { %>
              <div class="d-flex flex-wrap gap-2">
                <% assets.templates.forEach(function(name) { %>
                  <span class="badge bg-light text-dark border"><%= name %>.ejs</span>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted mb-0">No theme templates — inherits from parent theme or uses public view fallbacks.</p>
            <% } %>
          </div>
        </div>

        <div class="np-widget mb-3">
          <div class="np-widget-header"><span>Assets</span></div>
          <div class="np-widget-body">
            <% if (assets.assets && assets.assets.length) { %>
              <ul class="small mb-0"><% assets.assets.forEach(function(asset) { %><li><code><%= asset %></code></li><% }) %></ul>
            <% } else { %>
              <p class="text-muted mb-0">No theme assets discovered.</p>
            <% } %>
          </div>
        </div>

        <div class="np-widget">
          <div class="np-widget-header"><span>Activation check</span></div>
          <div class="np-widget-body">
            <% if (theme.activationMessage) { %>
              <div class="alert alert-warning mb-0"><%= theme.activationMessage %></div>
            <% } else { %>
              <p class="text-success mb-2"><i class="bi bi-check-circle"></i> Theme passes activation validation.</p>
              <% if (details && details.activationCheck && details.activationCheck.missingRecommended && details.activationCheck.missingRecommended.length) { %>
                <p class="text-muted small mb-0">Recommended templates using public fallbacks: <%= details.activationCheck.missingRecommended.join(', ') %></p>
              <% } %>
            <% } %>
            <% if (!theme.active) { %>
              <div class="d-flex flex-wrap gap-2 mt-3">
                <form method="post" action="/admin/themes/activate">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="theme_id" value="<%= theme.id %>">
                  <button class="np-btn np-btn-primary" type="submit">Activate Theme</button>
                </form>
                <a class="np-btn np-btn-secondary" href="/admin/themes/<%= theme.slug %>/preview" target="_blank" rel="noopener">Live Preview</a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<script src="/js/admin-themes.js"></script>
<div class="modal fade" id="npThemePreviewModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-xl">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" data-theme-preview-title>Theme preview</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0">
        <img src="" alt="" class="np-theme-preview-modal-img" data-theme-preview-image>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
