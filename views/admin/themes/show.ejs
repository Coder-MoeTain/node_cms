<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header d-flex flex-wrap justify-content-between align-items-start gap-2">
      <div>
        <h1><%= theme.name %></h1>
        <p class="text-muted mb-0"><code><%= theme.slug %></code> · v<%= theme.version || '1.0.0' %></p>
      </div>
      <div class="d-flex flex-wrap gap-2">
        <a class="np-btn np-btn-secondary" href="/admin/themes">Back to Themes</a>
        <% if (theme.active) { %><a class="np-btn np-btn-primary" href="/admin/themes/customize">Customize</a><% } %>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-lg-4">
        <div class="np-widget mb-3">
          <div class="theme-preview-card">
            <% if (theme.preview_image) { %>
              <img src="<%= theme.preview_image %>" alt="<%= theme.name %> preview" class="theme-preview-img">
            <% } else { %>
              <div class="theme-preview-placeholder"><i class="bi bi-image"></i></div>
            <% } %>
          </div>
          <div class="np-widget-body">
            <p class="text-muted"><%= theme.description || 'No description.' %></p>
            <dl class="row small mb-0">
              <dt class="col-5">Status</dt>
              <dd class="col-7"><span class="np-badge np-badge-<%= theme.active ? 'success' : 'muted' %>"><%= theme.active ? 'Active' : 'Inactive' %></span></dd>
              <% if (theme.parent_slug) { %>
                <dt class="col-5">Parent</dt>
                <dd class="col-7"><code><%= theme.parent_slug %></code></dd>
              <% } %>
              <% if (assets.chain && assets.chain.length > 1) { %>
                <dt class="col-5">Chain</dt>
                <dd class="col-7"><%= assets.chain.join(' → ') %></dd>
              <% } %>
            </dl>
          </div>
        </div>
      </div>
      <div class="col-lg-8">
        <div class="np-widget mb-3">
          <div class="np-widget-header"><span>Templates</span></div>
          <div class="np-widget-body">
            <% if (assets.templates.length) { %>
              <div class="d-flex flex-wrap gap-2">
                <% assets.templates.forEach(function(name) { %>
                  <span class="badge bg-light text-dark border"><%= name %>.ejs</span>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted mb-0">No theme templates — using public view fallbacks.</p>
            <% } %>
          </div>
        </div>

        <div class="np-widget mb-3">
          <div class="np-widget-header"><span>Assets</span></div>
          <div class="np-widget-body">
            <% if (assets.assets && assets.assets.length) { %>
              <ul class="small mb-0"><% assets.assets.forEach(function(asset) { %><li><code><%= asset %></code></li><% }) %></ul>
            <% } else { %>
              <p class="text-muted mb-0">No theme assets discovered.</p>
            <% } %>
          </div>
        </div>

        <div class="np-widget">
          <div class="np-widget-header"><span>Activation check</span></div>
          <div class="np-widget-body">
            <% if (details && details.activationCheck && details.activationCheck.error) { %>
              <div class="alert alert-warning mb-0"><%= details.activationCheck.error %></div>
            <% } else { %>
              <p class="text-success mb-2"><i class="bi bi-check-circle"></i> Theme passes activation validation.</p>
              <% if (details && details.activationCheck && details.activationCheck.missingRecommended && details.activationCheck.missingRecommended.length) { %>
                <p class="text-muted small mb-0">Recommended templates using public fallbacks: <%= details.activationCheck.missingRecommended.join(', ') %></p>
              <% } %>
            <% } %>
            <% if (!theme.active) { %>
              <form method="post" action="/admin/themes/activate" class="mt-3">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="theme_id" value="<%= theme.id %>">
                <button class="np-btn np-btn-primary" type="submit">Activate Theme</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
