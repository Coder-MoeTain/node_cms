<%- include('partials/head') %>
<%- include('partials/sidebar') %>
<div class="admin-main">
  <%- include('partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('partials/flash') %>
    <div class="np-page-header">
      <h1>Dashboard</h1>
      <% if (canManageResource('posts', 'create')) { %><a class="np-btn np-btn-primary" href="/admin/posts/create"><i class="bi bi-plus-lg"></i> Add New Post</a><% } %>
    </div>

    <div class="row dashboard-widgets">
      <div class="col-lg-8">
        <div class="np-widget">
          <div class="np-widget-header"><span>At a Glance</span></div>
          <div class="np-widget-body dashboard-at-glance">
            <div><a href="/admin/posts"><%= stats.posts %></a><span>Posts</span></div>
            <div><a href="/admin/pages"><%= stats.pages %></a><span>Pages</span></div>
            <div><a href="/admin/comments"><%= stats.comments %></a><span>Comments</span></div>
            <div><a href="/admin/media"><%= stats.media %></a><span>Media</span></div>
            <div><a href="/admin/categories"><%= stats.categories %></a><span>Categories</span></div>
            <div><span class="np-badge np-badge-info"><%= siteHealth.activeTheme || 'Classic' %></span><span>Theme</span></div>
          </div>
        </div>

        <div class="np-widget">
          <div class="np-widget-header"><span>Recent Posts</span><a href="/admin/posts">See all</a></div>
          <div class="np-widget-body p-0">
            <table class="np-list-table mb-0">
              <thead><tr><th>Title</th><th>Status</th><th>Date</th></tr></thead>
              <tbody>
                <% recentPosts.forEach(function(post) { %>
                  <tr>
                    <td>
                      <a class="row-title" href="/admin/posts/<%= post.id %>/edit"><%= post.title %></a>
                      <div class="row-actions">
                        <a href="/admin/posts/<%= post.id %>/edit">Edit</a>
                        <% if (post.status === 'published') { %><span>|</span><a href="/post/<%= post.slug %>" target="_blank">View</a><% } %>
                      </div>
                    </td>
                    <td><span class="np-badge np-badge-<%= post.status === 'published' ? 'success' : (post.status === 'draft' ? 'info' : 'muted') %>"><%= post.status %></span></td>
                    <td><%= post.created_at ? post.created_at.toLocaleDateString() : '' %></td>
                  </tr>
                <% }) %>
                <% if (!recentPosts.length) { %><tr><td colspan="3" class="text-muted">No posts yet.</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="np-widget">
          <div class="np-widget-header"><span>Activity</span></div>
          <div class="np-widget-body">
            <h6 class="mb-2">Recent Comments</h6>
            <ul class="list-unstyled mb-3">
              <% recentComments.slice(0, 5).forEach(function(comment) { %>
                <li class="mb-2"><strong><%= comment.name %></strong> on <%= comment.Post ? comment.Post.title : 'Deleted post' %> <span class="np-badge np-badge-muted"><%= comment.status %></span></li>
              <% }) %>
              <% if (!recentComments.length) { %><li class="text-muted">No comments yet.</li><% } %>
            </ul>
            <h6 class="mb-2">Recent Activity</h6>
            <ul class="list-unstyled mb-0">
              <% recentActivity.slice(0, 5).forEach(function(log) { %>
                <li class="mb-1 text-muted"><%= log.action %> — <%= log.User ? log.User.name : 'System' %></li>
              <% }) %>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <% if (canManageResource('posts', 'create')) { %>
        <div class="np-widget">
          <div class="np-widget-header"><span>Quick Draft</span></div>
          <div class="np-widget-body">
            <form method="post" action="/admin/quick-draft">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="mb-2"><input class="form-control" name="title" placeholder="Title" required></div>
              <div class="mb-2"><textarea class="form-control" name="content" rows="4" placeholder="Content"></textarea></div>
              <button class="np-btn np-btn-primary" type="submit">Save Draft</button>
            </form>
          </div>
        </div>
        <% } %>

        <div class="np-widget">
          <div class="np-widget-header"><span>Site Health</span></div>
          <div class="np-widget-body">
            <div class="health-item"><span>Environment</span><span class="np-badge np-badge-info"><%= siteHealth.env %></span></div>
            <div class="health-item"><span>Database</span><span class="np-badge np-badge-<%= siteHealth.database ? 'success' : 'danger' %>"><%= siteHealth.database ? 'Connected' : 'Error' %></span></div>
            <div class="health-item"><span>Uploads folder</span><span class="np-badge np-badge-<%= siteHealth.uploadsWritable ? 'success' : 'warning' %>"><%= siteHealth.uploadsWritable ? 'Writable' : 'Check permissions' %></span></div>
            <div class="health-item"><span>WAF</span><span class="np-badge np-badge-muted"><%= siteHealth.wafMode %></span></div>
            <div class="health-item"><span>Security alerts</span><span class="np-badge np-badge-<%= securityAlerts > 0 ? 'warning' : 'success' %>"><%= securityAlerts %> failed logins</span></div>
          </div>
        </div>

        <div class="np-widget">
          <div class="np-widget-header"><span>Security Summary</span><% if (can('manage_security')) { %><a href="/admin/security">Manage</a><% } %></div>
          <div class="np-widget-body">
            <div class="health-item"><span>Unread messages</span><strong><%= messages %></strong></div>
            <div class="health-item"><span>Recent login failures</span><strong><%= recentLogins.filter(function(l){ return !l.success; }).length %></strong></div>
          </div>
        </div>

        <% (pluginWidgets || []).forEach(function(widget) { %>
          <div class="np-widget np-plugin-widget">
            <div class="np-widget-header"><span><%= widget.title || 'Plugin' %></span></div>
            <div class="np-widget-body"><%= widget.body || '' %></div>
          </div>
        <% }) %>
      </div>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
