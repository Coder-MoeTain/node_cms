<%- include('partials/head') %>
<%- include('partials/sidebar') %>
<div class="admin-main">
  <%- include('partials/topbar') %>
  <main class="admin-content np-admin-page-inner" id="np-main-content">
    <%- include('partials/flash') %>
    <%- include('partials/onboarding') %>

    <div class="dashboard-welcome">
      <div class="dashboard-welcome-text">
        <h2>Welcome back, <%= currentUser ? currentUser.name.split(' ')[0] : 'Admin' %></h2>
        <p>Here's what's happening with your site today.</p>
      </div>
      <div class="dashboard-welcome-actions np-page-actions">
        <a class="np-btn np-btn-secondary" href="/" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right"></i> View Site</a>
        <% if (canManageResource('posts', 'create')) { %><a class="np-btn np-btn-primary" href="/admin/posts/create"><i class="bi bi-plus-lg"></i> New Post</a><% } %>
      </div>
    </div>

    <div class="np-page-header">
      <h1 class="np-page-title">Dashboard</h1>
    </div>

    <div class="row dashboard-widgets g-3">
      <div class="col-lg-8">
        <div class="np-widget np-card">
          <div class="np-widget-header"><span>At a Glance</span></div>
          <div class="np-widget-body dashboard-at-glance dashboard-stat-grid">
            <div class="stat-card"><i class="bi bi-file-earmark-text stat-icon" aria-hidden="true"></i><a href="/admin/posts"><%= stats.posts %></a><span>Posts</span></div>
            <div class="stat-card"><i class="bi bi-file-earmark stat-icon" aria-hidden="true"></i><a href="/admin/pages"><%= stats.pages %></a><span>Pages</span></div>
            <div class="stat-card"><i class="bi bi-chat-dots stat-icon" aria-hidden="true"></i><a href="/admin/comments"><%= stats.comments %></a><span>Comments</span></div>
            <div class="stat-card"><i class="bi bi-images stat-icon" aria-hidden="true"></i><a href="/admin/media"><%= stats.media %></a><span>Media</span></div>
            <div class="stat-card"><i class="bi bi-people stat-icon" aria-hidden="true"></i><a href="/admin/users"><%= stats.users %></a><span>Users</span></div>
            <div class="stat-card"><i class="bi bi-folder stat-icon" aria-hidden="true"></i><a href="/admin/categories"><%= stats.categories %></a><span>Categories</span></div>
            <div class="stat-card"><i class="bi bi-plug stat-icon" aria-hidden="true"></i><a href="/admin/plugins">Plugins</a><span>Extensions</span></div>
            <div class="stat-card"><i class="bi bi-palette stat-icon" aria-hidden="true"></i><span class="np-badge np-badge-info"><%= siteHealth.activeTheme || 'Classic' %></span><span>Theme</span></div>
          </div>
        </div>

        <div class="np-widget np-card dashboard-widget-collapsible">
          <div class="np-widget-header"><span>Recent Posts</span><a href="/admin/posts">See all</a></div>
          <div class="np-widget-body p-0">
            <div class="np-list-table-wrap">
              <table class="np-list-table mb-0">
                <thead><tr><th scope="col">Title</th><th scope="col">Status</th><th scope="col">Date</th></tr></thead>
                <tbody>
                  <% recentPosts.forEach(function(post) { %>
                    <tr>
                      <td>
                        <a class="row-title" href="/admin/posts/<%= post.id %>/edit"><%= post.title %></a>
                        <div class="row-actions">
                          <a href="/admin/posts/<%= post.id %>/edit">Edit</a>
                          <% if (post.status === 'published') { %><span>|</span><a href="/post/<%= post.slug %>" target="_blank" rel="noopener">View</a><% } %>
                        </div>
                      </td>
                      <td><span class="np-badge np-badge-<%= post.status === 'published' ? 'success' : (post.status === 'draft' ? 'info' : 'muted') %>"><%= post.status %></span></td>
                      <td><%= post.created_at ? post.created_at.toLocaleDateString() : '' %></td>
                    </tr>
                  <% }) %>
                  <% if (!recentPosts.length) { %>
                    <tr><td colspan="3">
                      <div class="np-empty-state py-4">
                        <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
                        <p class="mb-2">No posts yet.</p>
                        <% if (canManageResource('posts', 'create')) { %><a class="np-btn np-btn-primary np-btn-small" href="/admin/posts/create">Create your first post</a><% } %>
                      </div>
                    </td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="np-widget np-card dashboard-widget-collapsible">
          <div class="np-widget-header"><span>Activity</span></div>
          <div class="np-widget-body">
            <h3 class="h6 mb-2">Recent Comments</h3>
            <ul class="list-unstyled mb-3">
              <% recentComments.slice(0, 5).forEach(function(comment) { %>
                <li class="mb-2">
                  <strong><%= comment.name %></strong>
                  <% if (comment.Post) { %> on <a href="/admin/posts/<%= comment.Post.id %>/edit"><%= comment.Post.title %></a><% } else { %> on <em>Deleted post</em><% } %>
                  <span class="np-badge np-badge-muted"><%= comment.status %></span>
                </li>
              <% }) %>
              <% if (!recentComments.length) { %><li class="np-empty-state py-2"><i class="bi bi-chat-dots" aria-hidden="true"></i><span class="text-muted">No comments yet.</span></li><% } %>
            </ul>
            <h3 class="h6 mb-2">Recent Logins</h3>
            <ul class="list-unstyled mb-3">
              <% recentLogins.slice(0, 4).forEach(function(login) { %>
                <li class="mb-1">
                  <span class="np-badge np-badge-<%= login.success ? 'success' : 'danger' %>"><%= login.success ? 'OK' : 'Failed' %></span>
                  <%= login.email || login.ip_address || 'Unknown' %>
                  <span class="text-muted small"><%= login.created_at ? login.created_at.toLocaleString() : '' %></span>
                </li>
              <% }) %>
              <% if (!recentLogins.length) { %><li class="text-muted">No login attempts logged.</li><% } %>
            </ul>
            <h3 class="h6 mb-2">Audit Events</h3>
            <ul class="list-unstyled mb-0">
              <% recentActivity.slice(0, 5).forEach(function(log) { %>
                <li class="mb-1 text-muted"><%= log.action %> — <%= log.User ? log.User.name : 'System' %></li>
              <% }) %>
              <% if (!recentActivity.length) { %><li class="text-muted">No recent activity.</li><% } %>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <% if (canManageResource('posts', 'create')) { %>
        <div class="np-widget np-card">
          <div class="np-widget-header"><span>Quick Draft</span></div>
          <div class="np-widget-body">
            <form method="post" action="/admin/quick-draft">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="mb-2"><label class="form-label visually-hidden" for="quick-draft-title">Title</label><input class="form-control" id="quick-draft-title" name="title" placeholder="Title" required></div>
              <div class="mb-2"><label class="form-label visually-hidden" for="quick-draft-content">Content</label><textarea class="form-control" id="quick-draft-content" name="content" rows="4" placeholder="What's on your mind?"></textarea></div>
              <button class="np-btn np-btn-primary" type="submit">Save Draft</button>
            </form>
          </div>
        </div>
        <% } %>

        <div class="np-widget np-card">
          <div class="np-widget-header"><span>Site Health</span><a href="/admin/tools/health">Details</a></div>
          <div class="np-widget-body">
            <div class="health-item"><span>Environment</span><span class="np-badge np-badge-info"><%= siteHealth.env %></span></div>
            <div class="health-item"><span>Database</span><span class="np-badge np-badge-<%= siteHealth.database ? 'success' : 'danger' %>"><%= siteHealth.database ? 'Connected' : 'Error' %></span></div>
            <div class="health-item"><span>Uploads folder</span><span class="np-badge np-badge-<%= siteHealth.uploadsWritable ? 'success' : 'warning' %>"><%= siteHealth.uploadsWritable ? 'Writable' : 'Check permissions' %></span></div>
            <div class="health-item"><span>WAF mode</span><span class="np-badge np-badge-<%= siteHealth.wafMode === 'block' ? 'success' : 'warning' %>"><%= siteHealth.wafMode %></span></div>
            <div class="health-item"><span>HTTPS</span><span class="np-badge np-badge-<%= siteHealth.https ? 'success' : 'muted' %>"><%= siteHealth.https ? 'Enabled' : 'Not detected' %></span></div>
          </div>
        </div>

        <div class="np-widget np-card">
          <div class="np-widget-header"><span>Security Summary</span><% if (can('manage_security')) { %><a href="/admin/security">Manage</a><% } %></div>
          <div class="np-widget-body">
            <div class="health-item"><span>Failed logins (all time)</span><strong><%= securityAlerts %></strong></div>
            <div class="health-item"><span>Recent failures</span><strong><%= recentLogins.filter(function(l){ return !l.success; }).length %></strong></div>
            <div class="health-item"><span>Unread messages</span><strong><%= messages %></strong></div>
            <% if (can('manage_waf')) { %><div class="health-item"><span>WAF</span><a href="/admin/waf">Open dashboard</a></div><% } %>
          </div>
        </div>

        <div class="np-widget np-card">
          <div class="np-widget-header"><span>Updates</span><a href="/admin/updates">View all</a></div>
          <div class="np-widget-body">
            <div class="health-item"><span>NodePress CMS</span><span class="np-badge np-badge-info">v<%= typeof npVersion !== 'undefined' ? npVersion : '1.0.0' %></span></div>
            <div class="health-item"><span>Published posts</span><strong><%= stats.publishedPosts %></strong></div>
            <div class="health-item"><span>Draft posts</span><strong><%= stats.draftPosts %></strong></div>
            <p class="np-help-text mb-0 mt-2">Check the Updates screen for plugin and theme notices.</p>
          </div>
        </div>

        <% (pluginWidgets || []).forEach(function(widget) { %>
          <div class="np-widget np-card np-plugin-widget">
            <div class="np-widget-header"><span><%= widget.title || 'Plugin' %></span></div>
            <div class="np-widget-body"><%= widget.body || '' %></div>
          </div>
        <% }) %>
      </div>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
