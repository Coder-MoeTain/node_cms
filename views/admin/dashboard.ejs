<%- include('partials/head') %>
<%- include('partials/sidebar') %>
<div class="admin-main">
  <%- include('partials/topbar') %>
  <main class="admin-content">
    <%- include('partials/flash') %>
    <div class="row g-3">
      <% Object.entries(stats).forEach(function(entry) { %>
        <div class="col-6 col-lg-3">
          <div class="card stat-card"><div class="card-body"><span class="text-muted text-capitalize"><%= entry[0] %></span><h2><%= entry[1] %></h2></div></div>
        </div>
      <% }) %>
    </div>
    <div class="row g-3 mt-2">
      <div class="col-lg-7">
        <div class="card">
          <div class="card-header">Recent Posts</div>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <tbody>
                <% recentPosts.forEach(function(post) { %>
                  <tr><td><%= post.title %></td><td><span class="badge text-bg-secondary"><%= post.status %></span></td><td><a href="/admin/posts/<%= post.id %>/edit">Edit</a></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="card mb-3"><div class="card-body"><h5>Website Traffic Summary</h5><p class="mb-0">Traffic counters can be connected to analytics; post views are tracked in the CMS.</p></div></div>
        <div class="card">
          <div class="card-header">Recent Login Activity</div>
          <ul class="list-group list-group-flush">
            <% recentLogins.forEach(function(login) { %>
              <li class="list-group-item d-flex justify-content-between"><span><%= login.email || login.ip_address %></span><span class="badge <%= login.success ? 'text-bg-success' : 'text-bg-danger' %>"><%= login.success ? 'success' : 'failed' %></span></li>
            <% }) %>
          </ul>
        </div>
        <div class="alert alert-warning mt-3">Security alerts: <strong><%= securityAlerts %></strong> failed login attempts recorded.</div>
      </div>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
