<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="media-library-toolbar">
      <div class="np-page-header mb-0"><h1>Media Library</h1></div>
      <div class="d-flex flex-wrap gap-2 align-items-center">
        <input class="form-control form-control-sm" type="search" placeholder="Search media..." data-media-search aria-label="Search media">
        <button class="np-btn np-btn-secondary" type="button" data-view-toggle="grid" aria-pressed="true">Grid</button>
        <button class="np-btn np-btn-secondary" type="button" data-view-toggle="list" aria-pressed="false">List</button>
        <a class="np-btn np-btn-primary" href="#upload"><i class="bi bi-upload"></i> Add New</a>
      </div>
    </div>

    <div class="upload-dropzone" id="upload">
      <form method="post" action="/admin/media/upload?_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data" data-upload-form>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <p class="mb-2"><strong>Drop files to upload</strong> or choose files</p>
        <input class="form-control" type="file" name="files" multiple data-preview-file accept="image/*,video/*,.pdf,.doc,.docx">
        <div class="upload-preview mt-2"></div>
        <div class="progress mt-3 d-none" data-upload-progress role="progressbar" aria-valuemin="0" aria-valuemax="100"><div class="progress-bar progress-bar-striped progress-bar-animated w-100"></div></div>
        <p class="np-help-text mt-2 mb-0 d-none" data-upload-status></p>
        <button class="np-btn np-btn-primary mt-3" type="submit" data-loading-label="Uploading…">Upload</button>
      </form>
    </div>

    <div class="media-grid" data-media-library-grid>
      <% rows.forEach(function(file) { %>
        <article
          class="media-attachment"
          role="button"
          tabindex="0"
          data-media-item
          data-id="<%= file.id %>"
          data-name="<%= (file.original_name || '').toLowerCase() %>"
          data-original-name="<%= file.original_name %>"
          data-file-path="<%= file.file_path %>"
          data-thumb="<%= file.thumbnail_path || file.file_path %>"
          data-file-type="<%= file.file_type %>"
          data-uploaded="<%= file.created_at ? file.created_at.toISOString() : '' %>"
          data-alt="<%= (file.alt_text || '').replace(/"/g, '&quot;') %>"
          data-caption="<%= (file.caption || '').replace(/"/g, '&quot;') %>"
          data-description="<%= (file.description || '').replace(/"/g, '&quot;') %>"
          data-mime="<%= file.mime_type || '' %>"
          aria-label="Open <%= file.original_name %>"
        >
          <% if (file.file_type === 'image') { %>
            <img src="<%= file.thumbnail_path || file.file_path %>" alt="<%= file.alt_text || file.original_name %>">
          <% } else if (file.file_type === 'video') { %>
            <div class="media-attachment-meta d-flex align-items-center justify-content-center media-file-icon"><i class="bi bi-camera-video fs-1 text-muted" aria-hidden="true"></i></div>
          <% } else { %>
            <div class="media-attachment-meta d-flex align-items-center justify-content-center media-file-icon"><i class="bi bi-file-earmark fs-1 text-muted" aria-hidden="true"></i></div>
          <% } %>
          <div class="media-attachment-meta media-attachment-caption">
            <strong class="d-block text-truncate"><%= file.original_name %></strong>
            <span class="np-badge np-badge-muted"><%= file.file_type %></span>
          </div>
          <div class="media-attachment-actions">
            <button class="np-btn np-btn-small np-btn-secondary" type="button" data-copy-url="<%= file.file_path %>">Copy URL</button>
          </div>
        </article>
      <% }) %>
      <% if (!rows.length) { %>
        <div class="empty-state empty-state-card w-100">
          <i class="bi bi-images d-block" aria-hidden="true"></i>
          <strong>No media files yet</strong>
          <p class="mb-2">Upload images, documents, or videos to build your media library.</p>
          <a class="np-btn np-btn-primary" href="#upload">Upload files</a>
        </div>
      <% } %>
    </div>

    <% if (pagination && pagination.pages > 1) { %>
      <nav class="mt-3" aria-label="Media pagination">
        <ul class="pagination pagination-sm">
          <% for (let i = 1; i <= pagination.pages; i++) { %>
            <li class="page-item <%= i === pagination.page ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>"><%= i %></a></li>
          <% } %>
        </ul>
      </nav>
    <% } %>
  </main>
</div>
<%- include('../partials/media-detail-modal') %>
<%- include('../partials/footer') %>
