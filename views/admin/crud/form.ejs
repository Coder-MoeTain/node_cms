<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<%
  const isEdit = Boolean(record.id);
  const csrfQuery = `_csrf=${encodeURIComponent(csrfToken)}`;
  const action = isEdit ? `/admin/${resource}/${record.id}?_method=PUT&${csrfQuery}` : `/admin/${resource}?${csrfQuery}`;
  const val = (name, fallback = '') => record[name] == null ? fallback : record[name];
  const selectedTags = record.Tags ? record.Tags.map((tag) => String(tag.id)) : [];
  const selectedPermissions = record.Permissions ? record.Permissions.map((permission) => String(permission.id)) : [];
  let publishedAtValue = '';
  if (record.published_at) {
    publishedAtValue = typeof toDatetimeLocalValue === 'function'
      ? toDatetimeLocalValue(record.published_at)
      : '';
  }
  let contentPreviewUrl = '';
  if (typeof previewUrl !== 'undefined' && previewUrl) {
    contentPreviewUrl = previewUrl;
  } else if (isEdit && val('slug') && val('status') === 'published') {
    contentPreviewUrl = `/${resource === 'pages' ? 'page' : 'post'}/${val('slug')}`;
  }
%>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <form method="post" action="<%= action %>" enctype="multipart/form-data" data-editor-form data-autosave-form data-resource-type="<%= resource === 'pages' ? 'page' : 'post' %>" data-resource-id="<%= record.id || '' %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <% if (['posts','pages'].includes(resource)) { %>
          <div class="np-page-header mb-3">
            <h1><%= isEdit ? 'Edit' : 'Add New' %> <%= resource === 'posts' ? 'Post' : 'Page' %></h1>
          </div>
          <div class="editor-layout">
            <div class="editor-main">
              <input class="np-editor-title" name="title" value="<%= val('title') %>" placeholder="Add title" required data-slug-source>
              <div class="np-permalink" data-permalink-wrap>
                <span>Permalink:</span>
                <span data-permalink-display><%= resource === 'pages' ? '/page/' : '/post/' %><%= val('slug') || 'sample-post' %></span>
                <button class="np-btn np-btn-link np-btn-small" type="button" data-permalink-edit>Edit</button>
                <span class="permalink-edit d-none" data-permalink-editor>
                  <span><%= resource === 'pages' ? '/page/' : '/post/' %></span>
                  <input class="form-control form-control-sm d-inline-block" style="width:220px" type="text" data-permalink-input value="<%= val('slug') %>">
                  <button class="np-btn np-btn-link np-btn-small" type="button" data-permalink-save>OK</button>
                  <button class="np-btn np-btn-link np-btn-small" type="button" data-permalink-cancel>Cancel</button>
                </span>
              </div>
              <input type="hidden" name="slug" value="<%= val('slug') %>" data-slug-target>
              <%- include('../partials/content-editor', { record: record }) %>
              <div class="np-metabox">
                <div class="np-metabox-header" data-metabox-toggle aria-expanded="true">Excerpt</div>
                <div class="np-metabox-body"><textarea class="form-control" name="excerpt" rows="3" placeholder="Optional excerpt"><%= val('excerpt') %></textarea><p class="np-help-text">Excerpts are optional hand-crafted summaries.</p></div>
              </div>
              <div class="np-metabox">
                <div class="np-metabox-header" data-metabox-toggle aria-expanded="true">SEO</div>
                <div class="np-metabox-body">
                  <div class="mb-2"><label class="form-label">SEO Title</label><input class="form-control" name="seo_title" value="<%= val('seo_title') %>"></div>
                  <div><label class="form-label">Meta Description</label><input class="form-control" name="seo_description" value="<%= val('seo_description') %>"></div>
                </div>
              </div>
              <%- include('../partials/content-translations', { translations: typeof translations !== 'undefined' ? translations : {}, translationLocales: typeof translationLocales !== 'undefined' ? translationLocales : ['en', 'my', 'zh-CN', 'ru'] }) %>
            </div>
            <aside class="editor-sidebar editor-sidebar-sticky">
              <div class="np-metabox np-metabox-publish">
                <div class="np-metabox-header">Publish</div>
                <div class="np-metabox-body">
                  <div class="publish-status-row mb-2">
                    <span class="publish-label">Status:</span>
                    <select class="form-select form-select-sm" name="status" data-status-select><% ['draft','published','private','scheduled'].forEach(function(status) { const canUseStatus = resource === 'pages' ? can('manage_pages') : (status === 'draft' || canPublishPost(isEdit ? record : null)); if (canUseStatus) { %><option value="<%= status %>" <%= val('status','draft') === status ? 'selected' : '' %>><%= status.charAt(0).toUpperCase() + status.slice(1) %></option><% } }) %></select>
                  </div>
                  <div class="publish-status-row mb-3">
                    <span class="publish-label">Publish:</span>
                    <input class="form-control form-control-sm" name="published_at" type="datetime-local" value="<%= publishedAtValue %>">
                  </div>
                  <div class="publish-actions">
                    <button class="np-btn np-btn-secondary" type="submit" data-save-draft>Save Draft</button>
                    <% if (contentPreviewUrl) { %><a class="np-btn np-btn-secondary" href="<%= contentPreviewUrl %>" target="_blank" rel="noopener">Preview</a><% } %>
                    <button class="np-btn np-btn-primary" type="submit" data-publish-submit><%= isEdit ? 'Update' : 'Publish' %></button>
                  </div>
                  <p class="np-help-text mt-2 mb-0" data-autosave-status aria-live="polite"></p>
                  <div class="mt-2"><a class="np-btn np-btn-link" href="/admin/<%= resource %>">Cancel</a></div>
                </div>
              </div>
              <% if (resource === 'pages') { %>
                <div class="np-metabox">
                  <div class="np-metabox-header">Featured Image</div>
                  <div class="np-metabox-body">
                    <%- include('../partials/featured-image-field', { name: 'featured_image', fileName: 'featured_image_file', value: val('featured_image') }) %>
                  </div>
                </div>
              <% } %>
              <% if (resource === 'posts') { %>
                <div class="np-metabox">
                  <div class="np-metabox-header" data-metabox-toggle aria-expanded="true">Categories</div>
                  <div class="np-metabox-body">
                    <div class="category-checklist" role="radiogroup" aria-label="Categories">
                      <label class="category-check-item">
                        <input type="radio" name="category_id" value="" <%= !val('category_id') ? 'checked' : '' %>>
                        <span>Uncategorized</span>
                      </label>
                      <% (extra.categories || []).forEach(function(category) { %>
                        <label class="category-check-item">
                          <input type="radio" name="category_id" value="<%= category.id %>" <%= String(val('category_id')) === String(category.id) ? 'checked' : '' %>>
                          <span><%= category.name %></span>
                        </label>
                      <% }) %>
                    </div>
                  </div>
                </div>
                <div class="np-metabox">
                  <div class="np-metabox-header" data-metabox-toggle aria-expanded="true">Tags</div>
                  <div class="np-metabox-body">
                    <select class="form-select" name="tags" multiple size="6" aria-label="Tags"><% (extra.tags || []).forEach(function(tag) { %><option value="<%= tag.id %>" <%= selectedTags.includes(String(tag.id)) ? 'selected' : '' %>><%= tag.name %></option><% }) %></select>
                    <p class="np-help-text">Hold Ctrl or Cmd to select multiple tags.</p>
                  </div>
                </div>
                <div class="np-metabox">
                  <div class="np-metabox-header">Featured Image</div>
                  <div class="np-metabox-body">
                    <%- include('../partials/featured-image-field', { name: 'featured_image', fileName: 'featured_image_file', value: val('featured_image') }) %>
                  </div>
                </div>
                <div class="np-metabox">
                  <div class="np-metabox-header">Video &amp; Discussion</div>
                  <div class="np-metabox-body">
                    <div class="mb-2"><label class="form-label">Video URL</label><input class="form-control" name="video_url" value="<%= val('video_url') %>"></div>
                    <label class="form-check"><input class="form-check-input" name="allow_comments" type="checkbox" <%= val('allow_comments', true) ? 'checked' : '' %>> Allow comments</label>
                  </div>
                </div>
                <% if (can('manage_posts')) { %>
                <div class="np-metabox">
                  <div class="np-metabox-header">Author</div>
                  <div class="np-metabox-body"><select class="form-select" name="author_id"><% (extra.users || []).forEach(function(user) { %><option value="<%= user.id %>" <%= String(val('author_id')) === String(user.id) ? 'selected' : '' %>><%= user.name %></option><% }) %></select></div>
                </div>
                <% } %>
              <% } %>
            </aside>
          </div>
        <% } else if (['categories','tags','roles'].includes(resource)) { %>
          <div class="mb-3"><label class="form-label">Name</label><input class="form-control" name="name" value="<%= val('name') %>" required></div>
          <div class="mb-3"><label class="form-label">Slug</label><input class="form-control" name="slug" value="<%= val('slug') %>"></div>
          <div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description"><%= val('description') %></textarea></div>
          <% if (resource === 'categories') { %>
            <div class="mb-3"><label class="form-label">Parent Category</label><select class="form-select" name="parent_id"><option value="">None</option><% (extra.categories || []).forEach(function(category) { if (category.id !== record.id) { %><option value="<%= category.id %>" <%= String(val('parent_id')) === String(category.id) ? 'selected' : '' %>><%= category.name %></option><% } }) %></select></div>
            <%- include('../partials/image-upload-field', { label: 'Category Image', name: 'image', fileName: 'image_file', value: val('image') }) %>
          <% } %>
          <% if (resource === 'roles') { %>
            <label class="form-label">Permissions</label>
            <% const permGroups = {};
               (extra.permissions || []).forEach(function(permission) {
                 const parts = (permission.slug || permission.name || '').split('_');
                 const groupKey = parts.length > 1 ? parts.slice(1).join(' ') : 'general';
                 const groupLabel = groupKey.replace(/\b\w/g, function(c) { return c.toUpperCase(); });
                 if (!permGroups[groupLabel]) permGroups[groupLabel] = [];
                 permGroups[groupLabel].push(permission);
               });
               Object.keys(permGroups).sort().forEach(function(groupLabel) { %>
              <div class="np-permission-group mb-3">
                <h6 class="np-permission-group-title"><%= groupLabel %></h6>
                <div class="row">
                  <% permGroups[groupLabel].forEach(function(permission) { %>
                    <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="permissions" value="<%= permission.id %>" <%= selectedPermissions.includes(String(permission.id)) ? 'checked' : '' %>> <%= permission.name %></label></div>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          <% } %>
        <% } else if (resource === 'users') { %>
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Name</label><input class="form-control" name="name" value="<%= val('name') %>" required></div>
            <div class="col-md-6"><label class="form-label">Email</label><input class="form-control" name="email" type="email" value="<%= val('email') %>" required></div>
            <div class="col-md-6"><label class="form-label">Password</label><input class="form-control" name="password" type="password" <%= isEdit ? '' : 'required' %>></div>
            <div class="col-md-3"><label class="form-label">Role</label><select class="form-select" name="role_id"><% (extra.roles || []).forEach(function(role) { %><option value="<%= role.id %>" <%= String(val('role_id')) === String(role.id) ? 'selected' : '' %>><%= role.name %></option><% }) %></select></div>
            <div class="col-md-3"><label class="form-label">Status</label><select class="form-select" name="status"><% ['active','disabled','pending'].forEach(function(status) { %><option value="<%= status %>" <%= val('status','active') === status ? 'selected' : '' %>><%= status %></option><% }) %></select></div>
          </div>
        <% } else if (resource === 'menus') { %>
          <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Name</label><input class="form-control" name="name" value="<%= val('name') %>" required></div>
            <div class="col-md-4"><label class="form-label">Slug</label><input class="form-control" name="slug" value="<%= val('slug') %>"></div>
            <div class="col-md-4"><label class="form-label">Location</label><select class="form-select" name="location"><% ['header','footer','sidebar'].forEach(function(location) { %><option value="<%= location %>" <%= val('location','header') === location ? 'selected' : '' %>><%= location %></option><% }) %></select></div>
          </div>
          <label class="form-check mt-3"><input class="form-check-input" name="active" type="checkbox" <%= val('active', true) ? 'checked' : '' %>> Active</label>
        <% } else if (resource === 'menu-items') { %>
          <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Menu</label><select class="form-select" name="menu_id"><% (extra.menus || []).forEach(function(menu) { %><option value="<%= menu.id %>" <%= String(val('menu_id')) === String(menu.id) ? 'selected' : '' %>><%= menu.name %></option><% }) %></select></div>
            <div class="col-md-4"><label class="form-label">Title</label><input class="form-control" name="title" value="<%= val('title') %>" required></div>
            <div class="col-md-4"><label class="form-label">URL</label><input class="form-control" name="url" value="<%= val('url') %>" required></div>
            <div class="col-md-3"><label class="form-label">Parent</label><select class="form-select" name="parent_id"><option value="">None</option><% (extra.menuItems || []).forEach(function(item) { if (item.id !== record.id) { %><option value="<%= item.id %>" <%= String(val('parent_id')) === String(item.id) ? 'selected' : '' %>><%= item.title %></option><% } }) %></select></div>
            <div class="col-md-3"><label class="form-label">Type</label><select class="form-select" name="item_type"><% ['custom','page','category','post'].forEach(function(type) { %><option value="<%= type %>" <%= val('item_type','custom') === type ? 'selected' : '' %>><%= type %></option><% }) %></select></div>
            <div class="col-md-3"><label class="form-label">Target</label><select class="form-select" name="target"><option value="_self">Same tab</option><option value="_blank" <%= val('target') === '_blank' ? 'selected' : '' %>>New tab</option></select></div>
            <div class="col-md-3"><label class="form-label">Order</label><input class="form-control" name="display_order" type="number" value="<%= val('display_order', 0) %>"></div>
          </div>
          <label class="form-check mt-3"><input class="form-check-input" name="active" type="checkbox" <%= val('active', true) ? 'checked' : '' %>> Active</label>
        <% } else if (resource === 'sliders') { %>
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Title</label><input class="form-control" name="title" value="<%= val('title') %>" required></div>
            <div class="col-md-6"><label class="form-label">Description</label><input class="form-control" name="description" value="<%= val('description') %>"></div>
          </div>
          <p class="np-help-text mt-3 mb-2">Add up to 3 photos for this slider. Each photo is cropped to 16:9 and becomes one slide in the homepage carousel.</p>
          <div class="row g-3">
            <% let sliderSlots = [];
               if (record && record.images && record.images.length) {
                 sliderSlots = record.images.slice(0, 3);
               } else if (record && record.image) {
                 sliderSlots = [record.image];
               }
               while (sliderSlots.length < 3) sliderSlots.push(''); %>
            <% sliderSlots.forEach(function(slotValue, index) {
                 const slot = index + 1;
                 const pathName = slot === 1 ? 'image' : `image_${slot}`;
                 const fileName = slot === 1 ? 'image_file' : `image_file_${slot}`;
            %>
              <div class="col-md-4">
                <%- include('../partials/image-upload-field', { label: `Photo ${slot}`, name: pathName, fileName, value: slotValue, enableCrop: true, cropAspect: '16/9' }) %>
              </div>
            <% }) %>
          </div>
          <div class="row g-3 mt-1">
            <div class="col-md-4"><label class="form-label">Button Text</label><input class="form-control" name="button_text" value="<%= val('button_text') %>" placeholder="e.g. Learn more"></div>
            <div class="col-md-4"><label class="form-label">Button URL</label><input class="form-control" name="button_url" value="<%= val('button_url') %>" placeholder="e.g. /about"></div>
            <div class="col-md-4"><label class="form-label">Order</label><input class="form-control" name="display_order" type="number" value="<%= val('display_order', 0) %>"></div>
          </div>
          <p class="np-help-text mb-0">Button Text appears on the homepage slider when set. Add a URL to make the button clickable.</p>
          <label class="form-check mt-3"><input class="form-check-input" name="active" type="checkbox" <%= val('active', true) ? 'checked' : '' %>> Active</label>
        <% } else if (resource === 'banners') { %>
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Title</label><input class="form-control" name="title" value="<%= val('title') %>" required></div>
            <div class="col-md-6"><label class="form-label">Subtitle</label><input class="form-control" name="subtitle" value="<%= val('subtitle') %>"></div>
            <div class="col-md-6"><%- include('../partials/image-upload-field', { label: 'Image', name: 'image', fileName: 'image_file', value: val('image') }) %></div>
            <div class="col-md-3"><label class="form-label">Button Text</label><input class="form-control" name="button_text" value="<%= val('button_text') %>"></div>
            <div class="col-md-3"><label class="form-label">Button URL</label><input class="form-control" name="button_link" value="<%= val('button_link') %>"></div>
            <div class="col-md-3"><label class="form-label">Order</label><input class="form-control" name="display_order" type="number" value="<%= val('display_order', 0) %>"></div>
          </div>
          <label class="form-check mt-3"><input class="form-check-input" name="active" type="checkbox" <%= val('active', true) ? 'checked' : '' %>> Active</label>
        <% } else if (resource === 'comments') { %>
          <label class="form-label">Status</label><select class="form-select mb-3" name="status"><% ['pending','approved','spam','rejected'].forEach(function(status) { %><option value="<%= status %>" <%= val('status') === status ? 'selected' : '' %>><%= status %></option><% }) %></select>
          <label class="form-label">Comment</label><textarea class="form-control" name="content"><%= val('content') %></textarea>
        <% } else if (resource === 'messages') { %>
          <p><strong>From:</strong> <%= record.name %> &lt;<%= record.email %>&gt;</p>
          <p><strong>Subject:</strong> <%= record.subject %></p>
          <p><%= record.message %></p>
          <label class="form-label">Status</label><select class="form-select" name="status"><option value="unread">Unread</option><option value="read" <%= val('status') === 'read' ? 'selected' : '' %>>Read</option></select>
          <a class="btn btn-outline-primary mt-3" href="mailto:<%= record.email %>?subject=Re: <%= record.subject %>">Reply by email</a>
        <% } %>
      </div>
      <% if (!['posts','pages'].includes(resource)) { %>
      <div class="card-footer d-flex justify-content-between">
        <a class="np-btn np-btn-secondary" href="/admin/<%= resource %>">Cancel</a>
        <button class="np-btn np-btn-primary" type="submit">Save</button>
      </div>
      <% } %>
    </form>
  </main>
</div>
<% if (resource === 'sliders') { %>
  <link rel="stylesheet" href="/vendor/cropperjs/cropper.min.css">
  <script src="/vendor/cropperjs/cropper.min.js"></script>
  <%- include('../partials/image-crop-modal') %>
  <script src="/js/slider-crop.js"></script>
<% } %>
<% if (['posts','pages','categories','banners','sliders'].includes(resource)) { %><%- include('../partials/media-modal') %><% } %>
<%- include('../partials/footer') %>
