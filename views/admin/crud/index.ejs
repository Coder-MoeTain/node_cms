<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content">
    <%- include('../partials/flash') %>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <form class="d-flex gap-2" method="get">
        <input class="form-control" name="q" placeholder="Search..." value="<%= query %>">
        <button class="btn btn-outline-primary">Search</button>
      </form>
      <% if (!['comments','messages'].includes(resource)) { %><a class="btn btn-primary" href="/admin/<%= resource %>/create">Add New</a><% } %>
    </div>
    <div class="card">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead><tr><th>ID</th><th>Title/Name</th><th>Status</th><th>Created</th><th class="text-end">Actions</th></tr></thead>
          <tbody>
            <% rows.forEach(function(row) { %>
              <tr>
                <td><%= row.id %></td>
                <td><strong><%= row.title || row.name || row.subject || row.email %></strong><br><small class="text-muted"><%= row.slug || row.url || '' %></small></td>
                <td><span class="badge text-bg-<%= row.status === 'published' || row.active ? 'success' : 'secondary' %>"><%= row.status || (row.active ? 'active' : 'inactive') %></span></td>
                <td><%= row.created_at ? row.created_at.toISOString().slice(0,10) : '' %></td>
                <td class="text-end">
                  <a class="btn btn-sm btn-outline-primary" href="/admin/<%= resource %>/<%= row.id %>/edit">Edit</a>
                  <form class="d-inline" method="post" action="/admin/<%= resource %>/<%= row.id %>?_method=DELETE" data-confirm="Delete this item?">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <nav class="mt-3">
      <ul class="pagination">
        <% for (let i = 1; i <= pagination.pages; i++) { %>
          <li class="page-item <%= i === pagination.page ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>&q=<%= query %>"><%= i %></a></li>
        <% } %>
      </ul>
    </nav>
  </main>
</div>
<%- include('../partials/footer') %>
