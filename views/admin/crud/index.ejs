<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <% const resourceLabel = title.replace(/^Manage /i, ''); %>
    <div class="np-page-header">
      <h1><%= resourceLabel %></h1>
      <% if (!['comments','messages'].includes(resource) && canManageResource(resource, 'create')) { %>
        <a class="np-btn np-btn-primary" href="/admin/<%= resource %>/create"><i class="bi bi-plus-lg"></i> Add New</a>
      <% } %>
    </div>

    <% if (resource === 'posts') { %>
      <ul class="np-subsub list-unstyled">
        <li class="<%= !filters.status ? 'active' : '' %>"><a href="/admin/posts">All <span class="count">(<%= pagination.total || rows.length %>)</span></a></li>
        <% ['published','draft','private','scheduled'].forEach(function(status) { %>
          <li class="<%= filters.status === status ? 'active' : '' %>"><a href="/admin/posts?status=<%= status %>"><%= status.charAt(0).toUpperCase() + status.slice(1) %></a></li>
        <% }) %>
      </ul>
    <% } %>

    <% if (resource === 'pages') { %>
      <ul class="np-subsub list-unstyled">
        <li class="<%= !filters.status ? 'active' : '' %>"><a href="/admin/pages">All <span class="count">(<%= pagination.total || rows.length %>)</span></a></li>
        <% ['published','draft','private'].forEach(function(status) { %>
          <li class="<%= filters.status === status ? 'active' : '' %>"><a href="/admin/pages?status=<%= status %>"><%= status.charAt(0).toUpperCase() + status.slice(1) %></a></li>
        <% }) %>
      </ul>
    <% } %>

    <div class="np-tablenav">
      <div class="tablenav-actions">
        <select class="form-select form-select-sm" aria-label="Bulk actions" data-bulk-action disabled>
          <option value="">Bulk actions</option>
          <option value="delete">Move to Trash</option>
        </select>
        <button class="np-btn np-btn-secondary np-btn-small" type="button" data-bulk-apply disabled>Apply</button>
      </div>
      <div class="np-tablenav-pages">
        <% if (pagination.total) { %><%= pagination.total %> item<%= pagination.total === 1 ? '' : 's' %><% } %>
      </div>
    </div>

    <div class="list-toolbar">
      <form class="admin-search" method="get">
        <input class="form-control" name="q" placeholder="Search <%= resourceLabel.toLowerCase() %>..." value="<%= query %>" aria-label="Search">
        <% if (resource === 'posts' || resource === 'pages') { %>
          <input type="hidden" name="status" value="<%= filters.status || '' %>">
        <% } %>
        <% if (resource === 'posts') { %>
          <select class="form-select" name="category_id" aria-label="Filter by category">
            <option value="">All categories</option>
            <% (extra.categories || []).forEach(function(category) { %>
              <option value="<%= category.id %>" <%= String(filters.category_id) === String(category.id) ? 'selected' : '' %>><%= category.name %></option>
            <% }) %>
          </select>
        <% } %>
        <button class="np-btn np-btn-secondary" type="submit">Search</button>
      </form>
    </div>

    <div class="np-list-table-wrap">
      <table class="np-list-table admin-table">
        <thead>
          <tr>
            <th class="check-column"><input type="checkbox" aria-label="Select all" data-select-all></th>
            <th>Title</th>
            <% if (['posts','pages'].includes(resource)) { %><th>Author</th><% } %>
            <th>Status</th>
            <% if (resource === 'posts') { %><th>Category</th><% } %>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(function(row) { %>
            <% const statusKey = row.status || (row.active ? 'active' : 'inactive');
               const badgeClass = statusKey === 'published' || row.active ? 'success' : (statusKey === 'draft' ? 'info' : (statusKey === 'scheduled' ? 'warning' : (statusKey === 'private' ? 'muted' : 'muted'))); %>
            <tr>
              <td class="check-column"><input type="checkbox" class="row-select" aria-label="Select item" value="<%= row.id %>"></td>
              <td class="title-column">
                <% if (canManageResource(resource, 'edit', row)) { %>
                  <a class="row-title" href="/admin/<%= resource %>/<%= row.id %>/edit"><%= row.title || row.name || row.subject || row.email %></a>
                <% } else { %>
                  <span class="row-title text-muted"><%= row.title || row.name || row.subject || row.email %></span>
                <% } %>
                <div class="row-actions">
                  <% if (canManageResource(resource, 'edit', row)) { %><a href="/admin/<%= resource %>/<%= row.id %>/edit">Edit</a><% } %>
                  <% if (row.slug && row.status === 'published') { %><span class="sep">|</span><a href="/<%= resource === 'pages' ? 'page' : 'post' %>/<%= row.slug %>" target="_blank" rel="noopener">View</a><% } %>
                  <% if (canManageResource(resource, 'destroy', row)) { %>
                    <span class="sep">|</span>
                    <form class="d-inline" method="post" action="/admin/<%= resource %>/<%= row.id %>?_method=DELETE" data-confirm="Move this item to trash?">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button class="delete-link border-0 bg-transparent p-0" type="submit">Trash</button>
                    </form>
                  <% } %>
                </div>
                <% if (row.slug) { %><div class="row-slug"><%= row.slug %></div><% } %>
              </td>
              <% if (['posts','pages'].includes(resource)) { %><td class="author-column"><%= row.author ? row.author.name : '—' %></td><% } %>
              <td><span class="np-badge np-badge-<%= badgeClass %>"><%= statusKey %></span></td>
              <% if (resource === 'posts') { %><td><%= row.Category ? row.Category.name : '—' %></td><% } %>
              <td class="date-column"><%= row.created_at ? row.created_at.toLocaleDateString() : '' %></td>
            </tr>
          <% }) %>
          <% if (!rows.length) { %>
            <tr><td colspan="<%= resource === 'posts' ? 6 : (resource === 'pages' ? 5 : 4) %>">
              <div class="empty-state empty-state-card">
                <i class="bi bi-inbox d-block" aria-hidden="true"></i>
                <strong>No <%= resourceLabel.toLowerCase() %> found</strong>
                <p class="mb-2">Try another search or create a new item.</p>
                <% if (canManageResource(resource, 'create')) { %>
                  <a class="np-btn np-btn-primary" href="/admin/<%= resource %>/create"><i class="bi bi-plus-lg"></i> Add New</a>
                <% } %>
              </div>
            </td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <% if (pagination.pages > 1) { %>
      <nav class="mt-3" aria-label="Pagination">
        <ul class="pagination pagination-sm">
          <% for (let i = 1; i <= pagination.pages; i++) { %>
            <li class="page-item <%= i === pagination.page ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>&q=<%= encodeURIComponent(query || '') %>&status=<%= filters.status || '' %>&category_id=<%= filters.category_id || '' %>"><%= i %></a></li>
          <% } %>
        </ul>
      </nav>
    <% } %>

    <form id="bulk-form" method="post" action="/admin/<%= resource %>/bulk" class="d-none" aria-hidden="true">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="action" value="trash" data-bulk-form-action>
    </form>
  </main>
</div>
<%- include('../partials/footer') %>
