<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <% const resourceLabel = title.replace(/^Manage /i, ''); %>
    <div class="np-page-header">
      <h1><%= resourceLabel %></h1>
      <% if (!['comments','messages'].includes(resource) && canManageResource(resource, 'create')) { %>
        <% const createHref = resource === 'menu-items' && filters.menu_id
          ? `/admin/${resource}/create?menu_id=${encodeURIComponent(filters.menu_id)}`
          : `/admin/${resource}/create`; %>
        <a class="np-btn np-btn-primary" href="<%= createHref %>"><i class="bi bi-plus-lg"></i> Add New</a>
      <% } %>
    </div>

    <% if (resource === 'menus') { %>
      <% const quickServicesMenu = (extra.menus || []).find(function(m) { return m.slug === 'quick-services'; }); %>
      <p class="np-help-text mb-3">Homepage quick-link tiles (Government Websites, Forms, Documents, etc.) are managed under the <strong>Quick Services</strong> menu. Open that menu and use <strong>Manage items</strong>, or go to <a href="/admin/menu-items<%= quickServicesMenu ? ('?menu_id=' + quickServicesMenu.id) : '' %>">Menu Items</a> and filter by Quick Services.</p>
    <% } %>

    <% if (['posts','pages'].includes(resource)) { %>
      <ul class="np-subsub list-unstyled">
        <% if (!trashed) { %>
        <li class="<%= !filters.status ? 'active' : '' %>"><a href="/admin/<%= resource %>">All <span class="count">(<%= pagination.total || rows.length %>)</span></a></li>
        <% if (resource === 'posts') { %>
        <% ['published','draft','pending','private','scheduled'].forEach(function(status) { %>
          <li class="<%= filters.status === status ? 'active' : '' %>"><a href="/admin/<%= resource %>?status=<%= status %>"><%= status.charAt(0).toUpperCase() + status.slice(1) %></a></li>
        <% }) %>
        <% } else { %>
        <% ['published','draft','pending','private','scheduled'].forEach(function(status) { %>
          <li class="<%= filters.status === status ? 'active' : '' %>"><a href="/admin/<%= resource %>?status=<%= status %>"><%= status.charAt(0).toUpperCase() + status.slice(1) %></a></li>
        <% }) %>
        <% } %>
        <li><a href="/admin/<%= resource %>?trashed=1">Trash</a></li>
        <% } else { %>
        <li class="active"><a href="/admin/<%= resource %>?trashed=1">Trash</a></li>
        <li><a href="/admin/<%= resource %>">← Back to all</a></li>
        <% } %>
      </ul>
    <% } %>

    <% const showBulk = !['comments','messages'].includes(resource) && canManageResource(resource, 'bulk'); %>
    <% if (showBulk) { %>
    <div class="np-tablenav">
      <div class="tablenav-actions">
        <select class="form-select form-select-sm" aria-label="Bulk actions" data-bulk-action disabled>
          <option value="">Bulk actions</option>
          <option value="delete">Move to Trash</option>
          <% if (['posts','pages'].includes(resource)) { %>
          <option value="publish">Publish</option>
          <option value="draft">Move to Draft</option>
          <option value="pending">Mark Pending Review</option>
          <% if (resource === 'posts') { %><option value="change_category">Change Category</option><% } %>
          <% if (can('manage_posts') || can('manage_pages')) { %><option value="change_author">Change Author</option><% } %>
          <% } %>
          <% if (trashed) { %><option value="restore">Restore</option><option value="delete">Delete Permanently</option><% } %>
        </select>
        <button class="np-btn np-btn-secondary np-btn-small" type="button" data-bulk-apply disabled>Apply</button>
      </div>
      <div class="np-tablenav-pages">
        <% if (pagination.total) { %><%= pagination.total %> item<%= pagination.total === 1 ? '' : 's' %><% } %>
      </div>
    </div>
    <% } %>

    <div class="list-toolbar">
      <form class="admin-search" method="get">
        <input class="form-control" name="q" placeholder="Search <%= resourceLabel.toLowerCase() %>..." value="<%= query %>" aria-label="Search">
        <% if (resource === 'posts' || resource === 'pages') { %>
          <input type="hidden" name="status" value="<%= filters.status || '' %>">
        <% } %>
        <% if (trashed) { %><input type="hidden" name="trashed" value="1"><% } %>
        <% if (resource === 'posts') { %>
          <select class="form-select" name="category_id" aria-label="Filter by category">
            <option value="">All categories</option>
            <% (extra.categories || []).forEach(function(category) { %>
              <option value="<%= category.id %>" <%= String(filters.category_id) === String(category.id) ? 'selected' : '' %>><%= category.name %></option>
            <% }) %>
          </select>
        <% } %>
        <% if (resource === 'menu-items') { %>
          <select class="form-select" name="menu_id" aria-label="Filter by menu">
            <option value="">All menus</option>
            <% (extra.menus || []).forEach(function(menu) { %>
              <option value="<%= menu.id %>" <%= String(filters.menu_id) === String(menu.id) ? 'selected' : '' %>><%= menu.name %></option>
            <% }) %>
          </select>
        <% } %>
        <button class="np-btn np-btn-secondary" type="submit">Search</button>
      </form>
    </div>

    <div class="np-list-table-wrap">
      <table class="np-list-table admin-table">
        <thead>
          <tr>
            <th class="check-column"><input type="checkbox" aria-label="Select all" data-select-all></th>
            <th>Title</th>
            <% if (['posts','pages'].includes(resource)) { %><th>Author</th><% } %>
            <% if (resource === 'menu-items') { %><th>Menu</th><th>URL</th><th>Order</th><% } %>
            <th>Status</th>
            <% if (resource === 'posts') { %><th>Category</th><% } %>
            <% if (!['menu-items'].includes(resource)) { %><th>Date</th><% } %>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(function(row) { %>
            <% const statusKey = row.status || (row.active ? 'active' : 'inactive');
               const badgeClass = statusKey === 'published' || row.active ? 'success' : (statusKey === 'draft' ? 'info' : (statusKey === 'scheduled' ? 'warning' : (statusKey === 'private' ? 'muted' : 'muted'))); %>
            <tr>
              <td class="check-column"><input type="checkbox" class="row-select" aria-label="Select item" value="<%= row.id %>"></td>
              <td class="title-column">
                <% if (canManageResource(resource, 'edit', row)) { %>
                  <a class="row-title" href="/admin/<%= resource %>/<%= row.id %>/edit"><%= row.title || row.name || row.subject || row.email %></a>
                <% } else { %>
                  <span class="row-title text-muted"><%= row.title || row.name || row.subject || row.email %></span>
                <% } %>
                <div class="row-actions">
                  <% if (canManageResource(resource, 'edit', row)) { %><a href="/admin/<%= resource %>/<%= row.id %>/edit">Edit</a><% } %>
                  <% if (!trashed && ['posts', 'pages'].includes(resource) && canManageResource(resource, 'edit', row)) { %><span class="sep">|</span><a href="/admin/revisions?resource_type=<%= resource === 'pages' ? 'page' : 'post' %>&resource_id=<%= row.id %>">Revisions</a><% } %>
                  <% if (row.slug && row.status === 'published') { %><span class="sep">|</span><a href="/<%= resource === 'pages' ? 'page' : 'post' %>/<%= row.slug %>" target="_blank" rel="noopener">View</a><% } %>
                  <% if (trashed && canManageResource(resource, 'destroy', row)) { %>
                    <form class="d-inline" method="post" action="/admin/<%= resource %>/<%= row.id %>/restore">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button class="np-btn-link border-0 bg-transparent p-0" type="submit">Restore</button>
                    </form>
                    <span class="sep">|</span>
                    <form class="d-inline" method="post" action="/admin/<%= resource %>/<%= row.id %>/force?_method=DELETE" data-confirm="Permanently delete this item?">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button class="delete-link border-0 bg-transparent p-0" type="submit">Delete Permanently</button>
                    </form>
                  <% } else if (canManageResource(resource, 'destroy', row)) { %>
                    <span class="sep">|</span>
                    <form class="d-inline" method="post" action="/admin/<%= resource %>/<%= row.id %>?_method=DELETE" data-confirm="Move this item to trash?">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button class="delete-link border-0 bg-transparent p-0" type="submit">Trash</button>
                    </form>
                  <% } %>
                </div>
                <% if (row.slug) { %><div class="row-slug"><%= row.slug %><% if (resource === 'menus' && row.location) { %> · <%= row.location %><% } %></div><% } %>
                <% if (resource === 'menus') { %>
                  <div class="menu-items-preview mt-2">
                    <% if (row.items && row.items.length) { %>
                      <% row.items.forEach(function(item) { %>
                        <span class="badge text-bg-light border me-1 mb-1"><a href="/admin/menu-items/<%= item.id %>/edit"><%= item.title %></a></span>
                      <% }) %>
                    <% } else { %>
                      <span class="text-muted">No items yet.</span>
                    <% } %>
                    <div class="row-actions mt-1">
                      <a href="/admin/menu-items?menu_id=<%= row.id %>">Manage items</a>
                      <span class="sep">|</span>
                      <a href="/admin/menu-items/create?menu_id=<%= row.id %>">Add item</a>
                    </div>
                  </div>
                <% } %>
              </td>
              <% if (['posts','pages'].includes(resource)) { %><td class="author-column"><%= row.author ? row.author.name : '—' %></td><% } %>
              <% if (resource === 'menu-items') { %>
                <td><%= row.Menu ? row.Menu.name : '—' %></td>
                <td class="text-muted"><%= row.url %></td>
                <td><%= row.display_order %></td>
              <% } %>
              <td><span class="np-badge np-badge-<%= badgeClass %>"><%= statusKey %></span></td>
              <% if (resource === 'posts') { %><td><%= row.Category ? row.Category.name : '—' %></td><% } %>
              <% if (!['menu-items'].includes(resource)) { %><td class="date-column"><%= row.created_at ? formatDate(row.created_at) : '' %></td><% } %>
            </tr>
          <% }) %>
          <% if (!rows.length) { %>
            <tr><td colspan="<%= resource === 'posts' ? 6 : (resource === 'pages' ? 5 : (resource === 'menu-items' ? 6 : 4)) %>">
              <div class="empty-state empty-state-card">
                <i class="bi bi-inbox d-block" aria-hidden="true"></i>
                <strong>No <%= resourceLabel.toLowerCase() %> found</strong>
                <p class="mb-2">Try another search or create a new item.</p>
                <% if (canManageResource(resource, 'create')) { %>
                  <a class="np-btn np-btn-primary" href="/admin/<%= resource %>/create"><i class="bi bi-plus-lg"></i> Add New</a>
                <% } %>
              </div>
            </td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="np-list-mobile-cards" aria-label="<%= resourceLabel %> list">
      <% rows.forEach(function(row) { %>
        <% const statusKey = row.status || (row.active ? 'active' : 'inactive');
           const badgeClass = statusKey === 'published' || row.active ? 'success' : (statusKey === 'draft' ? 'info' : (statusKey === 'scheduled' ? 'warning' : 'muted')); %>
        <article class="np-list-mobile-card">
          <div class="d-flex align-items-start gap-2 mb-2">
            <input type="checkbox" class="row-select mt-1" aria-label="Select item" value="<%= row.id %>">
            <div class="flex-grow-1">
              <% if (canManageResource(resource, 'edit', row)) { %>
                <a class="row-title" href="/admin/<%= resource %>/<%= row.id %>/edit"><%= row.title || row.name || row.subject || row.email %></a>
              <% } else { %>
                <span class="row-title text-muted"><%= row.title || row.name || row.subject || row.email %></span>
              <% } %>
              <div class="mt-1"><span class="np-badge np-badge-<%= badgeClass %>"><%= statusKey %></span></div>
            </div>
          </div>
          <div class="row-actions">
            <% if (canManageResource(resource, 'edit', row)) { %><a href="/admin/<%= resource %>/<%= row.id %>/edit">Edit</a><% } %>
            <% if (!trashed && ['posts', 'pages'].includes(resource) && canManageResource(resource, 'edit', row)) { %><span class="sep">|</span><a href="/admin/revisions?resource_type=<%= resource === 'pages' ? 'page' : 'post' %>&resource_id=<%= row.id %>">Revisions</a><% } %>
            <% if (row.slug && row.status === 'published') { %><span class="sep">|</span><a href="/<%= resource === 'pages' ? 'page' : 'post' %>/<%= row.slug %>" target="_blank" rel="noopener">View</a><% } %>
          </div>
        </article>
      <% }) %>
      <% if (!rows.length) { %>
        <div class="np-empty-state">
          <i class="bi bi-inbox" aria-hidden="true"></i>
          <strong>No <%= resourceLabel.toLowerCase() %> found</strong>
          <p class="mb-2">Try another search or create a new item.</p>
          <% if (canManageResource(resource, 'create')) { %>
            <a class="np-btn np-btn-primary" href="/admin/<%= resource %>/create"><i class="bi bi-plus-lg"></i> Add New</a>
          <% } %>
        </div>
      <% } %>
    </div>

    <% if (pagination.pages > 1) { %>
      <nav class="mt-3" aria-label="Pagination">
        <ul class="pagination pagination-sm">
          <% for (let i = 1; i <= pagination.pages; i++) { %>
            <li class="page-item <%= i === pagination.page ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>&q=<%= encodeURIComponent(query || '') %>&status=<%= filters.status || '' %>&category_id=<%= filters.category_id || '' %>&menu_id=<%= filters.menu_id || '' %>"><%= i %></a></li>
          <% } %>
        </ul>
      </nav>
    <% } %>

    <form id="bulk-form" method="post" action="/admin/<%= resource %>/bulk" class="d-none" aria-hidden="true">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="action" value="<%= trashed ? 'restore' : 'trash' %>" data-bulk-form-action>
      <% if (trashed) { %><input type="hidden" name="return_trashed" value="1"><% } %>
    </form>
  </main>
</div>
<%- include('../partials/footer') %>
