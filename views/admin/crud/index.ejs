<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content">
    <%- include('../partials/flash') %>
    <div class="list-toolbar">
      <form class="admin-search" method="get">
        <i class="bi bi-search"></i>
        <input class="form-control" name="q" placeholder="Search <%= title.toLowerCase() %>..." value="<%= query %>">
        <% if (resource === 'posts') { %>
          <select class="form-select" name="status">
            <option value="">All statuses</option>
            <% ['draft','published','private','scheduled'].forEach(function(status) { %>
              <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= status %></option>
            <% }) %>
          </select>
          <select class="form-select" name="category_id">
            <option value="">All categories</option>
            <% (extra.categories || []).forEach(function(category) { %>
              <option value="<%= category.id %>" <%= String(filters.category_id) === String(category.id) ? 'selected' : '' %>><%= category.name %></option>
            <% }) %>
          </select>
        <% } %>
        <button class="btn btn-outline-primary">Search</button>
      </form>
      <% if (!['comments','messages'].includes(resource)) { %><a class="btn btn-primary" href="/admin/<%= resource %>/create"><i class="bi bi-plus-lg"></i> Add New</a><% } %>
    </div>
    <div class="card">
      <div class="table-responsive">
        <table class="table admin-table align-middle mb-0">
          <thead><tr><th>ID</th><th>Title/Name</th><th>Status</th><th>Created</th><th class="text-end">Actions</th></tr></thead>
          <tbody>
            <% rows.forEach(function(row) { %>
              <tr>
                <td><%= row.id %></td>
                <td><strong><%= row.title || row.name || row.subject || row.email %></strong><br><small class="text-muted"><%= row.slug || row.url || '' %></small></td>
                <td><span class="status-pill status-<%= row.status || (row.active ? 'published' : 'draft') %>"><%= row.status || (row.active ? 'active' : 'inactive') %></span></td>
                <td><%= row.created_at ? row.created_at.toISOString().slice(0,10) : '' %></td>
                <td class="text-end">
                  <a class="btn btn-sm btn-outline-primary" href="/admin/<%= resource %>/<%= row.id %>/edit"><i class="bi bi-pencil"></i> Edit</a>
                  <form class="d-inline" method="post" action="/admin/<%= resource %>/<%= row.id %>?_method=DELETE" data-confirm="Delete this item?">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
            <% if (!rows.length) { %>
              <tr><td colspan="5"><div class="empty-state"><i class="bi bi-inbox"></i><strong>No records found</strong><span>Try another search or create a new item.</span></div></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
    <nav class="mt-3">
      <ul class="pagination">
        <% for (let i = 1; i <= pagination.pages; i++) { %>
          <li class="page-item <%= i === pagination.page ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>&q=<%= query %>&status=<%= filters.status %>&category_id=<%= filters.category_id %>"><%= i %></a></li>
        <% } %>
      </ul>
    </nav>
  </main>
</div>
<%- include('../partials/footer') %>
