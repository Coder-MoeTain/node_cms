<aside class="admin-sidebar">
  <% const isActive = (path) => currentPath === path || (path !== '/admin' && currentPath.startsWith(path)); %>
  <a class="brand" href="/admin">
    <span class="brand-mark"><i class="bi bi-stars"></i></span>
    <span><strong>NodePress</strong><small>Mission CMS</small></span>
  </a>
  <nav class="nav flex-column admin-nav">
    <span class="nav-section">Overview</span>
    <a class="nav-link <%= isActive('/admin') ? 'active' : '' %>" href="/admin"><i class="bi bi-speedometer2"></i> Dashboard</a>
    <span class="nav-section">Publish</span>
    <a class="nav-link <%= isActive('/admin/posts') ? 'active' : '' %>" href="/admin/posts"><i class="bi bi-file-richtext"></i> Posts</a>
    <a class="nav-link <%= isActive('/admin/pages') ? 'active' : '' %>" href="/admin/pages"><i class="bi bi-files"></i> Pages</a>
    <a class="nav-link <%= isActive('/admin/categories') ? 'active' : '' %>" href="/admin/categories"><i class="bi bi-folder"></i> Categories</a>
    <a class="nav-link <%= isActive('/admin/tags') ? 'active' : '' %>" href="/admin/tags"><i class="bi bi-tags"></i> Tags</a>
    <a class="nav-link <%= isActive('/admin/media') ? 'active' : '' %>" href="/admin/media"><i class="bi bi-images"></i> Media</a>
    <span class="nav-section">Engage</span>
    <a class="nav-link <%= isActive('/admin/comments') ? 'active' : '' %>" href="/admin/comments"><i class="bi bi-chat-dots"></i> Comments</a>
    <a class="nav-link <%= isActive('/admin/messages') ? 'active' : '' %>" href="/admin/messages"><i class="bi bi-envelope"></i> Contact Messages</a>
    <span class="nav-section">Experience</span>
    <a class="nav-link <%= isActive('/admin/menus') ? 'active' : '' %>" href="/admin/menus"><i class="bi bi-list"></i> Menus</a>
    <a class="nav-link <%= isActive('/admin/menu-items') ? 'active' : '' %>" href="/admin/menu-items"><i class="bi bi-menu-button-wide"></i> Menu Items</a>
    <a class="nav-link <%= isActive('/admin/sliders') ? 'active' : '' %>" href="/admin/sliders"><i class="bi bi-sliders"></i> Sliders</a>
    <a class="nav-link <%= isActive('/admin/banners') ? 'active' : '' %>" href="/admin/banners"><i class="bi bi-badge-ad"></i> Banners</a>
    <a class="nav-link <%= isActive('/admin/themes') ? 'active' : '' %>" href="/admin/themes"><i class="bi bi-palette"></i> Themes</a>
    <span class="nav-section">System</span>
    <a class="nav-link <%= isActive('/admin/users') ? 'active' : '' %>" href="/admin/users"><i class="bi bi-people"></i> Users</a>
    <a class="nav-link <%= isActive('/admin/roles') ? 'active' : '' %>" href="/admin/roles"><i class="bi bi-shield-lock"></i> Roles & Permissions</a>
    <a class="nav-link <%= isActive('/admin/security') ? 'active' : '' %>" href="/admin/security"><i class="bi bi-shield-check"></i> Security Plugins</a>
    <a class="nav-link <%= isActive('/admin/settings') ? 'active' : '' %>" href="/admin/settings"><i class="bi bi-gear"></i> Site Settings</a>
    <a class="nav-link external-link" href="/" target="_blank"><i class="bi bi-box-arrow-up-right"></i> View Site</a>
  </nav>
</aside>
