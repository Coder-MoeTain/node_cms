<% if (success && success.length) { %>
  <div class="toast-container position-fixed top-0 end-0 p-3 np-toast-container" aria-live="polite" aria-atomic="true">
    <% success.forEach(function(message) { %>
      <div class="toast show np-toast np-toast-success" role="status">
        <div class="toast-body d-flex align-items-center gap-2">
          <i class="bi bi-check-circle-fill" aria-hidden="true"></i>
          <span><%= message %></span>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
<% if (error && error.length) { %>
  <div class="toast-container position-fixed top-0 end-0 p-3 np-toast-container" aria-live="assertive" aria-atomic="true">
    <% error.forEach(function(message) { %>
      <div class="toast show np-toast np-toast-error" role="alert">
        <div class="toast-body d-flex align-items-center gap-2">
          <i class="bi bi-exclamation-circle-fill" aria-hidden="true"></i>
          <span><%= message %></span>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
