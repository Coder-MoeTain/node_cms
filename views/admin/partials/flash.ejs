<% if (success && success.length) { %>
  <div class="toast-container position-fixed top-0 end-0 p-3 np-toast-container" aria-live="polite">
    <% success.forEach(function(message) { %>
      <div class="toast show np-toast np-toast-success" role="status">
        <div class="toast-body d-flex align-items-start gap-2">
          <i class="bi bi-check-circle-fill flex-shrink-0" aria-hidden="true"></i>
          <span class="flex-grow-1"><%= message %></span>
          <button type="button" class="btn-close btn-close-white np-toast-close" data-bs-dismiss="toast" aria-label="Dismiss"></button>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
<% if (error && error.length) { %>
  <div class="toast-container position-fixed top-0 end-0 p-3 np-toast-container" aria-live="assertive">
    <% error.forEach(function(message) { %>
      <div class="toast show np-toast np-toast-error np-toast-persist" role="alert">
        <div class="toast-body d-flex align-items-start gap-2">
          <i class="bi bi-exclamation-circle-fill flex-shrink-0" aria-hidden="true"></i>
          <span class="flex-grow-1"><%= message %></span>
          <button type="button" class="btn-close np-toast-close" data-bs-dismiss="toast" aria-label="Dismiss"></button>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
