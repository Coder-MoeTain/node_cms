<header class="admin-topbar">
  <div>
    <button class="btn btn-sm btn-outline-secondary d-lg-none" data-sidebar-toggle><i class="bi bi-list"></i></button>
    <span class="fw-semibold"><%= title %></span>
  </div>
  <div class="d-flex align-items-center gap-3">
    <button class="btn btn-sm btn-outline-dark" data-theme-toggle type="button">Dark/Light</button>
    <a href="/admin/profile" class="text-decoration-none"><%= currentUser ? currentUser.name : 'Admin' %></a>
    <form action="/admin/logout" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn btn-sm btn-danger">Logout</button>
    </form>
  </div>
</header>
