<% const locales = typeof translationLocales !== 'undefined' ? translationLocales : ['en', 'my', 'zh-CN', 'ru']; %>
<% const labels = { en: 'English', my: 'Myanmar (မြန်မာ)', 'zh-CN': 'Chinese (中文)', ru: 'Russian (Русский)' }; %>
<% const store = typeof translations !== 'undefined' ? translations : {}; %>

<div class="np-metabox mt-3" data-content-translations>
  <div class="np-metabox-header">Translations</div>
  <div class="np-metabox-body">
    <p class="np-help-text">Use <strong>Auto-fill translations</strong> under the main editor to generate draft translations from the title and body. Review and edit before publishing. Saved translations override glossary auto-translation on the public site.</p>
    <ul class="nav nav-tabs mb-3" role="tablist">
      <% locales.forEach(function(locale, idx) { %>
        <li class="nav-item" role="presentation">
          <button class="nav-link<%= idx === 0 ? ' active' : '' %>" type="button" data-bs-toggle="tab" data-bs-target="#tr-tab-<%= locale.replace(/[^a-z]/gi, '') %>" role="tab"><%= labels[locale] || locale %></button>
        </li>
      <% }) %>
    </ul>
    <div class="tab-content">
      <% locales.forEach(function(locale, idx) {
        const row = store[locale] || {};
        const key = locale;
      %>
        <div class="tab-pane fade<%= idx === 0 ? ' show active' : '' %>" id="tr-tab-<%= locale.replace(/[^a-z]/gi, '') %>" role="tabpanel" data-translation-locale="<%= key %>">
          <div class="mb-2"><label class="form-label">Title</label><input class="form-control" name="tr[<%= key %>][title]" data-translation-field="title" value="<%= row.title || '' %>"></div>
          <div class="mb-2"><label class="form-label">Excerpt</label><textarea class="form-control" name="tr[<%= key %>][excerpt]" data-translation-field="excerpt" rows="2"><%= row.excerpt || '' %></textarea></div>
          <div class="mb-2"><label class="form-label">Content</label><textarea class="form-control" name="tr[<%= key %>][content]" data-translation-field="content" rows="8"><%- row.content || '' %></textarea></div>
          <div class="mb-2"><label class="form-label">SEO Title</label><input class="form-control" name="tr[<%= key %>][seo_title]" data-translation-field="seo_title" value="<%= row.seo_title || '' %>"></div>
          <div><label class="form-label">SEO Description</label><textarea class="form-control" name="tr[<%= key %>][seo_description]" data-translation-field="seo_description" rows="2"><%= row.seo_description || '' %></textarea></div>
        </div>
      <% }) %>
    </div>
  </div>
</div>
