<div class="modal fade" id="mediaGalleryModal" tabindex="-1" aria-labelledby="mediaGalleryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content media-gallery-modal">
      <div class="modal-header">
        <div>
          <h5 class="modal-title" id="mediaGalleryModalLabel">Media Library</h5>
          <small class="text-muted">Upload a photo or choose one from your library.</small>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="media-gallery-toolbar">
          <div class="media-gallery-upload">
            <input type="file" class="d-none" id="mediaGalleryUploadInput" accept="image/jpeg,image/png,image/gif,image/webp" multiple>
            <button type="button" class="np-btn np-btn-primary np-btn-small" data-media-gallery-upload>
              <i class="bi bi-upload"></i> Upload Photo
            </button>
            <span class="text-muted small ms-2" data-media-gallery-upload-status></span>
          </div>
        </div>
        <div class="media-gallery-grid" data-media-gallery-grid>
          <div class="media-gallery-empty">Loading media...</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="np-btn np-btn-secondary" data-bs-dismiss="modal">Cancel</button>
      </div>
    </div>
  </div>
</div>
