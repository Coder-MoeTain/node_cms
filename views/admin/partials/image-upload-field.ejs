<%
  const pathField = typeof name !== 'undefined' ? name : 'image';
  const uploadField = typeof fileName !== 'undefined' ? fileName : 'image_file';
  const currentValue = typeof value !== 'undefined' ? value : '';
  const fieldLabel = typeof label !== 'undefined' ? label : 'Image';
%>
<div class="image-upload-field mb-3" data-image-upload>
  <label class="form-label"><%= fieldLabel %></label>
  <input type="hidden" name="<%= pathField %>" value="<%= currentValue %>" data-image-path>
  <input type="hidden" name="remove_<%= pathField %>" value="0" data-image-remove-flag>
  <input class="form-control mb-2" type="file" name="<%= uploadField %>" accept="image/*" data-image-file>
  <div class="d-flex flex-wrap gap-2 mb-2">
    <button class="np-btn np-btn-secondary np-btn-small" type="button" data-open-media-picker="<%= pathField %>">Choose from Library</button>
    <% if (currentValue) { %><button class="np-btn np-btn-link np-btn-small text-danger" type="button" data-remove-image>Remove</button><% } %>
  </div>
  <% if (currentValue) { %>
    <img class="settings-image-preview" data-image-preview data-media-preview="<%= pathField %>" src="<%= currentValue %>" alt="<%= fieldLabel %>">
  <% } else { %>
    <div class="settings-empty-preview" data-image-preview data-media-preview="<%= pathField %>">No image selected</div>
  <% } %>
</div>
