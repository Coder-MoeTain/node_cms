<div class="modal fade" id="npConfirmModal" tabindex="-1" aria-labelledby="npConfirmModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content np-confirm-modal">
      <div class="modal-header">
        <h5 class="modal-title" id="npConfirmModalLabel">Please confirm</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0" data-confirm-message>Are you sure?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="np-btn np-btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="np-btn np-btn-danger" data-confirm-accept>Confirm</button>
      </div>
    </div>
  </div>
</div>
