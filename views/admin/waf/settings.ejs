<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header">
      <div>
        <h1>WAF Settings</h1>
        <p class="np-help-text mb-0">Configure protection mode, categories, logging, and auto-blocking.</p>
      </div>
      <a class="np-btn np-btn-secondary" href="/admin/waf">Dashboard</a>
    </div>
    <%- include('../partials/waf-nav', { activeNav: typeof activeNav !== 'undefined' ? activeNav : 'settings' }) %>
    <div class="np-alert np-alert-info">
      <strong>Monitor mode</strong> logs suspicious requests without blocking. Use it for 24–48 hours before switching to <strong>block mode</strong>.
    </div>
    <form method="post" action="/admin/waf/settings">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="_waf_settings_form" value="1">
      <div class="np-widget">
        <div class="np-widget-header"><span>General</span></div>
        <div class="np-widget-body">
          <div class="row g-3">
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="waf_enabled" <%= settings.waf_enabled === 'true' ? 'checked' : '' %>> Enable WAF</label></div>
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="admin_protection_enabled" <%= settings.admin_protection_enabled === 'true' ? 'checked' : '' %>> Protect admin routes</label></div>
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="public_protection_enabled" <%= settings.public_protection_enabled === 'true' ? 'checked' : '' %>> Protect public routes</label></div>
            <div class="col-md-4">
              <label class="form-label">Mode</label>
              <select class="form-select" name="waf_mode">
                <option value="disabled" <%= settings.waf_mode === 'disabled' ? 'selected' : '' %>>Disabled</option>
                <option value="monitor" <%= settings.waf_mode === 'monitor' ? 'selected' : '' %>>Monitor only</option>
                <option value="block" <%= settings.waf_mode === 'block' ? 'selected' : '' %>>Block matched requests</option>
              </select>
            </div>
            <div class="col-md-4"><label class="form-label">Max risk score (public)</label><input class="form-control" type="number" min="1" max="100" name="max_risk_score_public" value="<%= settings.max_risk_score_public || settings.max_risk_score || 50 %>"></div>
            <div class="col-md-4"><label class="form-label">Max risk score (admin)</label><input class="form-control" type="number" min="1" max="100" name="max_risk_score_admin" value="<%= settings.max_risk_score_admin || 40 %>"></div>
            <div class="col-md-8"><label class="form-label">Blocked response message</label><input class="form-control" name="waf_response_message" value="<%= settings.waf_response_message || 'Request blocked by Web Application Firewall.' %>"></div>
            <div class="col-md-4"><label class="form-check mt-4"><input class="form-check-input" type="checkbox" name="trusted_proxy_enabled" <%= settings.trusted_proxy_enabled === 'true' ? 'checked' : '' %>> Trust proxy headers (X-Forwarded-For, CF-Connecting-IP)</label></div>
          </div>
        </div>
      </div>
      <div class="np-widget">
        <div class="np-widget-header"><span>Protection Categories</span></div>
        <div class="np-widget-body">
          <div class="row g-2">
            <% [['block_sql_injection','SQL injection'],['block_xss','XSS'],['block_path_traversal','Path traversal'],['block_command_injection','Command injection'],['block_bad_bots','Bad bots'],['block_scanners','Scanners'],['block_cms_probes','CMS probes / sensitive files']].forEach(function(item) { %>
              <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="<%= item[0] %>" <%= settings[item[0]] === 'true' ? 'checked' : '' %>> <%= item[1] %></label></div>
            <% }) %>
          </div>
        </div>
      </div>
      <div class="np-widget">
        <div class="np-widget-header"><span>Logging and Auto Block</span></div>
        <div class="np-widget-body">
          <div class="row g-3">
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="log_all_suspicious" <%= settings.log_all_suspicious === 'true' ? 'checked' : '' %>> Log all suspicious requests</label></div>
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="log_blocked_only" <%= settings.log_blocked_only === 'true' ? 'checked' : '' %>> Log blocked actions only</label></div>
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="log_all_requests" <%= settings.log_all_requests === 'true' ? 'checked' : '' %>> Log all dynamic requests</label></div>
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="auto_block_enabled" <%= settings.auto_block_enabled === 'true' ? 'checked' : '' %>> Enable auto block</label></div>
            <div class="col-md-4"><label class="form-label">Auto block threshold</label><input class="form-control" type="number" min="1" name="auto_block_threshold" value="<%= settings.auto_block_threshold || 5 %>"></div>
            <div class="col-md-4"><label class="form-label">Auto block window (minutes)</label><input class="form-control" type="number" min="1" name="auto_block_window_minutes" value="<%= settings.auto_block_window_minutes || 10 %>"></div>
            <div class="col-md-4"><label class="form-label">Auto block duration (minutes)</label><input class="form-control" type="number" min="1" name="auto_block_duration_minutes" value="<%= settings.auto_block_duration_minutes || 60 %>"></div>
          </div>
        </div>
      </div>
      <div class="np-widget">
        <div class="np-widget-header"><span>WebGuard API Connection</span></div>
        <div class="np-widget-body">
          <% if (webguardEnvFallback) { %>
            <div class="np-alert np-alert-info mb-3">
              Some WebGuard values are still loaded from environment variables. Saved values below override <code>.env</code> when filled in.
            </div>
          <% } %>
          <div class="row g-3">
            <div class="col-md-8">
              <label class="form-label">API URL</label>
              <input class="form-control" type="url" name="webguard_api_url" value="<%= settings.webguard_api_url || '' %>" placeholder="http://127.0.0.1:8001">
              <div class="np-help-text">Base URL of the WebGuard-ML service (no trailing slash).</div>
            </div>
            <div class="col-md-4">
              <label class="form-label">Timeout (ms)</label>
              <input class="form-control" type="number" min="100" max="60000" name="webguard_timeout_ms" value="<%= settings.webguard_timeout_ms || '500' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">API key</label>
              <input class="form-control" type="password" name="webguard_api_key" autocomplete="new-password" placeholder="<%= settings.webguard_api_key_set ? 'Saved key (leave blank to keep)' : 'X-API-Key header value' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Bearer token (optional)</label>
              <input class="form-control" type="password" name="webguard_api_token" autocomplete="new-password" placeholder="<%= settings.webguard_api_token_set ? 'Saved token (leave blank to keep)' : 'Authorization: Bearer token' %>">
            </div>
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="webguard_allow_localhost" <%= settings.webguard_allow_localhost === 'true' ? 'checked' : '' %>> Allow localhost / loopback URLs</label></div>
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="webguard_fail_open" <%= settings.webguard_fail_open !== 'false' ? 'checked' : '' %>> Fail open when API is unavailable</label></div>
            <div class="col-md-4 d-flex align-items-end">
              <button class="np-btn np-btn-secondary" type="button" id="webguard-test-btn">Test connection</button>
            </div>
          </div>
          <div id="webguard-test-result" class="mt-3" hidden></div>
          <p class="np-help-text mb-0">Use API key or bearer token. Environment variables remain a fallback until values are saved here.</p>
        </div>
      </div>
      <div class="np-widget">
        <div class="np-widget-header"><span>WebGuard ML Detection</span></div>
        <div class="np-widget-body">
          <% if (!webguardConfigured) { %>
            <div class="np-alert np-alert-warning mb-3">
              WebGuard is not configured. Enter API URL and credentials above, save settings, then enable ML detection below.
            </div>
          <% } else if (webguardHealth && !webguardHealth.ok) { %>
            <div class="np-alert np-alert-warning mb-3">
              WebGuard API is configured but not reachable<%= webguardHealth.error ? `: ${webguardHealth.error}` : '' %>.
            </div>
          <% } else if (webguardHealth && webguardHealth.ok) { %>
            <div class="np-alert np-alert-success mb-3">WebGuard API is reachable. Trained models can augment WAF scoring.</div>
          <% } %>
          <div class="row g-3">
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="ml_waf_enabled" <%= settings.ml_waf_enabled === 'true' ? 'checked' : '' %>> Enable ML detection</label></div>
            <div class="col-md-4"><label class="form-label">Confidence threshold</label><input class="form-control" type="number" min="0.1" max="1" step="0.05" name="ml_waf_confidence_threshold" value="<%= settings.ml_waf_confidence_threshold || '0.7' %>"></div>
            <div class="col-md-4"><label class="form-label">Active model</label>
              <select class="form-select" name="ml_waf_model_id">
                <option value="" <%= !settings.ml_waf_model_id ? 'selected' : '' %>>Latest / auto-detect</option>
                <% (mlModels || []).forEach(function(model) { %>
                  <option value="<%= model.id %>" <%= settings.ml_waf_model_id === model.id ? 'selected' : '' %>><%= model.name || model.id %><%= model.source === 'webguard' ? ' (WebGuard)' : '' %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="ml_waf_block_standalone" <%= settings.ml_waf_block_standalone !== 'false' ? 'checked' : '' %>> ML detections can block alone</label></div>
            <div class="col-md-4"><label class="form-check"><input class="form-check-input" type="checkbox" name="ml_waf_reject_uncertain" <%= settings.ml_waf_reject_uncertain !== 'false' ? 'checked' : '' %>> Ignore uncertain predictions</label></div>
          </div>
          <p class="np-help-text mb-0">ML runs alongside signature rules. Use monitor mode first to validate false positives before blocking.</p>
        </div>
      </div>
      <p class="mb-4"><button class="np-btn np-btn-primary" type="submit">Save Settings</button></p>
    </form>

    <div class="np-widget">
      <div class="np-widget-header"><span>WebGuard ML Models</span></div>
      <div class="np-widget-body">
        <div class="border rounded p-3 mb-3 bg-light">
          <h2 class="h6 mb-3">Upload ML model (.zip)</h2>
          <p class="np-help-text">Upload a WebGuard model archive containing <code>rf_*.joblib</code> and preprocessor files. Max 25 MB.</p>
          <form method="post" action="/admin/waf/models/upload" enctype="multipart/form-data" class="row g-3 align-items-end">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="col-md-5">
              <label class="form-label">Model archive</label>
              <input class="form-control" type="file" name="model_archive" accept=".zip,application/zip" required>
            </div>
            <div class="col-md-3">
              <label class="form-label">Model ID (optional)</label>
              <input class="form-control" name="model_id" placeholder="rf_demo">
            </div>
            <div class="col-md-2">
              <label class="form-check mt-4"><input class="form-check-input" type="checkbox" name="activate_after" checked> Activate after upload</label>
            </div>
            <div class="col-md-2">
              <button class="np-btn np-btn-secondary w-100" type="submit">Upload model</button>
            </div>
          </form>
        </div>

        <% if ((mlModels || []).length) { %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>Model ID</th>
                  <th>Files</th>
                  <th>Installed</th>
                  <th>Remote</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% mlModels.forEach(function(model) { %>
                  <tr>
                    <td>
                      <strong><%= model.id %></strong>
                      <% if (settings.ml_waf_model_id === model.id) { %><span class="badge bg-success ms-1">Active</span><% } %>
                    </td>
                    <td class="small text-muted"><%= (model.joblib_files || model.files || []).slice(0, 3).join(', ') %></td>
                    <td class="small"><%= formatDateTime(model.installed_at) %></td>
                    <td class="small">
                      <% if (model.remote_synced) { %>Synced<% } else if (model.remote_error) { %><span class="text-warning" title="<%= model.remote_error %>">Local only</span><% } else { %>Local<% } %>
                    </td>
                    <td class="text-end">
                      <% if (settings.ml_waf_model_id !== model.id) { %>
                        <form method="post" action="/admin/waf/models/<%= model.id %>/activate" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-sm btn-outline-primary" type="submit">Activate</button>
                        </form>
                      <% } %>
                      <form method="post" action="/admin/waf/models/<%= model.id %>/delete" class="d-inline" onsubmit="return confirm('Delete model <%= model.id %>?');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="np-help-text mb-0">No uploaded models yet. Upload a trained WebGuard model zip to enable ML scoring.</p>
        <% } %>
      </div>
    </div>
  </main>
</div>
<script>
  (function () {
    const button = document.getElementById('webguard-test-btn');
    const result = document.getElementById('webguard-test-result');
    const form = document.querySelector('form[action="/admin/waf/settings"]');
    if (!button || !result || !form) return;

    button.addEventListener('click', async function () {
      button.disabled = true;
      result.hidden = false;
      result.className = 'mt-3 np-alert np-alert-info';
      result.textContent = 'Testing WebGuard API connection...';

      const formData = new FormData(form);
      try {
        const response = await fetch('/admin/waf/webguard/test', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'Accept': 'application/json'
          },
          body: new URLSearchParams(formData).toString()
        });
        const payload = await response.json();
        if (payload.ok) {
          result.className = 'mt-3 np-alert np-alert-success';
          result.textContent = 'WebGuard API is reachable.';
        } else {
          result.className = 'mt-3 np-alert np-alert-warning';
          result.textContent = payload.error || 'WebGuard API is not reachable.';
        }
      } catch (error) {
        result.className = 'mt-3 np-alert np-alert-warning';
        result.textContent = error.message || 'Connection test failed.';
      } finally {
        button.disabled = false;
      }
    });
  })();
</script>
<%- include('../partials/footer') %>
