<%- include('../../partials/head') %>
<%- include('../../partials/sidebar') %>
<div class="admin-main">
  <%- include('../../partials/topbar') %>
  <main class="admin-content">
    <%- include('../../partials/flash') %>
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
      <div><h2 class="mb-1">WAF Log Detail</h2><p class="text-muted mb-0">Request ID: <code><%= log.request_id %></code></p></div>
      <div class="btn-group">
        <a class="btn btn-outline-secondary" href="/admin/waf/logs">Back</a>
        <form method="post" action="/admin/waf/logs/<%= log.id %>/block-ip"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-outline-danger">Block IP</button></form>
        <form method="post" action="/admin/waf/logs/<%= log.id %>/whitelist-ip"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-outline-success">Whitelist IP</button></form>
      </div>
    </div>
    <div class="row g-3">
      <div class="col-lg-4">
        <div class="card">
          <div class="card-header">Summary</div>
          <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between"><span>IP</span><code><%= log.ip_address %></code></li>
            <li class="list-group-item d-flex justify-content-between"><span>Method</span><span><%= log.method %></span></li>
            <li class="list-group-item d-flex justify-content-between"><span>Action</span><span class="badge text-bg-danger"><%= log.action_taken %></span></li>
            <li class="list-group-item d-flex justify-content-between"><span>Severity</span><span class="badge text-bg-warning"><%= log.severity || '-' %></span></li>
            <li class="list-group-item d-flex justify-content-between"><span>Risk score</span><span class="badge <%= log.risk_score >= 50 ? 'text-bg-danger' : 'text-bg-light' %>"><%= log.risk_score %></span></li>
            <li class="list-group-item d-flex justify-content-between"><span>Admin route</span><span><%= log.is_admin_route ? 'yes' : 'no' %></span></li>
            <li class="list-group-item"><strong>Rule</strong><div><%= log.matched_rule_name || '-' %></div></li>
            <li class="list-group-item"><strong>User Agent</strong><div class="small text-break"><%= log.user_agent || '-' %></div></li>
            <li class="list-group-item"><strong>Referer</strong><div class="small text-break"><%= log.referer || '-' %></div></li>
          </ul>
        </div>
      </div>
      <div class="col-lg-8">
        <div class="card mb-3"><div class="card-header">URL</div><div class="card-body"><code class="text-break"><%= log.url %></code></div></div>
        <div class="card mb-3"><div class="card-header">Headers Snapshot</div><div class="card-body"><pre class="mb-0 small"><%= JSON.stringify(log.headers_snapshot || {}, null, 2) %></pre></div></div>
        <div class="card mb-3"><div class="card-header">Query Snapshot</div><div class="card-body"><pre class="mb-0 small"><%= JSON.stringify(log.query_snapshot || {}, null, 2) %></pre></div></div>
        <div class="card"><div class="card-header">Body Snapshot</div><div class="card-body"><pre class="mb-0 small"><%= JSON.stringify(log.body_snapshot || {}, null, 2) %></pre></div></div>
      </div>
    </div>
    <form class="mt-3" method="post" action="/admin/waf/logs/<%= log.id %>/delete" onsubmit="return confirm('Delete this WAF log?')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn btn-outline-danger">Delete Log</button>
    </form>
  </main>
</div>
<%- include('../../partials/footer') %>
