<%- include('../../partials/head') %>
<%- include('../../partials/sidebar') %>
<% const matchedRules = (log.body_snapshot && log.body_snapshot._waf_meta && log.body_snapshot._waf_meta.matched_rules) || []; %>
<div class="admin-main">
  <%- include('../../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../../partials/flash') %>
    <div class="np-page-header">
      <div>
        <h1>WAF log detail</h1>
        <p class="np-help-text mb-0">Request ID <code><%= log.request_id %></code></p>
      </div>
      <div class="d-flex flex-wrap gap-2">
        <a class="np-btn np-btn-secondary" href="/admin/waf/logs">Back</a>
        <form method="post" action="/admin/waf/logs/<%= log.id %>/block-ip"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="np-btn np-btn-danger">Block IP</button></form>
        <form method="post" action="/admin/waf/logs/<%= log.id %>/whitelist-ip"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="np-btn np-btn-secondary">Whitelist IP</button></form>
      </div>
    </div>

    <%- include('../../partials/waf-nav', { activeNav: typeof activeNav !== 'undefined' ? activeNav : 'logs' }) %>

    <div class="row g-3">
      <div class="col-lg-4">
        <div class="np-widget">
          <div class="np-widget-header"><span>Summary</span></div>
          <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between"><span>IP</span><code><%= log.ip_address %></code></li>
            <li class="list-group-item d-flex justify-content-between"><span>Method</span><span><%= log.method %></span></li>
            <li class="list-group-item d-flex justify-content-between"><span>Action</span><span class="np-badge np-badge-danger"><%= log.action_taken %></span></li>
            <li class="list-group-item d-flex justify-content-between"><span>Severity</span><span class="np-badge np-badge-warning"><%= log.severity || '-' %></span></li>
            <li class="list-group-item d-flex justify-content-between"><span>Risk score</span><span class="np-badge np-badge-<%= log.risk_score >= 50 ? 'danger' : 'warning' %>"><%= log.risk_score %></span></li>
            <li class="list-group-item d-flex justify-content-between"><span>Admin route</span><span><%= log.is_admin_route ? 'yes' : 'no' %></span></li>
            <li class="list-group-item"><strong>Primary rule</strong><div><%= log.matched_rule_name || '-' %></div></li>
            <li class="list-group-item"><strong>User-Agent</strong><div class="small text-break"><%= log.user_agent || '-' %></div></li>
            <li class="list-group-item"><strong>Referer</strong><div class="small text-break"><%= log.referer || '-' %></div></li>
          </ul>
        </div>

        <% if (matchedRules.length) { %>
          <div class="np-widget mt-3">
            <div class="np-widget-header"><span>All matched rules</span><span class="np-badge np-badge-muted"><%= matchedRules.length %></span></div>
            <ul class="list-group list-group-flush">
              <% matchedRules.forEach(function(rule) { %>
                <li class="list-group-item">
                  <strong><%= rule.name || 'Unknown rule' %></strong>
                  <div class="small text-muted"><%= rule.category %> · <%= rule.severity %> · <%= rule.target %><% if (rule.key) { %> (<%= rule.key %>)<% } %></div>
                </li>
              <% }) %>
            </ul>
          </div>
        <% } %>
      </div>
      <div class="col-lg-8">
        <div class="np-widget mb-3"><div class="np-widget-header"><span>URL</span></div><div class="np-widget-body"><code class="text-break"><%= log.url %></code></div></div>
        <div class="np-widget mb-3"><div class="np-widget-header"><span>Headers snapshot</span></div><div class="np-widget-body"><pre class="mb-0 small np-code-block"><%= JSON.stringify(log.headers_snapshot || {}, null, 2) %></pre></div></div>
        <div class="np-widget mb-3"><div class="np-widget-header"><span>Query snapshot</span></div><div class="np-widget-body"><pre class="mb-0 small np-code-block"><%= JSON.stringify(log.query_snapshot || {}, null, 2) %></pre></div></div>
        <div class="np-widget"><div class="np-widget-header"><span>Body snapshot</span></div><div class="np-widget-body"><pre class="mb-0 small np-code-block"><%= JSON.stringify(log.body_snapshot || {}, null, 2) %></pre></div></div>
      </div>
    </div>

    <form class="mt-3" method="post" action="/admin/waf/logs/<%= log.id %>/delete" onsubmit="return confirm('Delete this WAF log?')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="np-btn np-btn-danger">Delete log</button>
    </form>
  </main>
</div>
<%- include('../../partials/footer') %>
