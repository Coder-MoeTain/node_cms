<%- include('../../partials/head') %>
<%- include('../../partials/sidebar') %>
<div class="admin-main">
  <%- include('../../partials/topbar') %>
  <main class="admin-content">
    <%- include('../../partials/flash') %>
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
      <div><h2 class="mb-1">WAF Logs</h2><p class="text-muted mb-0">Review blocked, rate-limited, and monitored request events.</p></div>
      <form class="d-flex gap-2" method="post" action="/admin/waf/logs/delete-old" onsubmit="return confirm('Delete old WAF logs?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input class="form-control" style="width:100px" type="number" min="1" name="days" value="30"><button class="btn btn-outline-danger">Delete Old</button></form>
    </div>
    <form class="card card-body mb-3" method="get" action="/admin/waf/logs">
      <div class="row g-2">
        <div class="col-md-3"><input class="form-control" name="ip" value="<%= filters.ip || '' %>" placeholder="IP address"></div>
        <div class="col-md-2"><select class="form-select" name="category"><option value="">Category</option><% categories.forEach(function(category) { %><option value="<%= category %>" <%= filters.category === category ? 'selected' : '' %>><%= category %></option><% }) %></select></div>
        <div class="col-md-2"><select class="form-select" name="severity"><option value="">Severity</option><% severities.forEach(function(severity) { %><option value="<%= severity %>" <%= filters.severity === severity ? 'selected' : '' %>><%= severity %></option><% }) %></select></div>
        <div class="col-md-2"><select class="form-select" name="action"><option value="">Action</option><% actions.forEach(function(action) { %><option value="<%= action %>" <%= filters.action === action ? 'selected' : '' %>><%= action %></option><% }) %></select></div>
        <div class="col-md-2"><input class="form-control" type="date" name="date" value="<%= filters.date || '' %>"></div>
        <div class="col-md-1"><button class="btn btn-outline-primary w-100">Filter</button></div>
      </div>
    </form>
    <div class="card">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead><tr><th>Time</th><th>IP</th><th>Method</th><th>URL</th><th>Rule</th><th>Severity</th><th>Action</th><th>Risk</th><th></th></tr></thead>
          <tbody>
            <% logs.forEach(function(log) { %>
              <tr>
                <td><%= log.created_at.toLocaleString() %></td>
                <td><code><%= log.ip_address %></code></td>
                <td><%= log.method %></td>
                <td class="text-truncate" style="max-width:260px"><%= log.url %></td>
                <td><%= log.matched_rule_name || '-' %></td>
                <td><span class="badge <%= log.severity === 'critical' ? 'text-bg-danger' : log.severity === 'high' ? 'text-bg-warning' : 'text-bg-info' %>"><%= log.severity || '-' %></span></td>
                <td><span class="badge <%= log.action_taken === 'block' ? 'text-bg-danger' : log.action_taken === 'rate_limit' ? 'text-bg-warning' : 'text-bg-secondary' %>"><%= log.action_taken %></span></td>
                <td><span class="badge <%= log.risk_score >= 50 ? 'text-bg-danger' : 'text-bg-light' %>"><%= log.risk_score %></span></td>
                <td><a class="btn btn-sm btn-outline-primary" href="/admin/waf/logs/<%= log.id %>">View</a></td>
              </tr>
            <% }) %>
            <% if (!logs.length) { %><tr><td colspan="9" class="text-center text-muted py-4">No WAF logs found.</td></tr><% } %>
          </tbody>
        </table>
      </div>
      <div class="card-footer d-flex justify-content-between"><span>Page <%= meta.page %> of <%= meta.pages %></span><div class="btn-group"><a class="btn btn-sm btn-outline-secondary <%= meta.page <= 1 ? 'disabled' : '' %>" href="?page=<%= meta.page - 1 %>">Previous</a><a class="btn btn-sm btn-outline-secondary <%= meta.page >= meta.pages ? 'disabled' : '' %>" href="?page=<%= meta.page + 1 %>">Next</a></div></div>
    </div>
  </main>
</div>
<%- include('../../partials/footer') %>
