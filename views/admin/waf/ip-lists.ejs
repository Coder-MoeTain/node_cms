<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content">
    <%- include('../partials/flash') %>
    <div class="d-flex justify-content-between align-items-center mb-3"><div><h2 class="mb-1">WAF IP Lists</h2><p class="text-muted mb-0">Manage whitelist, blacklist, and temporary block entries.</p></div><a class="btn btn-outline-secondary" href="/admin/waf">Dashboard</a></div>
    <div class="row g-3">
      <div class="col-lg-4">
        <form class="card" method="post" action="/admin/waf/ip-lists">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="card-header">Add IP Entry</div>
          <div class="card-body">
            <label class="form-label">IP address</label>
            <input class="form-control mb-2" name="ip_address" required>
            <label class="form-label">List type</label>
            <select class="form-select mb-2" name="list_type"><% listTypes.forEach(function(type) { %><option value="<%= type %>"><%= type %></option><% }) %></select>
            <label class="form-label">Reason</label>
            <input class="form-control mb-2" name="reason">
            <label class="form-label">Expiry date for temporary blocks</label>
            <input class="form-control" type="datetime-local" name="expires_at">
          </div>
          <div class="card-footer"><button class="btn btn-primary w-100">Save IP Entry</button></div>
        </form>
      </div>
      <div class="col-lg-8">
        <form class="card card-body mb-3" method="get" action="/admin/waf/ip-lists">
          <div class="row g-2">
            <div class="col-md-6"><input class="form-control" name="ip" value="<%= filters.ip || '' %>" placeholder="Search IP"></div>
            <div class="col-md-4"><select class="form-select" name="type"><option value="">All types</option><% listTypes.forEach(function(type) { %><option value="<%= type %>" <%= filters.type === type ? 'selected' : '' %>><%= type %></option><% }) %></select></div>
            <div class="col-md-2"><button class="btn btn-outline-primary w-100">Filter</button></div>
          </div>
        </form>
        <div class="card">
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead><tr><th>IP</th><th>Type</th><th>Reason</th><th>Expires</th><th>Status</th><th></th></tr></thead>
              <tbody>
                <% ipLists.forEach(function(row) { %>
                  <tr>
                    <td><code><%= row.ip_address %></code></td>
                    <td><span class="badge <%= row.list_type === 'whitelist' ? 'text-bg-success' : row.list_type === 'blacklist' ? 'text-bg-danger' : 'text-bg-warning' %>"><%= row.list_type %></span></td>
                    <td><%= row.reason || '-' %></td>
                    <td><%= row.expires_at ? row.expires_at.toLocaleString() : '-' %></td>
                    <td><span class="badge <%= row.status ? 'text-bg-success' : 'text-bg-secondary' %>"><%= row.status ? 'active' : 'inactive' %></span></td>
                    <td class="text-end"><form method="post" action="/admin/waf/ip-lists/<%= row.id %>/delete" onsubmit="return confirm('Remove this IP entry?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-sm btn-outline-danger">Remove</button></form></td>
                  </tr>
                <% }) %>
                <% if (!ipLists.length) { %><tr><td colspan="6" class="text-center text-muted py-4">No IP list entries found.</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
