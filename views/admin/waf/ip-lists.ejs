<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header">
      <div><h1>WAF IP Lists</h1><p class="np-help-text mb-0">Whitelist trusted clients, block attackers, or apply temporary blocks. IPv4 CIDR notation is supported (e.g. <code>203.0.113.0/24</code>).</p></div>
      <a class="np-btn np-btn-secondary" href="/admin/waf">Dashboard</a>
    </div>

    <%- include('../partials/waf-nav', { activeNav: typeof activeNav !== 'undefined' ? activeNav : 'ip-lists' }) %>

    <div class="row g-3">
      <div class="col-lg-4">
        <form class="np-widget" method="post" action="/admin/waf/ip-lists">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="np-widget-header"><span>Add IP entry</span></div>
          <div class="np-widget-body">
            <label class="form-label">IP address or CIDR</label>
            <input class="form-control mb-2 font-monospace" name="ip_address" placeholder="203.0.113.10 or 10.0.0.0/8" required>
            <label class="form-label">List type</label>
            <select class="form-select mb-2" name="list_type"><% listTypes.forEach(function(type) { %><option value="<%= type %>"><%= type %></option><% }) %></select>
            <label class="form-label">Reason</label>
            <input class="form-control mb-2" name="reason" placeholder="Optional note for auditors">
            <label class="form-label">Expiry (temporary blocks)</label>
            <input class="form-control" type="datetime-local" name="expires_at">
          </div>
          <div class="np-widget-footer px-3 py-2 border-top"><button class="np-btn np-btn-primary w-100" type="submit">Save entry</button></div>
        </form>
      </div>
      <div class="col-lg-8">
        <form class="np-widget mb-3" method="get" action="/admin/waf/ip-lists">
          <div class="np-widget-body">
            <div class="row g-2">
              <div class="col-md-6"><input class="form-control" name="ip" value="<%= filters.ip || '' %>" placeholder="Search IP or CIDR"></div>
              <div class="col-md-4"><select class="form-select" name="type"><option value="">All types</option><% listTypes.forEach(function(type) { %><option value="<%= type %>" <%= filters.type === type ? 'selected' : '' %>><%= type %></option><% }) %></select></div>
              <div class="col-md-2"><button class="np-btn np-btn-secondary w-100">Filter</button></div>
            </div>
          </div>
        </form>
        <div class="np-widget">
          <div class="np-widget-body p-0">
            <div class="table-responsive">
              <table class="np-list-table mb-0">
                <thead><tr><th>IP / CIDR</th><th>Type</th><th>Reason</th><th>Expires</th><th>Status</th><th></th></tr></thead>
                <tbody>
                  <% ipLists.forEach(function(row) { %>
                    <tr>
                      <td><code><%= row.ip_address %></code></td>
                      <td><span class="np-badge np-badge-<%= row.list_type === 'whitelist' ? 'success' : row.list_type === 'blacklist' ? 'danger' : 'warning' %>"><%= row.list_type %></span></td>
                      <td><%= row.reason || '-' %></td>
                      <td><%= row.expires_at ? formatDateTime(row.expires_at) : '-' %></td>
                      <td><span class="np-badge np-badge-<%= row.status ? 'success' : 'muted' %>"><%= row.status ? 'active' : 'inactive' %></span></td>
                      <td class="text-end">
                        <form method="post" action="/admin/waf/ip-lists/<%= row.id %>/delete" onsubmit="return confirm('Remove this IP entry?')">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="np-btn np-btn-small np-btn-danger">Remove</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                  <% if (!ipLists.length) { %><tr><td colspan="6" class="text-center text-muted py-4">No IP list entries found.</td></tr><% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
