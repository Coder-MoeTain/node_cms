<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header">
      <h1>Database Backup &amp; Restore</h1>
      <p class="np-help-text">Create backups, restore from a previous snapshot, or reset the database to factory defaults.</p>
    </div>
    <%- include('../partials/settings-nav') %>

    <div class="np-widget mb-3">
      <div class="np-widget-header"><span>Connection</span></div>
      <div class="np-widget-body">
        <dl class="row mb-0">
          <dt class="col-sm-3">Database</dt>
          <dd class="col-sm-9"><code><%= dbConfig.database %></code></dd>
          <dt class="col-sm-3">Host</dt>
          <dd class="col-sm-9"><code><%= dbConfig.host %>:<%= dbConfig.port %></code></dd>
          <dt class="col-sm-3">User</dt>
          <dd class="col-sm-9"><code><%= dbConfig.user %></code></dd>
          <dt class="col-sm-3">Backup folder</dt>
          <dd class="col-sm-9"><code>database/backups</code></dd>
        </dl>
      </div>
    </div>

    <div class="np-widget mb-3">
      <div class="np-widget-header"><span>Create Backup</span></div>
      <div class="np-widget-body d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <p class="mb-1"><strong>Export a MySQL dump</strong></p>
          <p class="np-help-text mb-0">Requires <code>mysqldump</code> in PATH. Files are stored in <code>database/backups</code>.</p>
        </div>
        <form method="post" action="/admin/settings/database/backup" class="d-flex flex-wrap align-items-center gap-3">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label class="form-check mb-0">
            <input class="form-check-input" type="checkbox" name="include_uploads" checked>
            Include uploads archive
          </label>
          <button class="np-btn np-btn-primary" type="submit"><i class="bi bi-database-down"></i> Create Backup</button>
        </form>
      </div>
    </div>

    <div class="np-widget mb-3">
      <div class="np-widget-header"><span>Restore from SQL File</span></div>
      <div class="np-widget-body">
        <p class="np-help-text">Upload a <code>.sql</code> dump to restore the database. This overwrites all current data in <code><%= dbConfig.database %></code>. Requires <code>mysql</code> in PATH.</p>
        <form method="post" action="/admin/settings/database/restore-upload?_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data" class="d-flex flex-wrap align-items-end gap-3 mt-3" data-confirm="Restore database from the uploaded SQL file? All current data will be overwritten.">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="flex-grow-1" style="min-width: 220px;">
            <label class="form-label mb-1" for="sql_file">SQL file</label>
            <input class="form-control" type="file" id="sql_file" name="sql_file" accept=".sql,application/sql,text/plain" required>
          </div>
          <button class="np-btn np-btn-primary" type="submit"><i class="bi bi-upload"></i> Upload &amp; Restore</button>
        </form>
      </div>
    </div>

    <div class="np-widget mb-3">
      <div class="np-widget-header d-flex justify-content-between align-items-center">
        <span>Backup Files</span>
        <span class="np-badge np-badge-secondary"><%= backups.length %> file<%= backups.length === 1 ? '' : 's' %></span>
      </div>
      <div class="np-widget-body p-0">
        <% if (backups.length) { %>
          <table class="np-list-table mb-0">
            <thead>
              <tr>
                <th>File</th>
                <th>Size</th>
                <th>Created</th>
                <th>Uploads</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% backups.forEach(function(backup) { %>
                <tr>
                  <td><code><%= backup.file %></code></td>
                  <td><%= backup.sizeLabel %></td>
                  <td><%= formatDateTime(backup.created) %></td>
                  <td>
                    <% if (backup.uploadsArchive) { %>
                      <span class="np-badge np-badge-success">Yes</span>
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td class="text-end">
                    <div class="d-inline-flex flex-wrap gap-2 justify-content-end">
                      <form method="post" action="/admin/settings/database/restore/<%= encodeURIComponent(backup.file) %>" data-confirm="Restore database from <%= backup.file %>? This will overwrite all current data.">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <% if (backup.uploadsArchive) { %>
                          <input type="hidden" name="include_uploads" value="on">
                        <% } %>
                        <button class="np-btn np-btn-small np-btn-primary" type="submit"><i class="bi bi-arrow-counterclockwise"></i> Restore</button>
                      </form>
                      <form method="post" action="/admin/settings/database/backup/<%= encodeURIComponent(backup.file) %>?_method=DELETE" data-confirm="Delete backup <%= backup.file %>?">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="np-btn np-btn-small np-btn-danger" type="submit"><i class="bi bi-trash"></i> Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p class="text-muted mb-0 p-3">No backup files yet. Create your first backup above.</p>
        <% } %>
      </div>
    </div>

    <div class="np-widget">
      <div class="np-widget-header"><span>Reset Database</span></div>
      <div class="np-widget-body d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <p class="mb-1"><strong class="text-danger">Danger zone</strong></p>
          <p class="np-help-text mb-0">Drop all tables, recreate the schema, and seed default data. This cannot be undone unless you have a backup.</p>
        </div>
        <form method="post" action="/admin/settings/database/reset" data-confirm="Reset the entire database to factory defaults? All content, users, and settings will be erased.">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="np-btn np-btn-danger" type="submit"><i class="bi bi-exclamation-triangle"></i> Reset Database</button>
        </form>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
