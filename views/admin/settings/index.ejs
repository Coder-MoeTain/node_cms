<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content">
    <%- include('../partials/flash') %>
    <form class="card" method="post" action="/admin/settings?_method=PUT">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="card-body row g-3">
        <% rows.forEach(function(row) { %>
          <div class="col-md-6">
            <label class="form-label text-capitalize"><%= row.key.replace(/_/g, ' ') %></label>
            <% if (['site_logo','favicon'].includes(row.key)) { %>
              <div class="input-group">
                <input class="form-control media-preview-input" data-media-picker-field name="<%= row.key %>" value="<%= row.value %>" placeholder="<%= row.key === 'site_logo' ? '/uploads/2026-06/logo.png' : '/uploads/2026-06/favicon.png' %>">
                <button class="btn btn-outline-primary" type="button" data-open-media-gallery data-target-field="<%= row.key %>"><i class="bi bi-images"></i> Choose</button>
              </div>
              <div class="form-text">Choose from Media Gallery or paste an external image URL.</div>
              <div class="settings-preview-wrap mt-2">
                <% if (row.value) { %><img class="settings-image-preview" data-media-preview="<%= row.key %>" src="<%= row.value %>" alt="<%= row.key %> preview"><% } else { %><div class="settings-empty-preview" data-media-preview="<%= row.key %>">No image selected</div><% } %>
              </div>
              <a class="small d-inline-block mt-2" href="/admin/media" target="_blank">Upload new media</a>
            <% } else { %>
              <input class="form-control" name="<%= row.key %>" value="<%= row.value %>">
            <% } %>
          </div>
        <% }) %>
      </div>
      <div class="card-footer"><button class="btn btn-primary">Save Settings</button></div>
    </form>
  </main>
</div>

<div class="modal fade" id="mediaGalleryModal" tabindex="-1" aria-labelledby="mediaGalleryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content media-gallery-modal">
      <div class="modal-header">
        <div>
          <h5 class="modal-title" id="mediaGalleryModalLabel">Media Gallery</h5>
          <small class="text-muted">Select an image for the current setting.</small>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="media-gallery-toolbar">
          <span class="text-muted">Images from your Media Library</span>
          <a class="btn btn-sm btn-outline-primary" href="/admin/media" target="_blank"><i class="bi bi-upload"></i> Upload Media</a>
        </div>
        <div class="media-gallery-grid" data-media-gallery-grid>
          <div class="media-gallery-loading">Loading media...</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
