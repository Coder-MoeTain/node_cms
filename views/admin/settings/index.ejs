<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header"><h1>Site Settings</h1><p class="np-help-text">Configure portal identity, contact details, emergency numbers, statistics, and branding.</p></div>
    <%- include('../partials/settings-nav') %>
    <form method="post" action="/admin/settings?_method=PUT&_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% const order = groupOrder || []; const labels = groupLabels || {}; const defs = settingDefinitions || {}; %>
      <% order.forEach(function(groupKey) { %>
        <% const groupRows = (grouped && grouped[groupKey]) || []; if (!groupRows.length) return; %>
        <div class="np-widget mb-3">
          <div class="np-widget-header"><span><%= labels[groupKey] || groupKey %></span></div>
          <div class="np-widget-body p-0">
            <table class="np-form-table np-settings-table">
              <tbody>
                <% groupRows.forEach(function(row) { %>
                  <% const def = defs[row.key] || {}; const label = def.label || row.key.replace(/_/g, ' ').replace(/\b\w/g, function(c){ return c.toUpperCase(); }); %>
                  <tr>
                    <th scope="row"><label for="setting-<%= row.key %>"><%= label %></label></th>
                    <td>
                      <% if (['site_logo','favicon'].includes(row.key)) { %>
                        <%- include('../partials/image-upload-field', { label: label, name: row.key, fileName: row.key + '_file', value: row.value }) %>
                        <p class="np-help-text">Upload an image or choose one from the Media Library.</p>
                      <% } else if (row.key === 'contact_email') { %>
                        <input class="form-control" id="setting-<%= row.key %>" name="<%= row.key %>" type="email" value="<%= row.value %>">
                      <% } else if (row.key.includes('link') || row.key.includes('url')) { %>
                        <input class="form-control" id="setting-<%= row.key %>" name="<%= row.key %>" type="text" value="<%= row.value %>" placeholder="https://example.com or /page/path" inputmode="url" autocomplete="url">
                        <p class="np-help-text mb-0">Full URL, site path, or leave blank.</p>
                      <% } else if (row.key === 'contact_phone' || row.key.startsWith('emergency_')) { %>
                        <input class="form-control" id="setting-<%= row.key %>" name="<%= row.key %>" type="tel" value="<%= row.value %>">
                      <% } else if (row.key === 'show_utility_bar') { %>
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" id="setting-<%= row.key %>" name="<%= row.key %>" value="true" <%= row.value === 'true' ? 'checked' : '' %>>
                          <label class="form-check-label" for="setting-<%= row.key %>">Show font controls, language switcher, and login links above the main header on standard (non-portal) themes.</label>
                        </div>
                      <% } else if (row.key === 'posts_per_page' || row.key === 'revision_limit' || row.key === 'comment_max_depth' || row.key.startsWith('stat_') || row.key === 'portal_visit_count') { %>
                        <input class="form-control" id="setting-<%= row.key %>" name="<%= row.key %>" type="number" min="<%= row.key === 'comment_max_depth' ? '1' : '0' %>" value="<%= row.value %>" <%= row.key.startsWith('stat_') ? 'readonly' : '' %>>
                        <% if (row.key === 'revision_limit') { %><p class="np-help-text mb-0">Older revisions are pruned automatically beyond this limit.</p><% } %>
                        <% if (row.key === 'comment_max_depth') { %><p class="np-help-text mb-0">Maximum nesting level for public comment replies.</p><% } %>
                        <% if (row.key.startsWith('stat_')) { %><p class="np-help-text mb-0">Updated automatically from site activity.</p><% } %>
                      <% } else if (row.key === 'permalink_structure' || row.key === 'page_permalink_structure') { %>
                        <input class="form-control" id="setting-<%= row.key %>" name="<%= row.key %>" value="<%= row.value %>" data-permalink-setting>
                        <div class="d-flex flex-wrap gap-1 mt-2">
                          <% ['%year%', '%month%', '%day%', '%slug%', '%post_id%'].forEach(function(token) { %>
                            <button type="button" class="np-btn np-btn-small np-btn-secondary" data-permalink-token="<%= token %>" data-target="setting-<%= row.key %>"><%= token %></button>
                          <% }) %>
                        </div>
                        <p class="np-help-text mb-0">Use tokens to build custom URL structures. Default: /post/%slug% and /page/%slug%</p>
                      <% } else if (row.key === 'site_timezone') { %>
                        <select class="form-select" id="setting-<%= row.key %>" name="<%= row.key %>">
                          <% (timezoneOptions || []).forEach(function(opt) { %>
                            <option value="<%= opt.value %>" <%= row.value === opt.value ? 'selected' : '' %>><%= opt.label %></option>
                          <% }) %>
                        </select>
                        <p class="np-help-text mb-0">Dates and times across the site are displayed in this timezone.</p>
                      <% } else { %>
                        <input class="form-control" id="setting-<%= row.key %>" name="<%= row.key %>" value="<%= row.value %>">
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% }) %>
      <p class="mt-3"><button class="np-btn np-btn-primary" type="submit" data-loading-label="Saving…">Save Changes</button></p>
    </form>
    <script>
      document.querySelectorAll('[data-permalink-token]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = document.getElementById(btn.dataset.target);
          if (!target) return;
          const token = btn.dataset.permalinkToken;
          const base = target.value.replace(/\/$/, '');
          target.value = `${base}/${token}`.replace(/\/+/g, '/');
        });
      });
    </script>
  </main>
</div>
<%- include('../partials/media-modal') %>
<%- include('../partials/footer') %>
