<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header d-flex flex-wrap justify-content-between align-items-start gap-2">
      <div>
        <h1><%= plugin.name %></h1>
        <p class="text-muted mb-0"><code><%= plugin.slug %></code> · v<%= plugin.version %></p>
      </div>
      <div class="d-flex flex-wrap gap-2">
        <a class="np-btn np-btn-secondary" href="/admin/plugins">Back to Plugins</a>
        <a class="np-btn np-btn-secondary" href="/admin/plugins/<%= plugin.slug %>/settings">Settings</a>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-lg-8">
        <div class="np-widget mb-3">
          <div class="np-widget-header"><span>Plugin Details</span></div>
          <div class="np-widget-body">
            <p><%= plugin.description || 'No description provided.' %></p>
            <dl class="row mb-0">
              <dt class="col-sm-3">Author</dt>
              <dd class="col-sm-9"><%= plugin.author || 'Unknown' %></dd>
              <dt class="col-sm-3">Status</dt>
              <dd class="col-sm-9"><span class="np-badge np-badge-<%= isActive ? 'success' : 'muted' %>"><%= isActive ? 'Active' : 'Inactive' %></span></dd>
              <dt class="col-sm-3">Entry file</dt>
              <dd class="col-sm-9"><code><%= (diskManifest && diskManifest.main) || 'index.js' %></code></dd>
              <% if (diskManifest && diskManifest.permissions) { %>
                <dt class="col-sm-3">Permissions</dt>
                <dd class="col-sm-9"><%= diskManifest.permissions.join(', ') %></dd>
              <% } %>
            </dl>
            <% if (activationError) { %>
              <div class="alert alert-warning mt-3 mb-0"><strong>Activation error:</strong> <%= activationError %></div>
            <% } %>
          </div>
        </div>

        <div class="np-widget mb-3">
          <div class="np-widget-header"><span>Registered Hooks</span></div>
          <div class="np-widget-body">
            <% if (manifestHooks.length) { %>
              <p class="text-muted">Declared in manifest:</p>
              <ul><% manifestHooks.forEach(function(hook) { %><li><code><%= hook %></code></li><% }) %></ul>
            <% } %>
            <p class="text-muted mb-2">Currently registered in runtime:</p>
            <% if (registeredHooks.length) { %>
              <div class="d-flex flex-wrap gap-2">
                <% registeredHooks.forEach(function(hook) { %>
                  <span class="badge bg-light text-dark border"><%= hook %></span>
                <% }) %>
              </div>
            <% } else { %>
              <p class="mb-0 text-muted">No hooks registered. Activate the plugin to load hooks.</p>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="np-widget mb-3">
          <div class="np-widget-header"><span>Actions</span></div>
          <div class="np-widget-body d-flex flex-column gap-2">
            <% if (isActive) { %>
              <form method="post" action="/admin/plugins/<%= plugin.slug %>/deactivate">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="np-btn np-btn-secondary w-100" type="submit">Deactivate</button>
              </form>
            <% } else { %>
              <form method="post" action="/admin/plugins/<%= plugin.slug %>/activate">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="np-btn np-btn-primary w-100" type="submit">Activate</button>
              </form>
              <form method="post" action="/admin/plugins/<%= plugin.slug %>/uninstall" data-confirm="Remove this plugin from disk?">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="np-btn np-btn-danger w-100" type="submit">Delete Plugin</button>
              </form>
            <% } %>
            <% if (pendingMigrations.length) { %>
              <form method="post" action="/admin/plugins/<%= plugin.slug %>/migrate">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="np-btn np-btn-secondary w-100" type="submit">Run <%= pendingMigrations.length %> pending migration(s)</button>
              </form>
            <% } %>
          </div>
        </div>

        <div class="np-widget">
          <div class="np-widget-header"><span>Migrations</span></div>
          <div class="np-widget-body">
            <% const applied = (plugin.migrations || []).map(function(row) { return row.migration; }); %>
            <% if (applied.length || pendingMigrations.length) { %>
              <ul class="list-unstyled mb-0 small">
                <% applied.forEach(function(file) { %>
                  <li class="text-success"><i class="bi bi-check-circle"></i> <%= file %></li>
                <% }) %>
                <% pendingMigrations.forEach(function(file) { %>
                  <li class="text-muted"><i class="bi bi-circle"></i> <%= file %> (pending)</li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="text-muted mb-0">No migrations for this plugin.</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
