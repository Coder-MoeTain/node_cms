<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header">
      <h1><%= plugin.name %> Settings</h1>
      <a class="np-btn np-btn-secondary" href="/admin/plugins">Back to Plugins</a>
    </div>

    <form method="post" action="/admin/plugins/<%= plugin.slug %>/settings?_method=PUT">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="np-widget">
        <div class="np-widget-header"><span>Configuration</span></div>
        <div class="np-widget-body">
          <% if (plugin.description) { %><p class="np-help-text mb-3"><%= plugin.description %></p><% } %>
          <table class="np-form-table np-settings-table">
            <tbody>
              <% let currentSection = null;
                 fields.forEach(function(field) {
                   if (field.section && field.section !== currentSection) {
                     currentSection = field.section;
              %>
                <tr class="np-settings-section-row">
                  <th colspan="2" scope="colgroup" class="pt-4 pb-2"><%= currentSection %></th>
                </tr>
              <%   } %>
                <tr>
                  <th scope="row"><label for="setting-<%= field.key %>"><%= field.label || field.key %></label></th>
                  <td>
                    <% if (field.type === 'textarea') { %>
                      <textarea class="form-control" id="setting-<%= field.key %>" name="<%= field.key %>" rows="<%= field.rows || 4 %>" placeholder="<%= field.placeholder || '' %>"><%= settingsMap[field.key] || '' %></textarea>
                    <% } else if (field.type === 'select') { %>
                      <select class="form-select" id="setting-<%= field.key %>" name="<%= field.key %>">
                        <% (field.options || []).forEach(function(option) {
                             const value = typeof option === 'string' ? option : option.value;
                             const label = typeof option === 'string' ? option : option.label;
                        %>
                          <option value="<%= value %>" <%= String(settingsMap[field.key] || '') === String(value) ? 'selected' : '' %>><%= label %></option>
                        <% }) %>
                      </select>
                    <% } else if (field.type === 'checkbox') { %>
                      <label class="form-check">
                        <input class="form-check-input" id="setting-<%= field.key %>" name="<%= field.key %>" type="checkbox" value="on" <%= settingsMap[field.key] === 'on' || settingsMap[field.key] === 'true' ? 'checked' : '' %>>
                        <%= field.description || field.label %>
                      </label>
                    <% } else { %>
                      <input class="form-control" id="setting-<%= field.key %>" name="<%= field.key %>" type="<%= field.type || 'text' %>" value="<%= settingsMap[field.key] || '' %>" placeholder="<%= field.placeholder || '' %>"<%= field.min !== undefined ? ' min="' + field.min + '"' : '' %><%= field.max !== undefined ? ' max="' + field.max + '"' : '' %>>
                    <% } %>
                    <% if (field.description && field.type !== 'checkbox') { %><p class="np-help-text mb-0"><%= field.description %></p><% } %>
                    <% if (field.default !== undefined) { %><p class="np-help-text mb-0"><small>Default: <code><%= field.default %></code></small></p><% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-3"><button class="np-btn np-btn-primary" type="submit">Save Settings</button></p>
    </form>
  </main>
</div>
<%- include('../partials/footer') %>
