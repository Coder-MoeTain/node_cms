<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header">
      <div>
        <h1>Plugins</h1>
        <p class="text-muted mb-0">Extend your site with installable modules for SEO, analytics, security, caching, and more.</p>
      </div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-md-3"><div class="np-widget h-100"><div class="np-widget-body text-center"><div class="display-6"><%= stats.total %></div><div class="text-muted">Installed</div></div></div></div>
      <div class="col-md-3"><div class="np-widget h-100"><div class="np-widget-body text-center"><div class="display-6 text-success"><%= stats.active %></div><div class="text-muted">Active</div></div></div></div>
      <div class="col-md-3"><div class="np-widget h-100"><div class="np-widget-body text-center"><div class="display-6"><%= stats.inactive %></div><div class="text-muted">Inactive</div></div></div></div>
      <div class="col-md-3"><div class="np-widget h-100"><div class="np-widget-body text-center"><div class="display-6"><%= stats.hooks %></div><div class="text-muted">Registered hooks</div></div></div></div>
    </div>

    <div class="np-widget mb-3">
      <div class="np-widget-header"><span>Install Plugin</span></div>
      <div class="np-widget-body">
        <form method="post" action="/admin/plugins/upload?_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data" class="row g-2 align-items-end">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="col-md-8">
            <label class="form-label" for="plugin-archive">Upload plugin (.zip)</label>
            <input class="form-control" id="plugin-archive" type="file" name="archive" accept=".zip" required>
            <div class="form-text">Archive must contain <code>plugin.json</code> at the root or in a single folder.</div>
          </div>
          <div class="col-md-4">
            <button class="np-btn np-btn-primary w-100" type="submit"><i class="bi bi-upload"></i> Install Plugin</button>
          </div>
        </form>
      </div>
    </div>

    <div class="np-widget mb-3">
      <div class="np-widget-body row g-2 align-items-end">
        <div class="col-md-6">
          <label class="form-label" for="plugin-search">Search plugins</label>
          <input class="form-control" id="plugin-search" type="search" placeholder="Filter by name, slug, or author" data-plugin-filter>
        </div>
        <div class="col-md-3">
          <label class="form-label" for="plugin-status-filter">Status</label>
          <select class="form-select" id="plugin-status-filter" data-plugin-status>
            <option value="all">All</option>
            <option value="active">Active only</option>
            <option value="inactive">Inactive only</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Runtime hooks</label>
          <div class="form-text"><%= (registeredHooks || []).slice(0, 4).join(', ') %><% if ((registeredHooks || []).length > 4) { %> +<%= registeredHooks.length - 4 %> more<% } %></div>
        </div>
      </div>
    </div>

    <div class="row g-3" id="plugin-grid">
      <% plugins.forEach(function(plugin) { %>
        <div class="col-md-6 col-xl-4" data-plugin-card data-name="<%= (plugin.name + ' ' + plugin.slug + ' ' + (plugin.author || '')).toLowerCase() %>" data-status="<%= plugin.active ? 'active' : 'inactive' %>">
          <div class="np-widget h-100">
            <div class="np-widget-header">
              <span><%= plugin.name %></span>
              <span class="np-badge np-badge-<%= plugin.active ? 'success' : 'muted' %>"><%= plugin.active ? 'Active' : 'Inactive' %></span>
            </div>
            <div class="np-widget-body">
              <p class="text-muted mb-2"><%= plugin.description || 'No description provided.' %></p>
              <small class="text-muted d-block">v<%= plugin.version %> · <%= plugin.author || 'Unknown' %></small>
              <small class="text-muted d-block"><code><%= plugin.slug %></code></small>
              <% if (activationErrors && activationErrors[plugin.slug]) { %>
                <div class="alert alert-warning py-2 px-3 mt-2 mb-0 small"><%= activationErrors[plugin.slug] %></div>
              <% } %>
            </div>
            <div class="np-widget-footer d-flex flex-wrap gap-2 p-3 border-top">
              <% if (plugin.active) { %>
                <form method="post" action="/admin/plugins/<%= plugin.slug %>/deactivate">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="np-btn np-btn-small np-btn-secondary" type="submit">Deactivate</button>
                </form>
              <% } else { %>
                <form method="post" action="/admin/plugins/<%= plugin.slug %>/activate">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="np-btn np-btn-small np-btn-primary" type="submit">Activate</button>
                </form>
                <form method="post" action="/admin/plugins/<%= plugin.slug %>/uninstall" data-confirm="Remove this plugin from disk?">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="np-btn np-btn-small np-btn-danger" type="submit">Delete</button>
                </form>
              <% } %>
              <a class="np-btn np-btn-small np-btn-secondary" href="/admin/plugins/<%= plugin.slug %>/settings">Settings</a>
            </div>
          </div>
        </div>
      <% }) %>
      <% if (!plugins.length) { %>
        <div class="col-12"><div class="empty-state"><i class="bi bi-plug d-block"></i><strong>No plugins installed</strong><p class="mb-0">Upload a plugin zip or add one under <code>plugins/</code>.</p></div></div>
      <% } %>
    </div>
  </main>
</div>
<script>
  (function () {
    const search = document.querySelector('[data-plugin-filter]');
    const status = document.querySelector('[data-plugin-status]');
    const cards = [...document.querySelectorAll('[data-plugin-card]')];
    function applyFilter() {
      const q = (search?.value || '').trim().toLowerCase();
      const st = status?.value || 'all';
      cards.forEach((card) => {
        const matchesText = !q || card.dataset.name.includes(q);
        const matchesStatus = st === 'all' || card.dataset.status === st;
        card.classList.toggle('d-none', !(matchesText && matchesStatus));
      });
    }
    search?.addEventListener('input', applyFilter);
    status?.addEventListener('change', applyFilter);
  }());
</script>
<%- include('../partials/footer') %>
