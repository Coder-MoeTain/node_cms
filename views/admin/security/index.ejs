<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="admin-main">
  <%- include('../partials/topbar') %>
  <main class="admin-content" id="np-main-content">
    <%- include('../partials/flash') %>
    <div class="np-page-header">
      <h1>Security &amp; Backup</h1>
    </div>
    <%- include('../partials/settings-nav') %>

    <div class="np-widget mb-3">
      <div class="np-widget-header"><span>Database</span></div>
      <div class="np-widget-body d-flex flex-wrap justify-content-between align-items-center gap-3">
        <p class="np-help-text mb-0">Create backups, restore snapshots, or reset the database from <strong>Settings → Database</strong>.</p>
        <a class="np-btn np-btn-secondary" href="/admin/settings/database"><i class="bi bi-database"></i> Open Database Tools</a>
      </div>
    </div>

    <form method="post" action="/admin/security/settings?_method=PUT">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="np-widget">
        <div class="np-widget-header"><span>Security Plugin Features</span></div>
        <div class="np-widget-body p-0">
          <table class="np-form-table np-settings-table">
            <tbody>
              <% const bruteForceNumeric = ['login_max_account_attempts', 'login_lockout_minutes', 'login_max_ip_attempts', 'login_ip_window_minutes', 'login_auto_block_ip_attempts']; %>
              <% const securityFeatureLabels = {
                enable_login_attempt_logging: 'Log all login attempts',
                enable_ip_blocking: 'Block IPs after repeated failures',
                enable_activity_logging: 'Record admin activity in audit log',
                enable_csrf_protection: 'Require CSRF tokens on forms',
                enable_rate_limiting: 'Rate-limit sensitive endpoints',
                enable_upload_validation: 'Validate file uploads (type & size)',
                enable_security_headers: 'Send security headers (Helmet)',
                enable_waf: 'Web Application Firewall (WAF)'
              }; %>
              <% settings.filter(function(setting) { return !bruteForceNumeric.includes(setting.key); }).forEach(function(setting) { %>
                <tr>
                  <th scope="row"><%= securityFeatureLabels[setting.key] || setting.key.replace(/_/g, ' ').replace(/\b\w/g, function(c){ return c.toUpperCase(); }) %></th>
                  <td>
                    <label class="form-check">
                      <input class="form-check-input" type="checkbox" name="<%= setting.key %>" <%= setting.enabled ? 'checked' : '' %>>
                      Enable
                    </label>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="np-widget mt-3">
        <div class="np-widget-header"><span>Login Brute-Force Protection</span></div>
        <div class="np-widget-body p-0">
          <table class="np-form-table np-settings-table">
            <tbody>
              <% const bruteLabels = {
                login_max_account_attempts: 'Max failed attempts per account',
                login_lockout_minutes: 'Account lockout duration (minutes)',
                login_max_ip_attempts: 'Max failed attempts per IP (window)',
                login_ip_window_minutes: 'IP tracking window (minutes)',
                login_auto_block_ip_attempts: 'Auto-block IP after failures'
              }; %>
              <% settings.filter(function(setting) { return bruteForceNumeric.includes(setting.key); }).forEach(function(setting) { %>
                <tr>
                  <th scope="row"><%= bruteLabels[setting.key] || setting.key %></th>
                  <td>
                    <input class="form-control" type="number" min="1" name="<%= setting.key %>" value="<%= setting.value %>" required>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <p class="np-help-text px-3 pb-3 mb-0">Failed logins are rate-limited per IP, accounts lock after repeated failures, and abusive IPs can be auto-blocked.</p>
        </div>
      </div>
      <p class="mt-3"><button class="np-btn np-btn-primary" type="submit">Save Security Settings</button></p>
    </form>

    <div class="row g-3">
      <div class="col-lg-6">
        <div class="np-widget">
          <div class="np-widget-header"><span>Failed Login Attempts</span></div>
          <div class="np-widget-body p-0">
            <table class="np-list-table mb-0">
              <tbody>
                <% attempts.forEach(function(attempt) { %>
                  <tr>
                    <td><%= attempt.email || '—' %></td>
                    <td><code><%= attempt.ip_address %></code></td>
                    <td><span class="np-badge np-badge-<%= attempt.success ? 'success' : 'danger' %>"><%= attempt.success ? 'success' : 'failed' %></span></td>
                  </tr>
                <% }) %>
                <% if (!attempts.length) { %><tr><td colspan="3" class="text-muted">No login attempts logged.</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="np-widget">
          <div class="np-widget-header"><span>Blocked IPs</span></div>
          <div class="np-widget-body">
            <form class="row g-2" method="post" action="/admin/security/block-ip">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="col"><input class="form-control" name="ip_address" placeholder="IP address" required></div>
              <div class="col"><input class="form-control" name="reason" placeholder="Reason"></div>
              <div class="col-auto"><button class="np-btn np-btn-danger" type="submit">Block</button></div>
            </form>
          </div>
          <ul class="list-group list-group-flush">
            <% blockedIps.forEach(function(ip) { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><code><%= ip.ip_address %></code> <small class="text-muted"><%= ip.reason || '' %></small></span>
                <form method="post" action="/admin/security/unblock-ip/<%= ip.id %>?_method=DELETE" data-confirm="Unblock this IP address?">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="np-btn np-btn-small np-btn-secondary" type="submit">Unblock</button>
                </form>
              </li>
            <% }) %>
            <% if (!blockedIps.length) { %><li class="list-group-item text-muted">No blocked IPs.</li><% } %>
          </ul>
        </div>
      </div>
    </div>

    <div class="np-widget mt-3">
      <div class="np-widget-header"><span>Admin Activity Log</span></div>
      <div class="np-widget-body p-0">
        <table class="np-list-table mb-0">
          <tbody>
            <% activityLogs.forEach(function(log) { %>
              <tr><td><%= log.action %></td><td><%= log.entity_type || '' %></td><td><code><%= log.ip_address || '' %></code></td></tr>
            <% }) %>
            <% if (!activityLogs.length) { %><tr><td colspan="3" class="text-muted">No activity logged.</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
