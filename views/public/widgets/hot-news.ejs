<% const list = posts || []; const cardStyle = (portalConfig.widgets && portalConfig.widgets.cardStyle) || 'bordered'; %>
<section class="portal-widget site-widget portal-widget-hot portal-hot-accent portal-card-<%= cardStyle %>" id="portal-hot" aria-label="Hot news">
  <%- include('../partials/widget-header', { title: '<span class="portal-hot-label">HOT NEWS</span>', viewAllUrl: '/blog', headerClass: 'portal-hot-header' }) %>
  <div class="portal-widget-body">
    <% if (list.length) { %>
      <ul class="portal-post-list portal-hot-list">
        <% list.slice(0, 8).forEach(function(post, index) { %>
          <li class="portal-hot-list-item">
            <% const dateStr = post.published_at ? formatDate(post.published_at) : ''; %>
            <% const dateIso = post.published_at ? post.published_at.toISOString().slice(0, 10) : ''; %>
            <% if (dateStr) { %><time class="portal-hot-date" datetime="<%= dateIso %>"><%= dateStr %></time><% } %>
            <%- include('../partials/portal-post-item', { post, hot: index < 3, showReadMore: true }) %>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <%- include('../partials/portal-empty', { icon: 'fire', message: 'No highlighted posts yet.' }) %>
    <% } %>
  </div>
</section>
