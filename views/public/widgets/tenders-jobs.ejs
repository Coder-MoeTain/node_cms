<% const tenders = tenderPosts || []; const jobs = jobPosts || []; const cardStyle = (portalConfig.widgets && portalConfig.widgets.cardStyle) || 'bordered'; %>
<section class="portal-section portal-tenders-jobs site-section" id="portal-tenders" aria-label="Tenders and jobs">
  <div class="container py-4">
    <div class="row g-4">
      <div class="col-lg-6">
        <section class="portal-widget site-widget portal-card-<%= cardStyle %>">
          <%- include('../partials/widget-header', { title: 'Tenders', viewAllUrl: '/category/tenders', viewAllLabel: 'View all' }) %>
          <div class="portal-widget-body">
            <% if (tenders.length) { %>
              <ul class="portal-post-list portal-post-list-compact">
                <% tenders.forEach(function(post) { %>
                  <li><%- include('../partials/portal-post-item', { post, showClosing: true }) %></li>
                <% }) %>
              </ul>
            <% } else { %>
              <%- include('../partials/portal-empty', { icon: 'file-earmark-text', message: 'No tender posts yet.' }) %>
            <% } %>
          </div>
        </section>
      </div>
      <div class="col-lg-6">
        <section class="portal-widget site-widget portal-card-<%= cardStyle %>">
          <%- include('../partials/widget-header', { title: 'Jobs & Vacancies', viewAllUrl: '/category/jobs', viewAllLabel: 'View all' }) %>
          <div class="portal-widget-body">
            <% if (jobs.length) { %>
              <ul class="portal-post-list portal-post-list-compact">
                <% jobs.forEach(function(post) { %>
                  <li><%- include('../partials/portal-post-item', { post, showClosing: true }) %></li>
                <% }) %>
              </ul>
            <% } else { %>
              <%- include('../partials/portal-empty', { icon: 'briefcase', message: 'No job vacancies posted yet.' }) %>
            <% } %>
          </div>
        </section>
      </div>
    </div>
  </div>
</section>
