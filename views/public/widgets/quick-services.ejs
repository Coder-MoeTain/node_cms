<section class="portal-section portal-quick-services portal-mnp-services" id="portal-quick-services" aria-label="Quick services">
  <div class="container py-4">
    <% const isMnp = themePreset === 'myanmar-portal';
       const menuItems = (typeof quickServiceItems !== 'undefined' && quickServiceItems.length)
         ? quickServiceItems
         : ((siteMenus && siteMenus['quick-services']) || []);
       const fallbackServices = [
        { icon: 'bi-building', title: 'Government Websites', desc: 'Official ministries and agencies', url: '/blog', tone: 'blue' },
        { icon: 'bi-ui-checks', title: 'Forms', desc: 'Downloadable application forms', url: '/search?q=forms', tone: 'green' },
        { icon: 'bi-folder2-open', title: 'Documents', desc: 'Policies and publications', url: '/category/documents', tone: 'purple' },
        { icon: 'bi-calendar-event', title: 'Public Holidays', desc: 'National holiday calendar', url: '/page/public-holidays', tone: 'orange' },
        { icon: 'bi-telephone-fill', title: 'Emergency Contacts', desc: 'Hotlines and urgent support', url: '#portal-emergency', tone: 'red' },
        { icon: 'bi-phone', title: 'Mobile App Gallery', desc: 'Official mobile applications', url: '#portal-mobile-app', tone: 'teal' }
      ];
       const tones = ['blue', 'green', 'purple', 'orange', 'teal', 'red'];
       const services = menuItems.length
         ? menuItems.map(function(item, index) {
             return {
               icon: item.icon || 'bi-link-45deg',
               title: item.title,
               desc: item.description || '',
               url: item.url || '#',
               tone: tones[index % tones.length]
             };
           })
         : fallbackServices;
      const cardStyle = (portalConfig.widgets && portalConfig.widgets.cardStyle) || 'bordered';
    %>
    <% if (!isMnp) { %>
      <div class="portal-section-head">
        <h2 class="portal-section-title">Quick Services</h2>
        <p class="portal-section-subtitle">Shortcut access to common government resources</p>
      </div>
    <% } %>
    <div class="row g-4 portal-service-grid portal-mnp-service-grid">
      <% services.forEach(function(item) { %>
        <div class="col-12 col-sm-6 col-lg-4">
          <a class="portal-service-card portal-mnp-service-card portal-card-<%= cardStyle %>" href="<%= item.url %>">
            <span class="portal-mnp-icon-wrap portal-mnp-icon-<%= item.tone %>" aria-hidden="true">
              <i class="bi <%= item.icon %>"></i>
            </span>
            <strong class="portal-service-title portal-mnp-service-title"><%= item.title %></strong>
            <% if (item.desc) { %><span class="portal-service-desc"><%= item.desc %></span><% } %>
          </a>
        </div>
      <% }) %>
    </div>
  </div>
</section>
