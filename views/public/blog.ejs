<%- include(themePartial('head')) %>
<%- include(themePartial('header')) %>
<% if (isPortal) { %>
<main class="container portal-page portal-main py-4" id="main-content">
  <%- include('partials/page-header', { title: 'News & Blog', isPortal: true, crumbs: [{ label: 'Home', url: '/' }, { label: 'Blog' }] }) %>
  <div class="row g-4 layout-<%= activeTheme.sidebar_position || 'right' %>">
    <section class="<%= activeTheme.sidebar_position === 'none' ? 'col-12' : 'col-lg-8' %>">
      <div class="portal-list-panel site-list-panel portal-card-bordered">
        <% if (posts.length) { %>
          <ul class="portal-post-list portal-post-list-page">
            <% posts.forEach(function(post) { %>
              <li><%- include(themePartial('portal-post-item'), { post, showExcerpt: true }) %></li>
            <% }) %>
          </ul>
        <% } else { %>
          <%- include(themePartial('portal-empty'), { icon: 'journal-text', message: 'No published posts yet.' }) %>
        <% } %>
      </div>
      <% if (pagination && pagination.pages > 1) { %>
        <%- include('../partials/pagination', { pagination, paginationBase: '?', paginationClass: 'portal-pagination mt-4', paginationLabel: 'Blog pagination' }) %>
      <% } %>
    </section>
    <% if (activeTheme.sidebar_position !== 'none') { %><div class="col-lg-4"><%- include(themePartial('sidebar')) %></div><% } %>
  </div>
</main>
<% } else { %>
<main class="container site-page py-4 py-lg-5" id="main-content">
  <%- include('partials/page-header', { title: 'News & Blog', subtitle: 'Articles, updates, and announcements.', isPortal: false, crumbs: [{ label: 'Home', url: '/' }, { label: 'Blog' }] }) %>
  <div class="row g-4 layout-<%= activeTheme.sidebar_position || 'right' %>">
    <section class="<%= activeTheme.sidebar_position === 'none' ? 'col-12' : 'col-lg-8' %>">
      <% if (posts.length) { %>
        <div class="row g-4">
          <% posts.forEach(function(post) { %>
            <div class="col-md-6">
              <%- include(themePartial('post-card'), { post }) %>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="site-empty-state"><i class="bi bi-journal-x" aria-hidden="true"></i><p>No published posts yet.</p></div>
      <% } %>
      <% if (pagination && pagination.pages > 1) { %>
        <%- include('../partials/pagination', { pagination, paginationBase: '?', paginationClass: 'portal-pagination mt-4', paginationLabel: 'Blog pagination' }) %>
      <% } %>
    </section>
    <% if (activeTheme.sidebar_position !== 'none') { %><div class="col-lg-4"><%- include(themePartial('standard-sidebar')) %></div><% } %>
  </div>
</main>
<% } %>
<%- include(themePartial('footer')) %>
