<% const cfg = portalConfig || {}; const hp = cfg.homepage || {}; const isMnp = themePreset === 'myanmar-portal'; %>
<% if (hp.hero && sliders && sliders.length) { %>
  <%- include('partials/hero-carousel', { sliders, variant: 'portal', isMnp }) %>
<% } else if (hp.hero) { %>
  <%- include('partials/hero-fallback', { variant: 'portal', isMnp, siteSettings, portalConfig, portalStats }) %>
<% } %>

<% if (hp.quickLinks || hp.quickServices) { %><%- include('widgets/quick-services') %><% } %>

<% if (hp.emergency) { %><%- include('widgets/emergency-contacts') %><% } %>

<div class="container portal-home-grid py-4">
  <div class="row g-4">
    <% if (hp.latestNews) { %>
      <div class="col-lg-6"><%- include('widgets/latest-news', { posts: latestNews || posts }) %></div>
    <% } %>
    <% if (hp.announcements) { %>
      <div class="col-lg-6"><%- include('widgets/announcements', { posts: announcements || posts }) %></div>
    <% } %>
  </div>
</div>

<% if (hp.tendersJobs) { %><%- include('widgets/tenders-jobs', { tenderPosts: tenderPosts || [], jobPosts: jobPosts || [] }) %><% } %>

<% if (hp.mobileApp) { %><%- include('widgets/mobile-app') %><% } %>

<% if (hp.mediaGallery) { %><%- include('widgets/media-gallery', { mediaItems: mediaItems || [] }) %><% } %>

<div class="container portal-home-grid pb-4">
  <div class="row g-4">
    <% if (hp.hotNews) { %>
      <div class="col-lg-8"><%- include('widgets/hot-news', { posts: hotPosts || popularPosts || posts }) %></div>
    <% } %>
    <% if (hp.subscribe) { %>
      <div class="col-lg-4"><%- include('widgets/subscribe') %></div>
    <% } %>
  </div>
</div>

<% if (hp.statistics) { %><%- include('widgets/stat-counters') %><% } %>
