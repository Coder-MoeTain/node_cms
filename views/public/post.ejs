<%- include('partials/head') %>
<%- include('partials/header') %>
<main class="container py-4">
  <nav class="small mb-3"><a href="/">Home</a> / <a href="/blog">Blog</a> / <%= post.title %></nav>
  <div class="row g-4">
    <article class="col-lg-8">
      <h1><%= post.title %></h1>
      <div class="text-muted mb-3">By <%= post.author ? post.author.name : 'Author' %> in <%= post.Category ? post.Category.name : 'Uncategorized' %></div>
      <% if (post.featured_image) { %><img class="img-fluid rounded mb-3" src="<%= post.featured_image %>" alt="<%= post.title %>"><% } %>
      <% if (post.video_url) { %><div class="ratio ratio-16x9 mb-3"><iframe src="<%= post.video_url %>" allowfullscreen></iframe></div><% } %>
      <div class="content"><%- post.content %></div>
      <div class="mt-3"><% (post.Tags || []).forEach(function(tag) { %><a class="badge text-bg-secondary text-decoration-none me-1" href="/tag/<%= tag.slug %>"><%= tag.name %></a><% }) %></div>
      <% if (post.allow_comments) { %>
        <section class="mt-5">
          <h3>Comments</h3>
          <% (post.comments || []).forEach(function(comment) { %><div class="border rounded p-3 mb-2"><strong><%= comment.name %></strong><p class="mb-0"><%= comment.content %></p></div><% }) %>
          <form class="card card-body mt-3" method="post" action="/post/<%= post.id %>/comment">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <h4>Leave a comment</h4>
            <div class="row g-3">
              <div class="col-md-6"><input class="form-control" name="name" placeholder="Name" required></div>
              <div class="col-md-6"><input class="form-control" name="email" type="email" placeholder="Email" required></div>
              <div class="col-12"><input class="form-control" name="website" placeholder="Website"></div>
              <div class="col-12"><textarea class="form-control" name="content" placeholder="Comment" required></textarea></div>
            </div>
            <button class="btn btn-primary mt-3">Submit Comment</button>
          </form>
        </section>
      <% } %>
    </article>
    <div class="col-lg-4"><%- include('partials/sidebar') %></div>
  </div>
</main>
<%- include('partials/footer') %>
