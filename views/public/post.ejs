<%- include(themePartial('head')) %>
<%- include(themePartial('header')) %>
<%
  const plainText = (post.content || '').replace(/<[^>]+>/g, ' ').trim();
  const wordCount = plainText.split(/\s+/).filter(Boolean).length;
  const readMinutes = Math.max(1, Math.ceil(wordCount / 200));
  const publishedDate = post.published_at || post.created_at;
  const authorInitial = post.author && post.author.name ? post.author.name.trim().charAt(0).toUpperCase() : 'A';
  const featuredImage = typeof resolvePublicMediaUrl === 'function'
    ? resolvePublicMediaUrl(post.featured_image)
    : (post.featured_image || '');
%>
<main class="<%= isPortal ? 'portal-main portal-page' : '' %> post-page" id="main-content">
  <div class="post-reading-progress" aria-hidden="true"><div class="post-reading-progress-bar" data-reading-progress></div></div>
  <% if (featuredImage) { %>
    <figure class="post-hero">
      <img src="<%= featuredImage %>" alt="<%= post.title %>" decoding="async" fetchpriority="high">
      <div class="post-hero-shade" aria-hidden="true"></div>
    </figure>
  <% } %>

  <div class="container post-page-shell py-4">
    <nav class="post-breadcrumb portal-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="post-breadcrumb-sep" aria-hidden="true"><i class="bi bi-chevron-right"></i></span>
      <a href="/blog">Blog</a>
      <span class="post-breadcrumb-sep" aria-hidden="true"><i class="bi bi-chevron-right"></i></span>
      <span class="post-breadcrumb-current" aria-current="page"><%= post.title %></span>
    </nav>

    <div class="row g-4 layout-<%= activeTheme.sidebar_position || 'right' %>">
      <article class="post-article <%= activeTheme.sidebar_position === 'none' ? 'col-12' : 'col-lg-8' %>">
        <header class="post-header<%= featuredImage ? ' post-header--overlap' : '' %>">
          <% if (post.Category) { %>
            <a class="post-category-pill" href="/category/<%= post.Category.slug %>"><%= post.Category.name %></a>
          <% } %>
          <h1 class="post-title"><%= post.title %></h1>
          <% if (typeof canEditPost === 'function' && canEditPost(post)) { %>
            <p class="post-admin-actions"><%- include('partials/post-edit-link', { post }) %></p>
          <% } %>
          <% if (post.excerpt) { %><p class="post-lead"><%= post.excerpt %></p><% } %>
          <%- include('partials/post-toolbar', { post }) %>
          <ul class="post-meta-list">
            <li>
              <i class="bi bi-calendar3" aria-hidden="true"></i>
              <time datetime="<%= publishedDate %>"><%= formatDate(publishedDate, { month: 'long' }) %></time>
            </li>
            <li>
              <i class="bi bi-person" aria-hidden="true"></i>
              <span><%= post.author ? post.author.name : 'Author' %></span>
            </li>
            <li>
              <i class="bi bi-clock" aria-hidden="true"></i>
              <span><%= readMinutes %> min read</span>
            </li>
            <% if (post.views_count) { %>
              <li>
                <i class="bi bi-eye" aria-hidden="true"></i>
                <span><%= post.views_count.toLocaleString() %> views</span>
              </li>
            <% } %>
          </ul>
        </header>

        <% if (post.video_url) { %>
          <div class="post-media post-video">
            <div class="ratio ratio-16x9">
              <iframe src="<%= post.video_url %>" title="Video" allowfullscreen></iframe>
            </div>
          </div>
        <% } %>

        <div class="post-content entry-content content"><%- (typeof fseTemplateHtml !== 'undefined' && fseTemplateHtml) ? fseTemplateHtml : post.content %></div>

        <% if ((post.Tags || []).length) { %>
          <div class="post-tags">
            <span class="post-tags-label"><i class="bi bi-tags" aria-hidden="true"></i> Tags</span>
            <div class="post-tags-list">
              <% (post.Tags || []).forEach(function(tag) { %>
                <a class="post-tag" href="/tag/<%= tag.slug %>"><%= tag.name %></a>
              <% }) %>
            </div>
          </div>
        <% } %>

        <% if (post.author) { %>
          <aside class="post-author-box" aria-label="About the author">
            <div class="post-author-avatar" aria-hidden="true">
              <% if (post.author.profile_image) { %>
                <img src="<%= post.author.profile_image %>" alt="">
              <% } else { %>
                <span><%= authorInitial %></span>
              <% } %>
            </div>
            <div class="post-author-body">
              <span class="post-author-label">Written by</span>
              <strong class="post-author-name"><%= post.author.name %></strong>
              <p class="mb-0">Contributor at <%= siteSettings.site_title || 'NodePress CMS' %></p>
            </div>
          </aside>
        <% } %>

        <% if (prevPost || nextPost) { %>
          <nav class="post-nav-links" aria-label="Post navigation">
            <% if (prevPost) { %>
              <a class="post-nav-card post-nav-card--prev" href="<%= postUrl(prevPost) %>">
                <span class="post-nav-direction"><i class="bi bi-arrow-left" aria-hidden="true"></i> Previous</span>
                <span class="post-nav-title"><%= prevPost.title %></span>
              </a>
            <% } else { %>
              <span class="post-nav-spacer"></span>
            <% } %>
            <% if (nextPost) { %>
              <a class="post-nav-card post-nav-card--next" href="<%= postUrl(nextPost) %>">
                <span class="post-nav-direction">Next <i class="bi bi-arrow-right" aria-hidden="true"></i></span>
                <span class="post-nav-title"><%= nextPost.title %></span>
              </a>
            <% } %>
          </nav>
        <% } %>

        <% if (relatedPosts && relatedPosts.length) { %>
          <section class="post-related portal-related-posts">
            <%- include('partials/section-head', { title: 'Related posts', viewAllUrl: '/blog', viewAllLabel: 'View all', inline: true, headClass: 'mb-3' }) %>
            <ul class="portal-post-list portal-post-list-page portal-card-bordered site-list-panel p-3">
              <% relatedPosts.forEach(function(item) { %>
                <li><%- include(themePartial('portal-post-item'), { post: item, showExcerpt: true }) %></li>
              <% }) %>
            </ul>
          </section>
        <% } %>

        <% if (post.allow_comments) { %>
          <% if (success && success.length) { %><div class="np-alert np-alert-success site-alert mb-3" role="status"><%= success[0] %></div><% } %>
          <% if (typeof formError !== 'undefined' && formError) { %><div class="np-alert np-alert-danger site-alert mb-3" role="alert"><%= formError %></div><% } %>
          <%- include('partials/comments-thread', { post, commentTree: commentTree || post.comments || [], commentCount: commentCount || 0, commentPrefill: typeof commentPrefill !== 'undefined' ? commentPrefill : {} }) %>
        <% } %>
      </article>
      <% if (activeTheme.sidebar_position !== 'none') { %>
        <div class="col-lg-4"><%- include(themePartial('sidebar')) %></div>
      <% } %>
    </div>
  </div>
</main>
<%- include(themePartial('footer')) %>
