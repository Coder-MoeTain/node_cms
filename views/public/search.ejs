<%- include(themePartial('head')) %>
<%- include(themePartial('header')) %>
<main class="<%= isPortal ? 'container portal-page portal-main py-4' : 'site-page site-main py-5' %>" id="main-content">
  <div class="<%= isPortal ? '' : 'container' %>">
    <%- include('partials/page-header', {
      title: 'Search',
      subtitle: q ? ('Results for “' + q + '”') : 'Find posts, pages, and documents across the site.',
      isPortal: isPortal,
      crumbs: [{ label: 'Home', url: '/' }, { label: 'Search' }]
    }) %>
    <form class="<%= isPortal ? 'portal-search-page-form portal-card-bordered p-3 mb-4' : 'site-search-form mb-4' %>" action="/search" role="search">
      <label class="form-label" for="search-q">Search query</label>
      <div class="d-flex gap-2 flex-wrap">
        <input class="form-control" id="search-q" name="q" value="<%= q %>" placeholder="Search posts, pages, documents…" aria-label="Search query">
        <button class="site-btn <%= isPortal ? 'portal-btn' : '' %>" type="submit"><i class="bi bi-search" aria-hidden="true"></i> Search</button>
      </div>
    </form>
    <% if (q) { %><p class="<%= isPortal ? 'portal-search-results-label' : 'site-search-results-label' %>" aria-live="polite"><%= posts.length + (pages ? pages.length : 0) %> result<%= (posts.length + (pages ? pages.length : 0)) === 1 ? '' : 's' %> for “<%= q %>”</p><% } %>
    <div class="row g-4 layout-<%= activeTheme.sidebar_position || 'right' %>">
      <section class="<%= activeTheme.sidebar_position === 'none' ? 'col-12' : 'col-lg-8' %>">
        <% if (pages && pages.length) { %>
          <div class="<%= isPortal ? 'portal-widget site-widget portal-card-bordered mb-4' : 'site-panel mb-4' %>">
            <header class="<%= isPortal ? 'portal-widget-header' : 'site-panel-header' %>"><h2 class="<%= isPortal ? 'portal-widget-title' : 'site-panel-title' %>">Pages</h2></header>
            <div class="<%= isPortal ? 'portal-widget-body' : 'site-panel-body' %>">
              <ul class="<%= isPortal ? 'portal-sidebar-list' : 'site-link-list' %>">
                <% pages.forEach(function(pageRow) { %>
                  <li><a href="/page/<%= pageRow.slug %>"><%= pageRow.title %></a></li>
                <% }) %>
              </ul>
            </div>
          </div>
        <% } %>
        <div class="<%= isPortal ? 'portal-list-panel site-list-panel portal-card-bordered' : 'site-list-panel site-panel' %>">
          <% if (posts.length) { %>
            <ul class="<%= isPortal ? 'portal-post-list portal-post-list-page' : 'site-post-list' %>">
              <% posts.forEach(function(post) { %>
                <li><%- include(themePartial(isPortal ? 'portal-post-item' : 'post-card-list'), { post }) %></li>
              <% }) %>
            </ul>
          <% } else if (!pages || !pages.length) { %>
            <%- include(themePartial('portal-empty'), { icon: 'search', message: q ? 'No posts matched your search.' : 'Enter a search term above.' }) %>
          <% } %>
        </div>
        <% if (pagination && pagination.pages > 1) { %>
          <%- include('../partials/pagination', { pagination, paginationBase: q ? ('?q=' + encodeURIComponent(q)) : '?', paginationClass: (isPortal ? 'portal-pagination' : 'site-pagination') + ' mt-4', paginationLabel: 'Search pagination' }) %>
        <% } %>
      </section>
      <% if (activeTheme.sidebar_position !== 'none') { %>
        <div class="col-lg-4"><%- include(themePartial('sidebar')) %></div>
      <% } %>
    </div>
  </div>
</main>
<%- include(themePartial('footer')) %>
