<%- include('partials/head') %>
<%- include('partials/header') %>
<main id="main-content" class="portal-main portal-home-page">
  <% const usePortalHome = (portalConfig.header && portalConfig.header.layout === 'portal') || activeTheme.header_layout === 'portal' || themePreset === 'myanmar-portal'; %>
  <% if (usePortalHome) { %>
    <% if (portalConfig.homepage && portalConfig.homepage.announcementTicker && themePreset !== 'myanmar-portal') { %>
      <%- include('partials/portal-ticker') %>
    <% } %>
    <%- include('home-portal') %>
  <% } else { %>
    <% if (sliders.length) { %>
      <div id="homeSlider" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">
          <% sliders.forEach(function(slide, index) { %>
            <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
              <div class="hero-slide" style="<%= slide.image ? `--hero-image: url(${slide.image})` : '' %>">
                <div class="container hero-content">
                  <h1><%= slide.title %></h1>
                  <p><%= slide.description %></p>
                  <% if (slide.button_text) { %><a class="site-btn" href="<%= slide.button_url %>"><%= slide.button_text %></a><% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
    <% banners.forEach(function(banner) { %>
      <section class="container py-4"><div class="banner-box"><h2><%= banner.title %></h2><p><%= banner.subtitle %></p><% if (banner.button_text) { %><a class="site-btn" href="<%= banner.button_link %>"><%= banner.button_text %></a><% } %></div></section>
    <% }) %>
    <section class="container py-4">
      <div class="section-heading d-flex justify-content-between align-items-center mb-3">
        <h2 class="h3 mb-0">Latest Posts</h2>
        <a href="/blog">View all posts</a>
      </div>
      <div class="row g-4">
        <% if (posts.length) { %>
          <% posts.forEach(function(post) { %><div class="col-md-6 col-lg-4"><%- include('partials/post-card', { post }) %></div><% }) %>
        <% } else { %>
          <div class="col-12"><div class="np-card"><div class="np-card-body text-center text-muted">No published posts yet.</div></div></div>
        <% } %>
      </div>
    </section>
  <% } %>
</main>
<%- include('partials/footer') %>
