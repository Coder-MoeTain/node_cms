<%- include(themePartial('head')) %>
<%- include(themePartial('header')) %>
<% const usePortalHome = (portalConfig.header && portalConfig.header.layout === 'portal') || activeTheme.header_layout === 'portal' || themePreset === 'myanmar-portal'; %>
<main id="main-content" class="<%= usePortalHome ? 'portal-main portal-home-page' : 'site-main site-home-page' %>">
  <% if (usePortalHome) { %>
    <% if (portalConfig.homepage && portalConfig.homepage.announcementTicker && themePreset !== 'myanmar-portal') { %>
      <%- include(themePartial('portal-ticker')) %>
    <% } %>
    <%- include(themePartial('home-portal')) %>
  <% } else { %>
    <% if (sliders.length) { %>
      <%- include('partials/hero-carousel', { sliders, variant: 'site' }) %>
    <% } else { %>
      <%- include('partials/hero-fallback', { variant: 'site', siteSettings, portalConfig }) %>
    <% } %>
    <% banners.forEach(function(banner) { %>
      <section class="container py-4"><div class="banner-box"><h2><%= banner.title %></h2><p><%= banner.subtitle %></p><% if (banner.button_text) { %><a class="site-btn" href="<%= banner.button_link %>"><%= banner.button_text %></a><% } %></div></section>
    <% }) %>
    <section class="site-features site-widget-section">
      <div class="container">
        <%- include('partials/section-head', { title: 'Why NodePress', subtitle: 'Everything you need to publish and manage content at scale.' }) %>
        <div class="row g-4 site-feature-grid">
          <div class="col-md-4">
            <div class="site-feature-card site-widget-card">
              <div class="site-feature-icon"><i class="bi bi-journal-richtext" aria-hidden="true"></i></div>
              <h3>Rich content</h3>
              <p>Publish articles, pages, and media with a powerful editor built for teams.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="site-feature-card site-widget-card">
              <div class="site-feature-icon"><i class="bi bi-shield-check" aria-hidden="true"></i></div>
              <h3>Secure &amp; reliable</h3>
              <p>Enterprise-grade security with role-based access and activity logging.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="site-feature-card site-widget-card">
              <div class="site-feature-icon"><i class="bi bi-palette" aria-hidden="true"></i></div>
              <h3>Beautiful themes</h3>
              <p>Switch themes and customize colors, layouts, and branding in minutes.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section class="container py-5 site-widget-section">
      <%- include('partials/section-head', { title: 'Recent articles', subtitle: 'Latest stories from the blog.', viewAllUrl: '/blog', viewAllLabel: 'View all posts', inline: true, headClass: 'mb-4' }) %>
      <div class="row g-4 site-post-grid">
        <% if (posts.length) { %>
          <% posts.forEach(function(post) { %><div class="col-md-6 col-lg-4"><%- include(themePartial('post-card'), { post }) %></div><% }) %>
        <% } else { %>
          <div class="col-12"><div class="site-empty-state site-empty-box"><i class="bi bi-journal-x" aria-hidden="true"></i><p>No published posts yet.</p><a class="site-btn" href="/blog">Browse the blog</a></div></div>
        <% } %>
      </div>
    </section>
    <section class="site-cta-band">
      <div class="container site-cta-inner">
        <div>
          <h2>Stay connected</h2>
          <p>Have questions or feedback? We'd love to hear from you.</p>
        </div>
        <a class="site-btn site-btn-lg site-btn-light" href="/contact">Contact us</a>
      </div>
    </section>
  <% } %>
</main>
<%- include(themePartial('footer')) %>
