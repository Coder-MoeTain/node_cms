<%- include(themePartial('head')) %>
<%- include(themePartial('header')) %>
<main id="main-content" class="portal-main portal-page container py-5">
  <div class="portal-list-panel portal-card-bordered p-4 p-md-5 mx-auto" style="max-width:520px">
    <h1 class="h4 mb-3">Protected Content</h1>
    <p class="text-muted">Enter the password to view <strong><%= returnTitle %></strong>.</p>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <form method="post" action="<%= actionUrl %>">
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>
      <div class="mb-3">
        <label class="form-label" for="content_password">Password</label>
        <input class="form-control" type="password" id="content_password" name="content_password" required autocomplete="current-password">
      </div>
      <button class="site-btn portal-btn" type="submit">Unlock</button>
    </form>
  </div>
</main>
<%- include(themePartial('footer')) %>
