<%- include('partials/head') %>
<%- include('partials/header') %>
<main class="container py-4" id="main-content">
  <h1 class="mb-4">Contact Us</h1>
  <% if (success && success.length) { %><div class="np-alert np-alert-success"><%= success[0] %></div><% } %>
  <% if (error && error.length) { %><div class="np-alert np-alert-danger"><%= error[0] %></div><% } %>
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <form class="contact-form-card" method="post" action="/contact">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="row g-3">
          <div class="col-md-6"><label class="form-label" for="contact-name">Name</label><input class="form-control" id="contact-name" name="name" placeholder="Your name" required></div>
          <div class="col-md-6"><label class="form-label" for="contact-email">Email</label><input class="form-control" id="contact-email" name="email" type="email" placeholder="you@example.com" required></div>
          <div class="col-md-6"><label class="form-label" for="contact-phone">Phone</label><input class="form-control" id="contact-phone" name="phone" placeholder="Optional"></div>
          <div class="col-md-6"><label class="form-label" for="contact-subject">Subject</label><input class="form-control" id="contact-subject" name="subject" placeholder="How can we help?" required></div>
          <div class="col-12"><label class="form-label" for="contact-message">Message</label><textarea class="form-control" id="contact-message" name="message" rows="6" placeholder="Your message" required></textarea></div>
        </div>
        <button class="site-btn mt-3" type="submit">Send Message</button>
      </form>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
