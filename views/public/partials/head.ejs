<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= seo?.title || title %></title>
  <meta name="description" content="<%= seo?.description || '' %>">
  <link rel="canonical" href="<%= seo?.canonical || '' %>">
  <% if (seo?.image) { %><meta property="og:image" content="<%= seo.image %>"><% } %>
  <% if (siteSettings.favicon || activeTheme.favicon) { %><link rel="icon" href="<%= siteSettings.favicon || activeTheme.favicon %>"><% } %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme-vars.css">
  <link rel="stylesheet" href="/css/site.css">
  <style>
    :root {
      --np-primary: <%= activeTheme.primary_color || '#2271b1' %>;
      --np-primary-hover: #135e96;
      --np-secondary: <%= activeTheme.secondary_color || '#50575e' %>;
      --np-bg: <%= activeTheme.background_color || '#ffffff' %>;
      --np-text: <%= activeTheme.text_color || '#1d2327' %>;
      --np-font: <%= activeTheme.font_family || 'Georgia, "Times New Roman", serif' %>;
      --np-link: <%= activeTheme.primary_color || '#2271b1' %>;
      --np-header-bg: <%= activeTheme.primary_color || '#ffffff' %>;
      --np-footer-bg: #1d2327;
    }
  </style>
  <% if (typeof schema !== 'undefined' && schema) { %><script type="application/ld+json"><%- schema %></script><% } %>
  <% (pluginPublicHead || []).forEach(function(snippet) { %><%- snippet %><% }) %>
</head>
<body class="<%= activeTheme.dark_mode ? 'theme-dark' : '' %> <%= activeTheme.site_layout === 'boxed' ? 'boxed-layout' : '' %>">
