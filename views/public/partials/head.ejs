<!doctype html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>" data-theme-preset="<%= themePreset || 'classic-blue' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= (typeof seo !== 'undefined' && seo && seo.title) || title %></title>
  <meta name="description" content="<%= (typeof seo !== 'undefined' && seo && seo.description) || siteSettings.site_tagline || '' %>">
  <link rel="canonical" href="<%= (typeof seo !== 'undefined' && seo && seo.canonical) || '' %>">
  <% const seoToolkitActive = (typeof activePluginSlugs !== 'undefined' && activePluginSlugs.includes('seo-booster')); %>
  <% if (!seoToolkitActive) { %>
  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= (typeof seo !== 'undefined' && seo && seo.title) || siteSettings.site_title || title %>">
  <meta property="og:description" content="<%= (typeof seo !== 'undefined' && seo && seo.description) || siteSettings.site_tagline || '' %>">
  <meta property="og:url" content="<%= (typeof seo !== 'undefined' && seo && seo.canonical) || '' %>">
  <meta name="twitter:card" content="summary_large_image">
  <% if (typeof seo !== 'undefined' && seo && seo.image) { %><meta property="og:image" content="<%= seo.image %>"><% } %>
  <% } %>
  <meta name="theme-color" content="<%= activeTheme.primary_color || '#0b5f8a' %>">
  <% if (siteSettings.favicon || activeTheme.favicon) { %><link rel="icon" href="<%= siteSettings.favicon || activeTheme.favicon %>"><% } %>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme-vars.css">
  <link rel="stylesheet" href="/css/site-design-system.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/ui-modern.css">
  <link rel="stylesheet" href="/css/site.css">
  <link rel="stylesheet" href="/css/site-modern.css">
  <link rel="stylesheet" href="/css/site-pages.css">
  <% if (typeof themeStylesheet !== 'undefined' && themeStylesheet) { %><link rel="stylesheet" href="<%= themeStylesheet %>"><% } %>
  <link rel="stylesheet" href="/css/language-switcher.css">
  <% const isPortalLayout = typeof isPortal !== 'undefined' && isPortal; %>
  <% if (isPortalLayout) { %>
  <link rel="stylesheet" href="/css/portal.css">
  <% } %>
  <% if (themePreset === 'myanmar-portal') { %>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Myanmar:wght@400;600;700&family=Roboto:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/mnp-portal.css">
  <% } else if ((activeTheme.font_family || '').includes('Inter')) { %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <% } else if ((activeTheme.font_family || '').includes('Source Sans')) { %>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet">
  <% } else if ((activeTheme.font_family || '').includes('Merriweather')) { %>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&display=swap" rel="stylesheet">
  <% } else if ((activeTheme.font_family || '').includes('Lora')) { %>
  <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&display=swap" rel="stylesheet">
  <% } %>
  <% const tv = themeVars || {};
     const dt = (typeof designTokens !== 'undefined' && designTokens && designTokens.vars) ? designTokens.vars : {};
     const accent = tv.accent || activeTheme.primary_color || '#d71920';
     const cardColor = tv.card || '#ffffff';
     const footerBg = tv.footer || '#0b2f47';
     const muted = tv.muted || '#6b7280';
     const border = tv.border || '#d7dde5';
     const linkColor = tv.link || activeTheme.primary_color || '#0b5f8a';
     const buttonColor = tv.button || activeTheme.primary_color || '#0b5f8a';
  %>
  <style nonce="<%= cspNonce %>">
    :root {
      --portal-primary: <%= activeTheme.primary_color || (themePreset === 'myanmar-portal' ? '#006ba6' : '#0b5f8a') %>;
      --portal-primary-dark: <%= themePreset === 'myanmar-portal' ? '#004d7a' : '#06466a' %>;
      --portal-secondary: <%= activeTheme.secondary_color || (themePreset === 'myanmar-portal' ? '#ffcc00' : '#f4b000') %>;
      --portal-accent: <%= accent %>;
      --portal-bg: <%= activeTheme.background_color || '#f5f7fa' %>;
      --portal-card: <%= cardColor %>;
      --portal-border: <%= border %>;
      --portal-text: <%= activeTheme.text_color || '#1f2933' %>;
      --portal-muted: <%= muted %>;
      --portal-footer: <%= footerBg %>;
      --gov-primary: var(--portal-primary);
      --gov-primary-dark: var(--portal-primary-dark);
      --gov-secondary: var(--portal-secondary);
      --gov-accent: var(--portal-accent);
      --gov-bg: var(--portal-bg);
      --gov-card: var(--portal-card);
      --gov-border: var(--portal-border);
      --gov-text: var(--portal-text);
      --gov-muted: var(--portal-muted);
      --gov-footer: var(--portal-footer);
      --np-primary: <%= activeTheme.primary_color || '#0b5f8a' %>;
      --np-primary-hover: #06466a;
      --np-secondary: <%= activeTheme.secondary_color || '#f4b000' %>;
      --np-bg: <%= activeTheme.background_color || '#f5f7fa' %>;
      --np-text: <%= activeTheme.text_color || '#1f2933' %>;
      --np-font: <%= activeTheme.font_family || '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif' %>;
      --site-primary: var(--portal-primary);
      --site-primary-dark: var(--portal-primary-dark);
      --site-secondary: var(--portal-secondary);
      --site-accent: var(--portal-accent);
      --site-bg: var(--portal-bg);
      --site-surface: var(--portal-card);
      --site-surface-soft: #eef4f8;
      --site-card: var(--portal-card);
      --site-border: var(--portal-border);
      --site-text: var(--portal-text);
      --site-muted: var(--portal-muted);
      --site-header-bg: var(--portal-card);
      --site-footer-bg: var(--portal-footer);
      --site-link: <%= linkColor %>;
      --site-button: <%= buttonColor %>;
      --site-button-hover: var(--gov-primary-dark);
      --site-font-family: <%= activeTheme.font_family || '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif' %>;
      --site-radius-sm: <%= dt.radiusSm || '8px' %>;
      --site-radius-md: <%= dt.radiusMd || '14px' %>;
      --site-radius-lg: <%= dt.radiusLg || '22px' %>;
      --site-shadow-sm: <%= dt.shadowSm || '0 4px 12px rgba(15, 23, 42, 0.06)' %>;
      --site-shadow-md: <%= dt.shadowMd || '0 12px 30px rgba(15, 23, 42, 0.10)' %>;
      --site-shadow-lg: <%= dt.shadowLg || '0 20px 40px rgba(15, 23, 42, 0.12)' %>;
      --site-section-pad: <%= dt.sectionPad || '3.5rem' %>;
      --site-section-pad-mobile: <%= dt.sectionPadMobile || '2rem' %>;
      --site-container: 1180px;
      --site-header-z: 1030;
      --site-scroll-offset: 72px;
      --site-logo-max-height: <%= activeTheme.logo_max_height || 64 %>px;
      --site-logo-max-width: <%= activeTheme.logo_max_width || 180 %>px;
    }
  </style>
  <% if (activeTheme.custom_css) { %><style id="theme-custom-css" nonce="<%= cspNonce %>"><%- activeTheme.custom_css %></style><% } %>
  <% if (typeof schema !== 'undefined' && schema) { %><script type="application/ld+json" nonce="<%= cspNonce %>"><%- schema %></script><% } %>
  <% (pluginPublicHead || []).forEach(function(snippet) { %><%- snippet %><% }) %>
</head>
<body class="site-design-system <%= typeof themeLayoutClasses !== 'undefined' ? themeLayoutClasses : '' %> portal-preset-<%= themePreset || 'default' %> <%= isPortalLayout ? 'portal-layout-active' : 'standard-layout-active' %><% if (activeTheme.dark_mode) { %> theme-dark<% } %><% if (typeof isCustomizerPreview !== 'undefined' && isCustomizerPreview) { %> customizer-preview-active<% } %>">
<a class="np-skip-link" href="#main-content">Skip to main content</a>
