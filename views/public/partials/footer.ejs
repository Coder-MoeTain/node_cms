<% /* isPortal from siteContext */
   const footerMenu = (siteMenus.footer && siteMenus.footer.length ? siteMenus.footer : siteMenus.header) || [];
   const footerLogo = siteSettings.site_logo || activeTheme.logo;
%>

<% if (isPortal) { %>
<button type="button" class="portal-back-to-top" data-portal-back-top aria-label="Back to top" hidden>
  <i class="bi bi-arrow-up" aria-hidden="true"></i>
</button>
<footer class="portal-footer mt-5" aria-label="Site footer">
  <div class="container py-5">
    <div class="row g-4">
      <div class="col-lg-4">
        <div class="portal-footer-brand">
          <% if (footerLogo) { %><img class="portal-footer-logo" src="<%= footerLogo %>" alt="<%= siteSettings.site_title || 'NodePress CMS' %>"><% } %>
          <h2 class="portal-footer-title"><%= siteSettings.site_title || 'NodePress CMS' %></h2>
          <p class="portal-footer-desc"><%= siteSettings.site_tagline || 'Official information portal powered by NodePress CMS.' %></p>
          <div class="portal-footer-contact">
            <% if (siteSettings.contact_email) { %><p><i class="bi bi-envelope" aria-hidden="true"></i> <a href="mailto:<%= siteSettings.contact_email %>"><%= siteSettings.contact_email %></a></p><% } %>
            <% if (siteSettings.contact_phone) { %><p><i class="bi bi-telephone" aria-hidden="true"></i> <a href="tel:<%= siteSettings.contact_phone %>"><%= siteSettings.contact_phone %></a></p><% } %>
            <% if (siteSettings.contact_address) { %><p><i class="bi bi-geo-alt" aria-hidden="true"></i> <%= siteSettings.contact_address %></p><% } %>
          </div>
        </div>
      </div>
      <div class="col-lg-4">
        <h3 class="portal-footer-heading">Quick links</h3>
        <div class="portal-footer-links-grid">
          <% footerMenu.slice(0, 6).forEach(function(item) { %>
            <div class="portal-footer-link-group">
              <a class="portal-footer-parent" href="<%= item.url %>" target="<%= item.target %>"><%= item.title %></a>
              <% if (item.children && item.children.length) { %>
                <% item.children.slice(0, 4).forEach(function(child) { %>
                  <a class="portal-footer-child" href="<%= child.url %>" target="<%= child.target %>"><%= child.title %></a>
                <% }) %>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
      <div class="col-lg-4">
        <h3 class="portal-footer-heading">Services</h3>
        <div class="portal-footer-services">
          <a href="/search?q=forms">Forms</a>
          <a href="/category/documents">Documents</a>
          <a href="/blog">Online services</a>
          <a href="/category/tenders">Tenders</a>
          <a href="/category/jobs">Jobs &amp; vacancies</a>
        </div>
        <h3 class="portal-footer-heading mt-4">Connect</h3>
        <div class="portal-footer-socials">
          <% if (siteSettings.facebook_link) { %><a href="<%= siteSettings.facebook_link %>" rel="noopener">Facebook</a><% } %>
          <% if (siteSettings.youtube_link) { %><a href="<%= siteSettings.youtube_link %>" rel="noopener">YouTube</a><% } %>
          <% if (siteSettings.telegram_link) { %><a href="<%= siteSettings.telegram_link %>" rel="noopener">Telegram</a><% } %>
          <% if (siteSettings.linkedin_link) { %><a href="<%= siteSettings.linkedin_link %>" rel="noopener">LinkedIn</a><% } %>
        </div>
        <h3 class="portal-footer-heading mt-4">Mobile apps</h3>
        <p class="portal-footer-apps">Official NodePress mobile experiences — configure app store links in site settings.</p>
        <% if (portalConfig.homepage && portalConfig.homepage.statistics) { %>
        <div class="portal-footer-stats mt-3">
          <span><strong><%= (portalStats && portalStats.visitors != null ? portalStats.visitors.toLocaleString('en-US') : '0') %></strong> visitors</span>
          <span><strong><%= (portalStats && portalStats.registeredUsers != null ? portalStats.registeredUsers.toLocaleString('en-US') : '0') %></strong> users</span>
        </div>
        <% } %>
      </div>
    </div>
    <div class="portal-footer-bottom">
      <div class="portal-footer-bottom-links">
        <a href="/contact">Contact us</a>
        <a href="/page/terms">Terms of use</a>
        <a href="/page/privacy">Privacy policy</a>
        <a href="/sitemap.xml">Sitemap</a>
        <a href="/contact">Feedback</a>
      </div>
      <p class="portal-footer-copy">&copy; <%= new Date().getFullYear() %> <%= siteSettings.site_title || 'NodePress CMS' %>. Powered by <a href="https://github.com/Coder-MoeTain/node_cms" rel="noopener">NodePress CMS</a>.</p>
    </div>
  </div>
</footer>
<% } else { %>
<button type="button" class="portal-back-to-top site-back-to-top" data-portal-back-top aria-label="Back to top" hidden>
  <i class="bi bi-arrow-up" aria-hidden="true"></i>
</button>
<footer class="site-footer mt-5 footer-layout-<%= activeTheme.footer_layout || 'four-columns' %>">
  <div class="container py-5">
    <% if ((activeTheme.footer_layout || 'four-columns') !== 'minimal') { %>
    <div class="row g-4 footer-grid">
      <div class="col-lg-4">
        <div class="footer-brand-card">
          <% if (footerLogo) { %><img class="footer-logo" src="<%= footerLogo %>" alt="<%= siteSettings.site_title || 'NodePress CMS' %>"><% } %>
          <h5><%= siteSettings.site_title || 'NodePress CMS' %></h5>
          <p><%= siteSettings.site_tagline || 'Publishing tools for modern content teams.' %></p>
        </div>
      </div>
      <% if ((activeTheme.footer_layout || 'four-columns') === 'four-columns') { %>
      <div class="col-lg-5">
        <h5>Navigation</h5>
        <div class="footer-menu-grid">
          <% footerMenu.forEach(function(item) { %>
            <div class="footer-menu-group">
              <a class="footer-menu-parent" href="<%= item.url %>" target="<%= item.target %>"><%= item.title %></a>
              <% if (item.children && item.children.length) { %>
                <% item.children.forEach(function(child) { %>
                  <a class="footer-menu-child" href="<%= child.url %>" target="<%= child.target %>"><%= child.title %></a>
                <% }) %>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
      <div class="col-lg-3">
        <h5>Connect</h5>
        <div class="footer-socials">
          <% if (siteSettings.facebook_link) { %><a href="<%= siteSettings.facebook_link %>">Facebook</a><% } %>
          <% if (siteSettings.youtube_link) { %><a href="<%= siteSettings.youtube_link %>">YouTube</a><% } %>
          <% if (siteSettings.telegram_link) { %><a href="<%= siteSettings.telegram_link %>">Telegram</a><% } %>
          <% if (siteSettings.linkedin_link) { %><a href="<%= siteSettings.linkedin_link %>">LinkedIn</a><% } %>
        </div>
      </div>
      <% } %>
    </div>
    <% } %>
    <div class="footer-bottom">
      <span>&copy; <%= new Date().getFullYear() %> <%= siteSettings.site_title || 'NodePress CMS' %>. All rights reserved.</span>
      <span>Powered by <a href="https://github.com/Coder-MoeTain/node_cms" rel="noopener">NodePress CMS</a></span>
    </div>
  </div>
</footer>
<% } %>
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/js/site.js"></script>
<% if (activeTheme.custom_js) { %><script id="theme-custom-js"><%- activeTheme.custom_js %></script><% } %>
<% (pluginPublicFooter || []).forEach(function(snippet) { %><%- snippet %><% }) %>
</body>
</html>
