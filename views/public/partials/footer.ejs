<footer class="site-footer mt-5">
  <% const footerMenu = (siteMenus.footer && siteMenus.footer.length ? siteMenus.footer : siteMenus.header) || []; %>
  <div class="container py-5">
    <div class="footer-command">
      <div>
        <span class="eyebrow">Mission Control</span>
        <h2><%= siteSettings.site_title || 'NodePress CMS' %></h2>
        <p><%= siteSettings.site_tagline || 'Publishing tools for modern content teams.' %></p>
      </div>
      <a class="btn btn-mission" href="/contact">Contact Control Room</a>
    </div>
    <div class="row g-4 footer-grid">
      <div class="col-lg-4">
        <div class="footer-brand-card">
          <% const footerLogo = siteSettings.site_logo || activeTheme.logo; %>
          <% if (footerLogo) { %><img class="footer-logo" src="<%= footerLogo %>" alt="<%= siteSettings.site_title || 'NodePress CMS' %>"><% } else { %><span class="brand-orbit"></span><% } %>
          <h5><%= siteSettings.site_title || 'NodePress CMS' %></h5>
          <p>Launch articles, pages, media, menus, and themes from a fast Node.js CMS built for exploration.</p>
        </div>
      </div>
      <div class="col-lg-5">
        <h5>Navigation</h5>
        <div class="footer-menu-grid">
          <% footerMenu.forEach(function(item) { %>
            <div class="footer-menu-group">
              <a class="footer-menu-parent" href="<%= item.url %>" target="<%= item.target %>"><%= item.title %></a>
              <% if (item.children && item.children.length) { %>
                <% item.children.forEach(function(child) { %>
                  <a class="footer-menu-child" href="<%= child.url %>" target="<%= child.target %>"><%= child.title %></a>
                <% }) %>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
      <div class="col-lg-3">
        <h5>Signals</h5>
        <div class="footer-socials">
          <a href="<%= siteSettings.facebook_link || '#' %>">Facebook</a>
          <a href="<%= siteSettings.youtube_link || '#' %>">YouTube</a>
          <a href="<%= siteSettings.telegram_link || '#' %>">Telegram</a>
          <a href="<%= siteSettings.linkedin_link || '#' %>">LinkedIn</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; <%= new Date().getFullYear() %> <%= siteSettings.site_title || 'NodePress CMS' %>. All rights reserved.</span>
      <span>Powered by NodePress CMS</span>
    </div>
  </div>
</footer>
<div id="google_translate_element" class="translate-engine" aria-hidden="true"></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/site.js"></script>
<script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</body>
</html>
