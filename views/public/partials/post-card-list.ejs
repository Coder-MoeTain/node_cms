<% const dateStr = post.published_at ? formatDate(post.published_at) : '';
   const dateIso = post.published_at ? post.published_at.toISOString().slice(0, 10) : '';
   const featuredImage = typeof resolvePublicMediaUrl === 'function'
     ? resolvePublicMediaUrl(post.featured_image)
     : (post.featured_image || '');
   const hasThumb = Boolean(featuredImage);
%>
<article class="site-post-item<%= hasThumb ? ' has-thumb' : '' %>">
  <% if (hasThumb) { %>
    <a class="site-post-thumb" href="<%= postUrl(post) %>" aria-hidden="true" tabindex="-1">
      <img src="<%= featuredImage %>" alt="<%= post.title %>" loading="lazy">
    </a>
  <% } %>
  <div class="site-post-main">
    <div class="site-post-meta">
      <% if (post.Category) { %><span class="post-card-category"><%= post.Category.name %></span><% } %>
      <% if (dateStr) { %><time datetime="<%= dateIso %>"><%= dateStr %></time><% } %>
      <%- include('post-edit-link', { post }) %>
    </div>
    <h3 class="site-post-title"><a href="<%= postUrl(post) %>"><%= post.title %></a></h3>
    <% if (post.excerpt) { %><p class="site-post-excerpt"><%= post.excerpt.length > 160 ? post.excerpt.slice(0, 160) + '…' : post.excerpt %></p><% } %>
    <a class="post-card-read" href="<%= postUrl(post) %>">Read article <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
  </div>
</article>
