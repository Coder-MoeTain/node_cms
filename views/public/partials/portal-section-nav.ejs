<% const cfg = portalConfig || {}; const hp = cfg.homepage || {};
   const sections = [];
   if (hp.sectionNav) {
     if (hp.quickLinks || hp.quickServices) sections.push({ id: 'portal-quick-services', label: 'Services' });
     if (hp.emergency) sections.push({ id: 'portal-emergency', label: 'Emergency' });
     if (hp.latestNews) sections.push({ id: 'portal-news', label: 'News' });
     if (hp.announcements) sections.push({ id: 'portal-announcements', label: 'Announcements' });
     if (hp.tendersJobs) sections.push({ id: 'portal-tenders', label: 'Tenders & Jobs' });
     if (hp.mobileApp) sections.push({ id: 'portal-mobile-app', label: 'Mobile Apps' });
     if (hp.mediaGallery) sections.push({ id: 'portal-media', label: 'Media' });
     if (hp.hotNews) sections.push({ id: 'portal-hot', label: 'Hot News' });
     if (hp.statistics) sections.push({ id: 'portal-stats', label: 'Statistics' });
   }
%>
<% if (sections.length) { %>
<nav class="portal-section-nav" aria-label="Homepage sections" data-portal-section-nav>
  <div class="container portal-section-nav-inner">
    <% sections.forEach(function(section) { %>
      <a class="portal-section-nav-link" href="#<%= section.id %>" data-section-target="<%= section.id %>"><%= section.label %></a>
    <% }) %>
  </div>
</nav>
<% } %>
