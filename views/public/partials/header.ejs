<nav class="navbar navbar-expand-lg site-navbar sticky-top header-layout-<%= activeTheme.header_layout || 'standard' %>">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">
      <% const siteLogo = siteSettings.site_logo || activeTheme.logo; %>
      <% if (siteLogo) { %><img class="site-logo" src="<%= siteLogo %>" alt="<%= siteSettings.site_title || 'NodePress CMS' %>"><% } else { %><span class="brand-mark">NP</span><%= siteSettings.site_title || 'NodePress CMS' %><% } %>
    </a>
    <button class="navbar-toggler site-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu"><span></span><span></span><span></span></button>
    <div class="collapse navbar-collapse" id="mainMenu">
      <ul class="navbar-nav mx-lg-auto">
        <% (siteMenus.header || []).forEach(function(item) { %>
          <% if (item.children && item.children.length) { %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="<%= item.url %>" target="<%= item.target %>" role="button" data-bs-toggle="dropdown" aria-expanded="false"><%= item.title %></a>
              <ul class="dropdown-menu dropdown-menu-end">
                <% item.children.forEach(function(child) { %>
                  <li><a class="dropdown-item" href="<%= child.url %>" target="<%= child.target %>"><%= child.title %></a></li>
                <% }) %>
              </ul>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="<%= item.url %>" target="<%= item.target %>"><%= item.title %></a></li>
          <% } %>
        <% }) %>
      </ul>
      <form class="nav-search-wrap" action="/search" role="search">
        <input class="form-control form-control-sm nav-search" name="q" placeholder="Search..." aria-label="Search">
        <button class="nav-search-button" type="submit">Search</button>
      </form>
      <div class="dropdown language-switcher">
        <button
          class="language-toggle dropdown-toggle"
          type="button"
          id="languageMenu"
          data-bs-toggle="dropdown"
          aria-expanded="false"
          aria-haspopup="true"
          aria-label="Choose language"
        >
          <i class="bi bi-globe2" aria-hidden="true"></i>
          <span class="language-current">English</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end language-menu" aria-labelledby="languageMenu">
          <li class="language-menu-label">Language</li>
          <li>
            <button type="button" class="dropdown-item language-option" data-lang="en" data-label="English">
              <span class="language-option-text"><span class="language-code">EN</span> English</span>
              <i class="bi bi-check2 language-check" aria-hidden="true"></i>
            </button>
          </li>
          <li>
            <button type="button" class="dropdown-item language-option" data-lang="my" data-label="Myanmar">
              <span class="language-option-text"><span class="language-code">MY</span> Myanmar</span>
              <i class="bi bi-check2 language-check" aria-hidden="true"></i>
            </button>
          </li>
          <li>
            <button type="button" class="dropdown-item language-option" data-lang="zh-CN" data-label="Chinese">
              <span class="language-option-text"><span class="language-code">ZH</span> Chinese</span>
              <i class="bi bi-check2 language-check" aria-hidden="true"></i>
            </button>
          </li>
          <li>
            <button type="button" class="dropdown-item language-option" data-lang="ru" data-label="Russian">
              <span class="language-option-text"><span class="language-code">RU</span> Russian</span>
              <i class="bi bi-check2 language-check" aria-hidden="true"></i>
            </button>
          </li>
        </ul>
      </div>
    </div>
  </div>
</nav>
