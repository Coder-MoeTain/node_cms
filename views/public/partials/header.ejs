<% /* isPortal from siteContext */
   const hdr = portalConfig.header || {};
   const nav = portalConfig.nav || {};
   const siteLogo = siteSettings.site_logo || activeTheme.logo;
   const portalDefaultNav = [
     { title: 'Home', url: '/', children: [] },
     { title: 'About', url: '/page/about', children: [
       { title: 'History', url: '/page/about' },
       { title: 'National Symbols', url: '/category/documents' },
       { title: 'Geography', url: '/blog' },
       { title: 'Culture', url: '/blog' },
       { title: 'Travel', url: '/blog' }
     ]},
     { title: 'Nation', url: '/blog', children: [
       { title: 'Government Organizations', url: '/blog' },
       { title: 'Directory', url: '/blog' },
       { title: 'Committees', url: '/blog' }
     ]},
     { title: 'Topics', url: '/blog', children: [
       { title: 'Health', url: '/category/health' },
       { title: 'Education', url: '/category/education' },
       { title: 'Economy', url: '/category/economy' },
       { title: 'Agriculture', url: '/category/agriculture' },
       { title: 'Law & Justice', url: '/search?q=law' },
       { title: 'Security', url: '/search?q=security' },
       { title: 'Technology', url: '/search?q=technology' },
       { title: 'Transportation', url: '/search?q=transportation' },
       { title: 'Finance', url: '/search?q=finance' },
       { title: 'Sports', url: '/search?q=sports' }
     ]},
     { title: 'Services', url: '/category/services', children: [
       { title: 'Online Services', url: '/blog' },
       { title: 'Forms', url: '/search?q=forms' },
       { title: 'Documents', url: '/category/documents' },
       { title: 'Public Holidays', url: '/page/public-holidays' }
     ]},
     { title: 'Contact', url: '/contact', children: [] }
   ];
   const standardDefaultNav = [
     { title: 'Home', url: '/', children: [] },
     { title: 'Blog', url: '/blog', children: [] },
     { title: 'Contact', url: '/contact', children: [] }
   ];
   const menuItems = (siteMenus.header && siteMenus.header.length)
     ? siteMenus.header
     : (isPortal ? portalDefaultNav : standardDefaultNav);
   const cp = (typeof currentPath !== 'undefined' ? currentPath : '') || '';
   function portalNavActive(url, children) {
     if (url === '/') return cp === '/' || cp === '';
     if (cp === url || (url.length > 1 && cp.indexOf(url) === 0)) return true;
     if (children && children.length) {
       for (let i = 0; i < children.length; i++) {
         const cu = children[i].url || '';
         if (cp === cu || (cu.length > 1 && cp.indexOf(cu) === 0)) return true;
       }
     }
     return false;
   }
   function portalChildActive(url) {
     if (!url || url === '/') return cp === '/' || cp === '';
     return cp === url || (url.length > 1 && cp.indexOf(url) === 0);
   }
%>

<% if (isPortal) { %>
<header class="portal-header <%= nav.sticky ? 'portal-header-sticky' : '' %>" data-portal-header>
  <% if (hdr.showUtilityBar) { %>
  <div class="portal-utility-bar">
    <div class="container portal-utility-inner">
      <% if (hdr.showFontControls !== false) { %>
      <div class="portal-font-controls" role="group" aria-label="Font size">
        <button type="button" class="portal-font-btn" data-font-scale="small" aria-label="Decrease font size">A-</button>
        <button type="button" class="portal-font-btn active" data-font-scale="normal" aria-label="Default font size">A</button>
        <button type="button" class="portal-font-btn" data-font-scale="large" aria-label="Increase font size">A+</button>
      </div>
      <% } %>
      <div class="portal-utility-right">
        <% if (themePreset === 'myanmar-portal') { %>
        <div class="portal-mnp-socials" aria-label="Social media">
          <% if (siteSettings.facebook_link) { %><a href="<%= siteSettings.facebook_link %>" rel="noopener" aria-label="Facebook"><i class="bi bi-facebook"></i></a><% } %>
          <% if (siteSettings.youtube_link) { %><a href="<%= siteSettings.youtube_link %>" rel="noopener" aria-label="YouTube"><i class="bi bi-youtube"></i></a><% } %>
          <a href="/contact" aria-label="Contact"><i class="bi bi-envelope"></i></a>
        </div>
        <% } %>
        <% if (hdr.showLanguageSwitcher) { %>
        <%- include('language-switcher', { langSwitcherVariant: 'portal' }) %>
        <% } %>
        <% if (hdr.showLoginLinks && !isAdminLoggedIn && !adminHoneypotEnabled) { %>
        <a class="portal-utility-link" href="<%= adminLoginUrl || '/admin/login' %>">Login</a>
        <a class="portal-utility-link portal-utility-link-accent" href="/contact?subject=Citizen+registration+request">Register</a>
        <% } else if (hdr.showLoginLinks && isAdminLoggedIn) { %>
        <a class="portal-utility-link" href="/admin">Dashboard</a>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>

  <div class="portal-identity-bar">
    <div class="container portal-identity-inner">
      <a class="portal-brand" href="/">
        <% if (siteLogo) { %><img class="portal-brand-logo" src="<%= siteLogo %>" alt="<%= siteSettings.site_title || 'NodePress CMS' %>"><% } else if (themePreset === 'myanmar-portal') { %><span class="portal-brand-mark portal-brand-seal" aria-hidden="true"></span><% } else { %><span class="portal-brand-mark">NP</span><% } %>
        <div class="portal-brand-text">
          <% if (themePreset === 'myanmar-portal') { %>
            <strong class="portal-brand-title portal-brand-mnp">
              <span class="portal-brand-line"><%= siteSettings.site_title || 'NodePress CMS' %></span>
              <span class="portal-brand-line portal-brand-line-gold"><%= siteSettings.site_tagline || 'Official information portal' %></span>
            </strong>
          <% } else { %>
            <strong class="portal-brand-title"><%= siteSettings.site_title || 'NodePress CMS' %></strong>
            <span class="portal-brand-tagline"><%= siteSettings.site_tagline || 'Official information portal powered by NodePress' %></span>
          <% } %>
        </div>
      </a>
      <% if (hdr.showSearch) { %>
      <form class="portal-header-search" action="/search" role="search">
        <label class="visually-hidden" for="portal-search">Search</label>
        <input class="form-control" id="portal-search" name="q" type="search" placeholder="Search news, services, documents…" aria-label="Search" autocomplete="off">
        <button class="portal-search-btn" type="submit" aria-label="Submit search"><i class="bi bi-search" aria-hidden="true"></i></button>
      </form>
      <% } %>
    </div>
  </div>

  <nav class="portal-nav-bar portal-nav-style-<%= nav.style || 'simple' %> <%= nav.megaMenu ? 'portal-nav-mega' : '' %>" aria-label="Main navigation">
    <div class="container">
      <button class="portal-mobile-toggle" type="button" data-portal-menu-toggle aria-expanded="false" aria-controls="portalMainNav">
        <span class="portal-mobile-toggle-label">Menu</span>
        <span class="portal-mobile-toggle-icon" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
      <div class="portal-nav-collapse" id="portalMainNav" data-portal-nav>
        <ul class="portal-nav-list">
          <% menuItems.forEach(function(item) { %>
            <% if (item.children && item.children.length && (nav.megaMenu || item.children.length > 3)) { %>
              <li class="portal-nav-item has-mega">
                <a class="portal-nav-link <%= portalNavActive(item.url, item.children) ? 'is-active' : '' %>" href="<%= item.url %>" target="<%= item.target || '_self' %>" <%= portalNavActive(item.url, item.children) ? 'aria-current="page"' : '' %>><%= item.title %><i class="bi bi-chevron-down portal-nav-chevron" aria-hidden="true"></i></a>
                <button class="portal-nav-submenu-toggle" type="button" aria-expanded="false" aria-label="Toggle <%= item.title %> submenu"><i class="bi bi-chevron-down" aria-hidden="true"></i></button>
                <div class="portal-mega-panel">
                  <div class="portal-mega-grid">
                    <% item.children.forEach(function(child) { %>
                      <a class="portal-mega-link <%= portalChildActive(child.url) ? 'is-active' : '' %>" href="<%= child.url %>" target="<%= child.target || '_self' %>" <%= portalChildActive(child.url) ? 'aria-current="page"' : '' %>><%= child.title %></a>
                    <% }) %>
                  </div>
                </div>
              </li>
            <% } else if (item.children && item.children.length) { %>
              <li class="portal-nav-item has-dropdown">
                <a class="portal-nav-link <%= portalNavActive(item.url, item.children) ? 'is-active' : '' %>" href="<%= item.url %>" target="<%= item.target || '_self' %>" <%= portalNavActive(item.url, item.children) ? 'aria-current="page"' : '' %>><%= item.title %><i class="bi bi-chevron-down portal-nav-chevron" aria-hidden="true"></i></a>
                <button class="portal-nav-submenu-toggle" type="button" aria-expanded="false" aria-label="Toggle <%= item.title %> submenu"><i class="bi bi-chevron-down" aria-hidden="true"></i></button>
                <ul class="portal-dropdown-menu">
                  <% item.children.forEach(function(child) { %>
                    <li><a class="<%= portalChildActive(child.url) ? 'is-active' : '' %>" href="<%= child.url %>" target="<%= child.target || '_self' %>" <%= portalChildActive(child.url) ? 'aria-current="page"' : '' %>><%= child.title %></a></li>
                  <% }) %>
                </ul>
              </li>
            <% } else { %>
              <li class="portal-nav-item"><a class="portal-nav-link <%= portalNavActive(item.url, item.children) ? 'is-active' : '' %>" href="<%= item.url %>" target="<%= item.target || '_self' %>" <%= portalNavActive(item.url, item.children) ? 'aria-current="page"' : '' %>><%= item.title %></a></li>
            <% } %>
          <% }) %>
        </ul>
      </div>
    </div>
  </nav>
  <div class="portal-mobile-overlay" data-portal-overlay hidden></div>
</header>
<% } else { %>
<% const stdUtilityBar = (portalConfig.header && portalConfig.header.showUtilityBar) || siteSettings.show_utility_bar === 'true'; %>
<%- include('standard-utility-bar') %>
<header class="site-header" data-site-header>
<nav class="navbar navbar-expand-lg site-navbar sticky-top header-layout-<%= activeTheme.header_layout || 'standard' %>">
  <div class="container">
    <a class="navbar-brand" href="/">
      <% if (siteLogo) { %><img class="site-logo" src="<%= siteLogo %>" alt="<%= siteSettings.site_title || 'NodePress CMS' %>"><% } else { %><span class="brand-mark">NP</span><span class="brand-text"><%= siteSettings.site_title || 'NodePress CMS' %></span><% } %>
    </a>
    <button class="navbar-toggler site-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu" aria-controls="mainMenu" aria-expanded="false" aria-label="Toggle navigation"><span></span><span></span><span></span></button>
    <div class="collapse navbar-collapse" id="mainMenu" data-site-nav>
      <ul class="navbar-nav mx-lg-auto">
        <% menuItems.forEach(function(item) { %>
          <% if (item.children && item.children.length) { %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle <%= portalNavActive(item.url, item.children) ? 'active' : '' %>" href="<%= item.url %>" target="<%= item.target || '_self' %>" role="button" data-bs-toggle="dropdown" aria-expanded="false" <%= portalNavActive(item.url, item.children) ? 'aria-current="page"' : '' %>><%= item.title %></a>
              <ul class="dropdown-menu dropdown-menu-end">
                <% item.children.forEach(function(child) { %>
                  <li><a class="dropdown-item <%= portalChildActive(child.url) ? 'active' : '' %>" href="<%= child.url %>" target="<%= child.target || '_self' %>" <%= portalChildActive(child.url) ? 'aria-current="page"' : '' %>><%= child.title %></a></li>
                <% }) %>
              </ul>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link <%= portalNavActive(item.url, item.children) ? 'active' : '' %>" href="<%= item.url %>" target="<%= item.target || '_self' %>" <%= portalNavActive(item.url, item.children) ? 'aria-current="page"' : '' %>><%= item.title %></a></li>
          <% } %>
        <% }) %>
      </ul>
      <div class="site-navbar-tools">
        <% if (!stdUtilityBar) { %>
        <div class="site-font-controls" role="group" aria-label="Font size">
          <button type="button" class="site-font-btn" data-font-scale="small" aria-label="Decrease font size">A-</button>
          <button type="button" class="site-font-btn active" data-font-scale="normal" aria-label="Default font size">A</button>
          <button type="button" class="site-font-btn" data-font-scale="large" aria-label="Increase font size">A+</button>
        </div>
        <% } %>
        <form class="nav-search-wrap" action="/search" role="search">
          <label class="visually-hidden" for="nav-search">Search</label>
          <input class="form-control form-control-sm nav-search" id="nav-search" name="q" type="search" placeholder="Search..." aria-label="Search" autocomplete="off">
          <button class="nav-search-button" type="submit" aria-label="Submit search"><i class="bi bi-search" aria-hidden="true"></i><span class="visually-hidden">Search</span></button>
        </form>
        <%- include('language-switcher', { langSwitcherVariant: 'dropdown' }) %>
      </div>
    </div>
  </div>
</nav>
</header>
<% } %>
