{
  "name": "nodepress-cms",
  "version": "1.0.0",
  "description": "A WordPress-like blog CMS built with Node.js, Express, MySQL, Sequelize, EJS, and Bootstrap 5.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:sync": "node database/sync.js",
    "seed": "node database/seed.js",
    "migrate": "node database/migrate.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "audit": "npm audit"
  },
  "keywords": [
    "cms",
    "blog",
    "wordpress",
    "express",
    "mysql",
    "sequelize",
    "ejs"
  ],
  "author": "NodePress CMS",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "latest",
    "bootstrap-icons": "^1.13.1",
    "compression": "latest",
    "connect-flash": "latest",
    "connect-session-sequelize": "latest",
    "cookie-parser": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "ejs": "latest",
    "express": "latest",
    "express-ejs-layouts": "latest",
    "express-rate-limit": "latest",
    "express-session": "latest",
    "express-validator": "latest",
    "helmet": "latest",
    "jest": "^30.4.2",
    "method-override": "latest",
    "morgan": "latest",
    "multer": "latest",
    "mysql2": "latest",
    "qrcode": "^1.5.4",
    "sanitize-html": "latest",
    "sequelize": "latest",
    "sharp": "^0.35.2",
    "slugify": "latest",
    "speakeasy": "^2.0.0",
    "supertest": "^7.2.2",
    "tinymce": "^8.6.0",
    "unzipper": "^0.12.5",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "latest"
  }
}
