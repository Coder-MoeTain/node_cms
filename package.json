{
  "name": "nodepress-cms",
  "version": "1.1.0",
  "description": "A modern blog and portal CMS built with Node.js, Express, MySQL, Sequelize, EJS, and Bootstrap 5.",
  "main": "server.js",
  "bin": {
    "nodepress": "./bin/nodepress"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:sync": "node database/sync.js",
    "seed": "node database/seed.js",
    "reset-admin": "node database/reset-admin.js",
    "assign-photos": "node database/assign-photos.js",
    "purge-missing-featured-images": "node database/purge-missing-featured-images.js",
    "migrate": "node database/migrate.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:ci": "cross-env NODE_ENV=test jest --runInBand --forceExit --ci --coverage",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --forceExit --coverage",
    "test:watch": "cross-env NODE_ENV=test jest --runInBand --watch",
    "migrate:status": "node database/migrate.js status",
    "backup:scheduled": "node scripts/scheduled-backup.js",
    "format:css": "node scripts/format-css.js",
    "sync:vendors": "node scripts/sync-vendor-assets.js",
    "postinstall": "node scripts/sync-vendor-assets.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "audit": "npm audit",
    "backup": "node scripts/backup.js",
    "health": "node scripts/health-check.js",
    "publish:scheduled": "node scripts/publish-scheduled.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:reload": "pm2 reload ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop nodepress-cms",
    "deploy:remote": "bash scripts/remote-deploy.sh",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down -v",
    "validate": "npm run lint && npm run migrate:status && npm run test",
    "check": "npm run validate && npm audit --audit-level=high",
    "predeploy": "npm run test:ci"
  },
  "keywords": [
    "cms",
    "blog",
    "portal",
    "express",
    "mysql",
    "sequelize",
    "ejs"
  ],
  "author": "NodePress CMS",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "bcrypt": "^6.0.0",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.13.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-session-sequelize": "^8.0.6",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cropperjs": "^1.6.2",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "method-override": "^3.0.0",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.5",
    "sequelize": "^6.37.8",
    "sharp": "^0.35.2",
    "slugify": "^1.6.9",
    "speakeasy": "^2.0.0",
    "tinymce": "^8.6.0",
    "unzipper": "^0.12.5",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
