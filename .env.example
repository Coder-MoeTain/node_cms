APP_NAME="NodePress CMS"
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=nodepress_cms
DB_PORT=3306

TEST_DB_HOST=127.0.0.1
TEST_DB_USER=root
TEST_DB_PASSWORD=
TEST_DB_NAME=nodepress_cms_test
TEST_DB_PORT=3306

SESSION_SECRET=replace-with-a-long-random-secret
SESSION_NAME=nodepress.sid
SESSION_MAX_AGE=86400000

# Optional REST API key (send via X-API-Key header or Authorization: Bearer)
API_KEY=

# Optional outbound update check URL (SSRF-protected; HTTPS required in production)
UPDATE_CHECK_URL=

UPLOAD_PATH=public/uploads
MAX_FILE_SIZE=10485760
UPLOAD_MAX_SIZE_MB=25
SQL_RESTORE_MAX_SIZE_MB=100
ADMIN_SESSION_TIMEOUT_MINUTES=60

# Login brute-force protection (optional overrides)
# LOGIN_BRUTE_FORCE=true
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15
# LOGIN_MAX_IP_ATTEMPTS=10
# LOGIN_IP_WINDOW_MINUTES=15
# LOGIN_AUTO_BLOCK_IP_ATTEMPTS=25
# LOGIN_RATE_LIMIT_MAX=10
# LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
TRUST_PROXY=false
CORS_ORIGIN=http://localhost:3000
CDN_URL=
LOG_LEVEL=info
