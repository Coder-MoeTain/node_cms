APP_NAME="NodePress CMS"
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=nodepress_cms
DB_PORT=3306

TEST_DB_HOST=127.0.0.1
TEST_DB_USER=root
TEST_DB_PASSWORD=
TEST_DB_NAME=nodepress_cms_test
TEST_DB_PORT=3306

SESSION_SECRET=replace-with-a-long-random-secret
SESSION_NAME=nodepress.sid
SESSION_MAX_AGE=86400000

# Optional REST API key (send via X-API-Key header or Authorization: Bearer)
API_KEY=

# Optional outbound update check URL (SSRF-protected; HTTPS required in production)
UPDATE_CHECK_URL=

UPLOAD_PATH=public/uploads
MAX_FILE_SIZE=10485760
UPLOAD_MAX_SIZE_MB=25
MEDIA_UPLOAD_MAX_FILES=100
# Max photos per page in the post/slider media picker modal (up to 500)
MEDIA_GALLERY_PICKER_LIMIT=36
SQL_RESTORE_MAX_SIZE_MB=100
ADMIN_SESSION_TIMEOUT_MINUTES=60

# Login brute-force protection (optional overrides)
# LOGIN_BRUTE_FORCE=true
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15
# LOGIN_MAX_IP_ATTEMPTS=10
# LOGIN_IP_WINDOW_MINUTES=15
# LOGIN_AUTO_BLOCK_IP_ATTEMPTS=25
# LOGIN_RATE_LIMIT_MAX=10
# LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
TRUST_PROXY=false
CORS_ORIGIN=http://localhost:3000

# Content Security Policy — Cloudflare Web Analytics is allowed by default (disable with CSP_CLOUDFLARE_INSIGHTS=false).
# Optional extra CSP sources (comma-separated URLs/schemes)
# CSP_SCRIPT_SRC_EXTRA=
# CSP_STYLE_SRC_EXTRA=
# CSP_CONNECT_SRC_EXTRA=
CDN_URL=
LOG_LEVEL=info

# WebGuard ML WAF integration (optional)
# WEBGUARD_API_URL=http://127.0.0.1:8001
# WEBGUARD_API_KEY=your-service-api-key
# WEBGUARD_API_TOKEN=
# WEBGUARD_TIMEOUT_MS=500
# WEBGUARD_ALLOW_LOCALHOST=true
# WEBGUARD_FAIL_OPEN=true
# WEBGUARD_MODELS_STORAGE=storage/webguard-models
# WEBGUARD_MODELS_PATH=/path/to/webguard/models
# WEBGUARD_MODEL_UPLOAD_PATH=/api/models/upload
# WEBGUARD_UPLOAD_TIMEOUT_MS=120000
